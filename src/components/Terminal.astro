<!-- Animated Terminal -->
<div class="hero-term" role="region" aria-label="Animated terminal demonstration">
  <div class="term-bar">
    <span class="term-dot red"></span>
    <span class="term-dot yellow"></span>
    <span class="term-dot green"></span>
    <span class="term-title">arr-barr</span>
  </div>
  <div class="term-body" id="termBody"></div>
</div>

<style>
  .hero-term {
    position: relative;
    max-width: 520px; margin: 28px auto 0;
    background: #080c16;
    border: 1px solid rgba(99,102,241,0.15);
    border-radius: 10px; overflow: hidden;
    text-align: left;
    box-shadow: 0 8px 40px rgba(0,0,0,0.4);
  }
  .term-bar {
    display: flex; align-items: center; gap: 6px;
    padding: 8px 12px;
    background: rgba(15,22,41,0.8);
    border-bottom: 1px solid rgba(30,41,59,0.6);
  }
  .term-dot { width: 10px; height: 10px; border-radius: 50%; }
  .term-dot.red { background: #f87171; }
  .term-dot.yellow { background: #fbbf24; }
  .term-dot.green { background: #4ade80; }
  .term-title {
    margin-left: auto; font-size: 0.68rem; color: var(--text-muted);
    font-family: 'SF Mono', 'Fira Code', monospace; letter-spacing: 0.5px;
  }
  .term-body {
    padding: 14px 16px; height: 180px;
    font-family: 'SF Mono', 'Fira Code', Consolas, monospace;
    font-size: 0.78rem; line-height: 1.65;
    color: var(--text-dim); overflow: hidden;
  }
</style>

<script>
  const D = 't-dim', G = 't-green', C = 't-cyan', A = 't-amber';
  const s = (c: string, t: string) => `<span class="${c}">${t}</span>`;
  const dot = (c: string) => s(c, '&#x25CF;');
  const pad = (t: string) => s(D, t);

  const scenes = [
    { lines: [
      { type:'prompt', text:'$ arr health' },
      { type:'out', delay:400, text:s(C,'&#x25B8; NETWORK &amp; DOWNLOADS')+' '+s(G,'&#x2713;') },
      { type:'out', delay:150, text:'  '+dot(G)+' '+pad('gluetun         ')+s(G,'healthy')+pad('   85ms') },
      { type:'out', delay:100, text:'  '+dot(G)+' '+pad('transmission    ')+s(G,'healthy')+pad('   82ms') },
      { type:'out', delay:100, text:'  '+dot(G)+' '+pad('sabnzbd         ')+s(G,'healthy')+pad('   90ms') },
      { type:'out', delay:200, text:s(C,'&#x25B8; MEDIA MANAGERS')+' '+s(G,'&#x2713;') },
      { type:'out', delay:100, text:'  '+dot(G)+' '+pad('radarr          ')+s(G,'healthy')+pad('  125ms') },
      { type:'out', delay:100, text:'  '+dot(G)+' '+pad('sonarr          ')+s(G,'healthy')+pad('  167ms') },
      { type:'out', delay:100, text:'  '+dot(G)+' '+pad('lidarr          ')+s(G,'healthy')+pad('   79ms') },
      { type:'out', delay:100, text:'  '+dot(G)+' '+pad('bazarr          ')+s(G,'healthy')+pad('  101ms') },
      { type:'out', delay:150, text:pad('  ... +6 more all healthy') },
      { type:'out', delay:300, text:'' },
      { type:'out', delay:100, text:s(G,'15/15')+' '+pad('healthy') },
    ]},
    { lines: [
      { type:'prompt', text:'$ arr vpn' },
      { type:'out', delay:500, text:s(C,'TUNNEL') },
      { type:'out', delay:300, text:'  '+dot(G)+' '+s(G,'CONNECTED') },
      { type:'out', delay:200, text:'  Public IP '+pad('.........')+' xxx.xxx.xxx.xx' },
      { type:'out', delay:200, text:'  Location '+pad('..........')+' Amsterdam, NL' },
      { type:'out', delay:200, text:'  Provider '+pad('..........')+' '+pad('VPN Provider') },
      { type:'out', delay:300, text:s(C,'SERVICES IN TUNNEL') },
      { type:'out', delay:200, text:'  '+dot(G)+' '+pad('transmission  ')+pad(':9091  ')+s(G,'accessible') },
      { type:'out', delay:200, text:'  '+dot(G)+' '+pad('sabnzbd       ')+pad(':8080  ')+s(G,'accessible') },
      { type:'out', delay:400, text:'' },
      { type:'out', delay:100, text:s(G,'Your real IP is hidden.')+pad(' Download traffic is protected.') },
    ]},
    { lines: [
      { type:'prompt', text:'$ arr req movie "Galactic Plumber 3"' },
      { type:'out', delay:600, text:pad('Searching 12 indexers (4 usenet + 8 torrent)...') },
      { type:'out', delay:800, text:pad('found 47 results \u2014 scoring against 48 custom formats...') },
      { type:'out', delay:400, text:s(G,'&#x2713;')+' Galactic.Plumber.3.2024.2160p.IMAX.WEB-DL.DV.HDR.Atmos-FLUX' },
      { type:'out', delay:200, text:'  '+s(G,'+1700')+' WEB Tier 01 \u00b7 '+s(G,'+800')+' IMAX \u00b7 '+s(G,'+500')+' HDR \u00b7 '+s(G,'+75')+' Streaming' },
      { type:'out', delay:200, text:'  Score: '+s(G,'3075')+' \u2014 grabbing via tunnel '+pad('......')+' '+s(C,'encrypted') },
      { type:'out', delay:600, text:pad('hardlinked to library (0 bytes) \u00b7 Jellyfin notified') },
      { type:'out', delay:200, text:s(G,'&#x25CF; Ready to watch')+pad(' \u2014 4K Dolby Vision') },
    ]},
    { lines: [
      { type:'prompt', text:'$ arr dl --once' },
      { type:'out', delay:400, text:s(C,'TORRENTS (Transmission)')+pad('            &#x25B2; 4.2 MB/s') },
      { type:'out', delay:200, text:'  '+s(A,'SEEDING')+pad(' (14)') },
      { type:'out', delay:150, text:'  '+pad('Space.Cowboy.S02.1080p...')+pad('   ratio 0.32 ')+s(C,'&#x25B2;')+pad(' 841 KB/s') },
      { type:'out', delay:150, text:'  '+pad('Neon.Depths.2024.2160p...')+pad('   ratio 1.71 ')+s(C,'&#x25B2;')+pad('  15 KB/s') },
      { type:'out', delay:150, text:pad('  ... and 12 more seeding') },
      { type:'out', delay:300, text:s(C,'USENET (SABnzbd)')+pad('                      Idle') },
      { type:'out', delay:200, text:'  '+s(G,'&#x2713;')+' '+pad('Phantom.Route.S01.2160p.WEB-DL')+pad('    25.5 GB') },
      { type:'out', delay:200, text:'  '+s(G,'&#x2713;')+' '+pad('Signal.Lost.S03E07.1080p')+pad('          314 MB') },
      { type:'out', delay:300, text:'' },
      { type:'out', delay:100, text:pad('Total: 14 seeding, 0 downloading') },
    ]},
  ];

  function sleep(ms: number) { return new Promise(r => setTimeout(r, ms)); }

  let sceneIdx = 0;

  let currentAbort: AbortController | null = null;

  async function runSceneAbortable(scene: typeof scenes[0], signal: AbortSignal) {
    const body = document.getElementById('termBody');
    if (!body) return;
    body.innerHTML = '';
    for (const line of scene.lines) {
      if (signal.aborted) return;
      const div = document.createElement('div');
      div.style.cssText = 'margin:2px 0;min-height:1.65em;';
      body.appendChild(div);
      if (line.type === 'prompt') {
        const parts = line.text.split(' '), prompt = parts[0], cmd = parts.slice(1).join(' ');
        div.innerHTML = `<span class="t-amber">${prompt}</span> <span class="t-cmd"></span><span class="term-cursor"></span>`;
        const cmdEl = div.querySelector('.t-cmd')!;
        const cur = div.querySelector('.term-cursor')!;
        for (let i = 0; i <= cmd.length; i++) { if (signal.aborted) return; cmdEl.textContent = cmd.slice(0,i); await sleep(45); }
        cur.remove(); await sleep(200);
      } else { await sleep(line.delay||100); div.innerHTML = line.text; }
    }
  }

  function skipToNextScene() {
    if (currentAbort) currentAbort.abort();
  }

  async function termLoop() {
    while (true) {
      currentAbort = new AbortController();
      await runSceneAbortable(scenes[sceneIdx], currentAbort.signal);
      if (!currentAbort.signal.aborted) await sleep(3000);
      sceneIdx = (sceneIdx + 1) % scenes.length;
    }
  }

  // Click to skip to next scene
  document.querySelector('.hero-term')?.addEventListener('click', skipToNextScene);

  termLoop();
</script>

<style is:global>
  .t-dim { color: var(--text-muted); }
  .t-green { color: var(--green); }
  .t-cyan { color: var(--cyan); }
  .t-amber { color: var(--yellow); }
  .t-cmd { color: var(--text); }
  .term-cursor {
    display: inline-block; width: 7px; height: 14px;
    background: var(--yellow); vertical-align: text-bottom;
    animation: blink 1s step-end infinite; margin-left: 1px;
  }
  @keyframes blink { 50% { opacity: 0; } }
</style>

  function sleep(ms: number) { return new Promise(r => setTimeout(r, ms)); }

  let sceneIdx = 0;
  let currentAbort: AbortController | null = null;

  // ── Logo animation handler ──
  async function animateLogo(body: HTMLElement, signal: AbortSignal): Promise<void> {
    const logoDiv = document.createElement('div');
    logoDiv.style.cssText = 'white-space:pre;font-size:0.55rem;line-height:1.2;';
    body.appendChild(logoDiv);

    // Flash through colors (8 frames × 75ms = 600ms)
    for (const color of LOGO_COLORS) {
      if (signal.aborted) return;
      logoDiv.innerHTML = LOGO_LINES.map(l => s(color, l)).join('\n');
      await sleep(75);
    }
    // Add TECHNOLOGIES tagline in cyan
    logoDiv.innerHTML += '\n' + s(C, LOGO_TAGLINE);
    await sleep(100);
    body.scrollTop = body.scrollHeight;
  }

  // ── arr start animation handler ──
  async function animateStart(body: HTMLElement, signal: AbortSignal): Promise<void> {
    // Create service lines with spinners
    const serviceElements: HTMLElement[] = [];
    const groupStartIdx = [0, 3, 5, 9, 11, 14]; // Where each group starts

    for (let i = 0; i < SERVICES.length; i++) {
      if (signal.aborted) return;
      const svc = SERVICES[i];
      const div = document.createElement('div');
      div.style.cssText = 'margin:1px 0;min-height:1.4em;';
      div.innerHTML = s(SAP, SPIN[0]) + '  ' + pad(svc.name.padEnd(16)) + pad(svc.desc);
      div.dataset.idx = String(i);
      body.appendChild(div);
      serviceElements.push(div);
      await sleep(20);
    }

    // Progress bar line
    const barDiv = document.createElement('div');
    barDiv.style.cssText = 'margin:8px 0 4px;min-height:1.4em;';
    body.appendChild(barDiv);
    body.scrollTop = body.scrollHeight;

    // Animate spinners + progress
    let completed = 0;
    const completionTimes = [1200, 1200, 1200, 1400, 1400, 1700, 1700, 1700, 1700, 1900, 1900, 2100, 2100, 2100, 2300];
    const startTime = Date.now();
    const completedSet = new Set<number>();

    // Group header elements (to be inserted)
    const groupHeaders: (HTMLElement | null)[] = [null, null, null, null, null, null];
    const groupInserted = [false, false, false, false, false, false];

    while (completed < 15) {
      if (signal.aborted) return;
      const elapsed = Date.now() - startTime;

      // Update spinners and check completions
      for (let i = 0; i < SERVICES.length; i++) {
        if (!completedSet.has(i)) {
          if (elapsed >= completionTimes[i]) {
            // Complete this service
            const svc = SERVICES[i];
            serviceElements[i].innerHTML = s(G, '●') + '  ' + s(TXT, svc.name.padEnd(16)) + pad(svc.desc) + '  ' + s(OV, svc.port);
            completedSet.add(i);
            completed++;

            // Check if group is complete
            const group = svc.group;
            const groupServices = SERVICES.filter(s => s.group === group);
            const allGroupDone = groupServices.every((_, idx) => {
              const svcIdx = SERVICES.findIndex(s => s === groupServices[idx]);
              return completedSet.has(svcIdx);
            });

            if (allGroupDone && !groupInserted[group]) {
              // Insert group header after 100ms delay
              setTimeout(() => {
                if (signal.aborted) return;
                const headerDiv = document.createElement('div');
                headerDiv.style.cssText = 'margin:4px 0 2px;opacity:0;transition:opacity 200ms;';
                headerDiv.innerHTML = bold(GROUP_HEADERS[group].color, '▸ ' + GROUP_HEADERS[group].name) + ' ' + chk(G);
                // Insert before first service of this group
                const firstIdx = groupStartIdx[group];
                body.insertBefore(headerDiv, serviceElements[firstIdx]);
                setTimeout(() => { headerDiv.style.opacity = '1'; }, 10);
                groupHeaders[group] = headerDiv;
              }, 100);
              groupInserted[group] = true;
            }
          } else {
            // Animate spinner
            const frame = Math.floor(elapsed / 80) % SPIN.length;
            const svc = SERVICES[i];
            serviceElements[i].innerHTML = s(SAP, SPIN[frame]) + '  ' + pad(svc.name.padEnd(16)) + pad(svc.desc);
          }
        }
      }

      // Update progress bar
      const barWidth = 35;
      const filled = Math.floor(completed * barWidth / 15);
      let bar = '█'.repeat(filled) + '░'.repeat(barWidth - filled);
      barDiv.innerHTML = s(SAP, bar) + '  ' + s(TXT, `${completed}/15`);

      await sleep(40);
      body.scrollTop = body.scrollHeight;
    }

    // Wave animation at 15/15
    const waveStart = Date.now();
    while (Date.now() - waveStart < 1200) {
      if (signal.aborted) return;
      const offset = Math.floor((Date.now() - waveStart) / 80);
      barDiv.innerHTML = s(SAP, waveFrame(offset)) + '  ' + s(G, '15/15');
      await sleep(40);
    }

    // Clear and show completion
    await sleep(200);
    if (signal.aborted) return;

    // Add completion output
    const completionLines = [
      '',
      s(S1, '─'.repeat(58)),
      '  ' + bold(G, 'ALL SYSTEMS OPERATIONAL'),
      '  ' + s(TXT, '15 containers launched successfully'),
      '    ' + pad('arr status   — detailed health check'),
      '    ' + pad('arr logs     — view container logs'),
    ];

    for (const lineText of completionLines) {
      if (signal.aborted) return;
      const div = document.createElement('div');
      div.style.cssText = 'margin:1px 0;min-height:1.4em;';
      div.innerHTML = lineText;
      body.appendChild(div);
      body.scrollTop = body.scrollHeight;
      await sleep(50);
    }
  }

  async function runSceneAbortable(scene: typeof scenes[0], signal: AbortSignal) {
    const body = document.getElementById('termBody');
    if (!body) return;
    body.innerHTML = '';

    for (const line of scene.lines) {
      if (signal.aborted) return;

      // Auto-scroll: keep latest content visible
      body.scrollTop = body.scrollHeight;

      if (line.type === 'prompt') {
        const div = document.createElement('div');
        div.style.cssText = 'margin:1px 0;min-height:1.4em;';
        body.appendChild(div);
        const parts = line.text!.split(' '), prompt = parts[0], cmd = parts.slice(1).join(' ');
        div.innerHTML = `<span class="t-amber">${prompt}</span> <span class="t-cmd"></span><span class="term-cursor"></span>`;
        const cmdEl = div.querySelector('.t-cmd')!;
        const cur = div.querySelector('.term-cursor')!;
        for (let i = 0; i <= cmd.length; i++) {
          if (signal.aborted) return;
          cmdEl.textContent = cmd.slice(0,i);
          await sleep(35);
        }
        cur.remove();
        await sleep(200);

      } else if (line.type === 'logo') {
        await animateLogo(body, signal);

      } else if (line.type === 'box') {
        const div = document.createElement('div');
        div.style.cssText = 'margin:4px 0;white-space:pre;';
        div.innerHTML = boxHeader(line.title || '', line.emoji || '');
        body.appendChild(div);
        await sleep(100);

      } else if (line.type === 'start') {
        await animateStart(body, signal);

      } else if (line.type === 'menu') {
        // Interactive menu selection animation
        const menuDiv = document.createElement('div');
        menuDiv.style.cssText = 'margin:4px 0;white-space:pre;';
        body.appendChild(menuDiv);

        const options = ['Movie', 'TV Show', 'Music', 'Book', 'Game'];
        // Show menu with Movie highlighted
        menuDiv.innerHTML = s(P, '?') + ' ' + s(TXT, 'What are you looking for?') + '\n' +
          options.map((opt, i) =>
            i === 0
              ? '  ' + s(SAP, '▸') + ' ' + bold(TXT, opt)
              : '    ' + pad(opt)
          ).join('\n');

        await sleep(800);
        if (signal.aborted) return;

        // Change selected to green
        menuDiv.innerHTML = s(P, '?') + ' ' + s(TXT, 'What are you looking for?') + '\n' +
          options.map((opt, i) =>
            i === 0
              ? '  ' + s(G, '▸') + ' ' + bold(G, opt)
              : '    ' + pad(opt)
          ).join('\n');

        await sleep(300);
        if (signal.aborted) return;

        // Remove menu
        menuDiv.remove();

      } else if (line.type === 'spinner') {
        const div = document.createElement('div');
        div.style.cssText = 'margin:1px 0;min-height:1.4em;';
        body.appendChild(div);
        const dur = line.duration || 1000;
        const msg = line.msg || '';
        const start = Date.now();
        let frame = 0;
        while (Date.now() - start < dur) {
          if (signal.aborted) return;
          div.innerHTML = `<span class="t-sapphire">${SPIN[frame % SPIN.length]}</span> <span class="t-dim">${msg}</span>`;
          frame++;
          await sleep(80);
        }
        div.remove(); // spinner line disappears when done

      } else if (line.type === 'bar') {
        const div = document.createElement('div');
        div.style.cssText = 'margin:1px 0;min-height:1.4em;';
        body.appendChild(div);
        // Animated progress bar fill
        const target = line.pct || 50;
        const width = 30;
        const blocks = ['░','▏','▎','▍','▌','▋','▊','▉','█'];
        for (let p = 0; p <= target; p += 2) {
          if (signal.aborted) return;
          const filled = Math.floor(p * width / 100);
          const frac = Math.floor(((p * width / 100) - filled) * 8);
          let bar = '█'.repeat(filled);
          if (filled < width) bar += blocks[frac] || '░';
          bar += '░'.repeat(Math.max(0, width - filled - 1));
          const pctStr = p.toFixed(1) + '%';
          div.innerHTML = `  <span class="t-sapphire">${bar}</span>  <span class="t-text">${pctStr}</span>   <span class="t-dim">4.2 GB left   ETA 8m 12s</span>`;
          await sleep(20);
        }

      } else {
        const div = document.createElement('div');
        div.style.cssText = 'margin:1px 0;min-height:1.4em;';
        body.appendChild(div);
        await sleep(line.delay || 100);
        div.innerHTML = line.text || '';
      }

      body.scrollTop = body.scrollHeight;
    }
  }

  function skipToNextScene() {
    if (currentAbort) currentAbort.abort();
  }

  async function termLoop() {
    while (true) {
      currentAbort = new AbortController();
      await runSceneAbortable(scenes[sceneIdx], currentAbort.signal);
      if (!currentAbort.signal.aborted) await sleep(3000);
      sceneIdx = (sceneIdx + 1) % scenes.length;
    }
  }

  document.querySelector('.hero-term')?.addEventListener('click', skipToNextScene);
  termLoop();
</script>


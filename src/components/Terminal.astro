<!-- Animated Terminal -->
<div class="hero-term">
  <div class="term-bar">
    <span class="term-dot red"></span>
    <span class="term-dot yellow"></span>
    <span class="term-dot green"></span>
    <span class="term-title">arr-barr</span>
  </div>
  <div class="term-body" id="termBody"></div>
</div>

<style>
  .hero-term {
    position: relative;
    max-width: 520px; margin: 28px auto 0;
    background: #080c16;
    border: 1px solid rgba(99,102,241,0.15);
    border-radius: 10px; overflow: hidden;
    text-align: left;
    box-shadow: 0 8px 40px rgba(0,0,0,0.4);
  }
  .term-bar {
    display: flex; align-items: center; gap: 6px;
    padding: 8px 12px;
    background: rgba(15,22,41,0.8);
    border-bottom: 1px solid rgba(30,41,59,0.6);
  }
  .term-dot { width: 10px; height: 10px; border-radius: 50%; }
  .term-dot.red { background: #f87171; }
  .term-dot.yellow { background: #fbbf24; }
  .term-dot.green { background: #4ade80; }
  .term-title {
    margin-left: auto; font-size: 0.68rem; color: var(--text-muted);
    font-family: 'SF Mono', 'Fira Code', monospace; letter-spacing: 0.5px;
  }
  .term-body {
    padding: 14px 16px; height: 180px;
    font-family: 'SF Mono', 'Fira Code', Consolas, monospace;
    font-size: 0.78rem; line-height: 1.65;
    color: var(--text-dim); overflow: hidden;
  }
</style>

<script>
  const D = 't-dim', G = 't-green', C = 't-cyan', A = 't-amber';
  const s = (c: string, t: string) => `<span class="${c}">${t}</span>`;
  const dot = (c: string) => s(c, '&#x25CF;');
  const pad = (t: string) => s(D, t);

  const scenes = [
    { lines: [
      { type:'prompt', text:'$ arr health' },
      { type:'out', delay:400, text:dot(G)+' gluetun '+pad('............')+' '+s(G,'tunnel up')+pad('        23ms') },
      { type:'out', delay:150, text:dot(G)+' transmission '+pad('........')+' '+s(G,'healthy')+pad('          41ms') },
      { type:'out', delay:150, text:dot(G)+' sabnzbd '+pad('............')+' '+s(G,'healthy')+pad('          38ms') },
      { type:'out', delay:150, text:dot(G)+' radarr '+pad('.............')+' '+s(G,'healthy')+pad('          52ms') },
      { type:'out', delay:150, text:dot(G)+' sonarr '+pad('.............')+' '+s(G,'healthy')+pad('          47ms') },
      { type:'out', delay:150, text:dot(G)+' lidarr '+pad('.............')+' '+s(G,'healthy')+pad('          44ms') },
      { type:'out', delay:150, text:dot(G)+' jellyfin '+pad('...........')+' '+s(G,'healthy')+pad('          31ms') },
      { type:'out', delay:300, text:'' },
      { type:'out', delay:100, text:s(G,'15/15 crew members reporting')+pad('         all systems nominal') },
    ]},
    { lines: [
      { type:'prompt', text:'$ arr vpn' },
      { type:'out', delay:500, text:dot(G)+' '+s(C,'Tunnel')+' '+pad('.....................')+' connected' },
      { type:'out', delay:200, text:'  Protocol '+pad('...................')+' WireGuard' },
      { type:'out', delay:200, text:'  Public IP '+pad('....................')+' '+s(C,'hidden') },
      { type:'out', delay:200, text:'  Location '+pad('...................')+' Netherlands' },
      { type:'out', delay:200, text:'  Kill switch '+pad('................')+' '+s(G,'active') },
      { type:'out', delay:200, text:'  DNS '+pad('.........................')+' encrypted' },
      { type:'out', delay:400, text:'' },
      { type:'out', delay:100, text:pad('All download traffic routed through encrypted tunnel') },
    ]},
    { lines: [
      { type:'prompt', text:'$ requesting "Dune: Part Two (2024)"' },
      { type:'out', delay:600, text:s(A,'Radarr')+pad(' searching 12 indexers across 4 usenet + 8 torrent...') },
      { type:'out', delay:800, text:pad('found 47 results \u2014 scoring against 48 custom formats...') },
      { type:'out', delay:400, text:s(G,'&#x2713;')+' Dune.Part.Two.2024.2160p.IMAX.WEB-DL.DV.HDR.Atmos-FLUX' },
      { type:'out', delay:200, text:'  '+s(G,'+1700')+' WEB Tier 01 \u00b7 '+s(G,'+800')+' IMAX \u00b7 '+s(G,'+500')+' HDR \u00b7 '+s(G,'+75')+' DSNP' },
      { type:'out', delay:200, text:'  Score: '+s(G,'3075')+' \u2014 grabbing via tunnel '+pad('............')+' '+s(C,'encrypted') },
      { type:'out', delay:600, text:pad('hardlinked to library (0 extra bytes) \u00b7 Jellyfin updated \u00b7 subs queued') },
      { type:'out', delay:200, text:s(G,'&#x25CF; Ready to watch')+pad('                            4K Dolby Vision') },
    ]},
    { lines: [
      { type:'prompt', text:'$ arr downloads --once' },
      { type:'out', delay:400, text:s(C,'&#x25BC; Downloading')+pad(' ......................................')+' 2 active' },
      { type:'out', delay:200, text:'  Akira.1988.UHD.BluRay.REMUX.DTS-HD.MA '+pad('.')+' '+s(G,'\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u258a')+pad('\u2591\u2591')+' '+s(G,'87%')+' 42MB/s' },
      { type:'out', delay:200, text:'  Ted.Lasso.S03.1080p.ATVP.WEB-DL.Atmos '+pad('.')+' '+s(A,'\u2588\u2588\u2588')+pad('\u2591\u2591\u2591\u2591\u2591\u2591\u2591')+' '+s(A,'34%')+' 28MB/s' },
      { type:'out', delay:200, text:'  DAMN.2017.FLAC.CD-DeVOiD '+pad('...............')+' '+s(G,'\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588')+pad('\u2591')+' '+s(G,'95%')+' 11MB/s' },
      { type:'out', delay:300, text:'' },
      { type:'out', delay:100, text:s(C,'&#x25B2; Seeding')+pad(' .........................................')+' 12 active' },
      { type:'out', delay:100, text:pad('  ratio 2.4 \u00b7 uploaded 847 GB \u00b7 tunnel ')+dot(G)+s(G,' up')+pad(' \u00b7 70 MB/s') },
    ]},
  ];

  function sleep(ms: number) { return new Promise(r => setTimeout(r, ms)); }

  let sceneIdx = 0;

  async function runScene(scene: typeof scenes[0]) {
    const body = document.getElementById('termBody');
    if (!body) return;
    body.innerHTML = '';
    for (const line of scene.lines) {
      const div = document.createElement('div');
      div.style.cssText = 'margin:2px 0;min-height:1.65em;';
      body.appendChild(div);
      if (line.type === 'prompt') {
        const parts = line.text.split(' '), prompt = parts[0], cmd = parts.slice(1).join(' ');
        div.innerHTML = `<span class="t-amber">${prompt}</span> <span class="t-cmd"></span><span class="term-cursor"></span>`;
        const cmdEl = div.querySelector('.t-cmd')!;
        const cur = div.querySelector('.term-cursor')!;
        for (let i = 0; i <= cmd.length; i++) { cmdEl.textContent = cmd.slice(0,i); await sleep(45); }
        cur.remove(); await sleep(200);
      } else { await sleep(line.delay||100); div.innerHTML = line.text; }
    }
  }

  async function termLoop() {
    while (true) {
      await runScene(scenes[sceneIdx]);
      await sleep(3000);
      sceneIdx = (sceneIdx + 1) % scenes.length;
    }
  }

  termLoop();
</script>

<style is:global>
  .t-dim { color: #64748b; }
  .t-green { color: #4ade80; }
  .t-cyan { color: #22d3ee; }
  .t-amber { color: #fbbf24; }
  .t-cmd { color: #e0e6f0; }
  .term-cursor {
    display: inline-block; width: 7px; height: 14px;
    background: #fbbf24; vertical-align: text-bottom;
    animation: blink 1s step-end infinite; margin-left: 1px;
  }
  @keyframes blink { 50% { opacity: 0; } }
</style>

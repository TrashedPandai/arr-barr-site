      s(S1, '╭' + '─'.repeat(34) + '╮'),
      s(S1, '│') + `<span class="t-gradient">${paddedInner.slice(0, 34)}</span>` + s(S1, '│'),
      s(S1, '╰' + '─'.repeat(34) + '╯'),
    ].join('\n');
  }

  function waveFrame(offset: number, width: number = 35): string {
    let bar = '';
    for (let i = 0; i < width; i++) {

---
interface Props {
  title?: string;
  description?: string;
}

import '../styles/global.css';

const { title = 'arr-barr — Your media. Your server. Your rules.', description = '15 self-hosted services in one repo. Movies, TV, music, books, and games — automated, encrypted, and streaming to any device.' } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content={description}>
  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="icon" type="image/x-icon" href="/favicon.ico">
  <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site || 'https://arrbarr.com').href}>

  <!-- Open Graph -->
  <meta property="og:type" content="website">
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:image" content="https://arrbarr.com/og.png">
  <meta property="og:url" content={new URL(Astro.url.pathname, Astro.site || 'https://arrbarr.com').href}>
  <meta property="og:site_name" content="arr-barr">

  <!-- Twitter / Discord -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content={title}>
  <meta name="twitter:description" content={description}>
  <meta name="twitter:image" content="https://arrbarr.com/og.png">

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "arr-barr",
    "url": "https://arrbarr.com",
    "description": "Open-source, self-hosted media automation stack. Movies, TV, music, books, audiobooks, and games — all in one repo.",
    "publisher": {
      "@type": "Organization",
      "name": "Pandai Technologies",
      "url": "https://github.com/TrashedPandai"
    }
  })}></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
</head>
<body>

<nav id="nav">
  <div class="nav-inner">
    <button class="nav-brand" id="helmBtn" aria-label="Scroll to top">
      <svg class="nav-logo" id="helmSvg" viewBox="0 0 40 40" width="30" height="30" aria-hidden="true">
        <defs>
          <linearGradient id="navGrad" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" stop-color="#c8a050"/>
            <stop offset="50%" stop-color="#8b6914"/>
            <stop offset="100%" stop-color="#a07828"/>
          </linearGradient>
          <linearGradient id="hubGrad" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" stop-color="#d4a04a"/>
            <stop offset="100%" stop-color="#6b4c12"/>
          </linearGradient>
        </defs>
        <g fill="none" stroke-linecap="round" stroke-linejoin="round">
          <!-- Outer ring — thick worn wood -->
          <circle cx="20" cy="20" r="16" stroke="#8b6914" stroke-width="2.5"/>
          <circle cx="20" cy="20" r="16" stroke="url(#navGrad)" stroke-width="1.8" opacity="0.7"/>
          <!-- Inner hub ring -->
          <circle cx="20" cy="20" r="5.5" stroke="#8b6914" stroke-width="2"/>
          <circle cx="20" cy="20" r="5.5" stroke="#c8a050" stroke-width="1" opacity="0.5"/>
          <!-- Center brass cap -->
          <circle cx="20" cy="20" r="2.5" fill="url(#hubGrad)" stroke="#6b4c12" stroke-width="0.5"/>
          <!-- 8 spokes — tapered, wood-grain feel -->
          <!-- Cardinal spokes (thicker) -->
          <line x1="20" y1="4" x2="20" y2="14.5" stroke="#8b6914" stroke-width="2.2"/>
          <line x1="20" y1="25.5" x2="20" y2="36" stroke="#8b6914" stroke-width="2.2"/>
          <line x1="4" y1="20" x2="14.5" y2="20" stroke="#8b6914" stroke-width="2.2"/>
          <line x1="25.5" y1="20" x2="36" y2="20" stroke="#8b6914" stroke-width="2.2"/>
          <!-- Diagonal spokes (thinner) -->
          <line x1="8.7" y1="8.7" x2="16" y2="16" stroke="#8b6914" stroke-width="1.6"/>
          <line x1="24" y1="24" x2="31.3" y2="31.3" stroke="#8b6914" stroke-width="1.6"/>
          <line x1="31.3" y1="8.7" x2="24" y2="16" stroke="#8b6914" stroke-width="1.6"/>
          <line x1="16" y1="24" x2="8.7" y2="31.3" stroke="#8b6914" stroke-width="1.6"/>
          <!-- Handle pegs at cardinal ends -->
          <circle cx="20" cy="3.2" r="2.2" fill="#a07828" stroke="#6b4c12" stroke-width="0.6"/>
          <circle cx="20" cy="36.8" r="2.2" fill="#a07828" stroke="#6b4c12" stroke-width="0.6"/>
          <circle cx="3.2" cy="20" r="2.2" fill="#a07828" stroke="#6b4c12" stroke-width="0.6"/>
          <circle cx="36.8" cy="20" r="2.2" fill="#a07828" stroke="#6b4c12" stroke-width="0.6"/>
          <!-- Wood grain highlight on outer ring -->
          <circle cx="20" cy="20" r="16" stroke="rgba(212,180,100,0.15)" stroke-width="0.5" stroke-dasharray="3 8"/>
        </g>
      </svg>
    </button>
    <button class="hamburger" id="hamburger" aria-label="Menu">&#9776;</button>
    <div class="nav-links" id="navLinks">
      <a href="/" class:list={["nav-link", { active: currentPath === "/" }]}>Home</a>
      <a href="/guide" class:list={["nav-link", { active: currentPath === "/guide" || currentPath === "/guide/" }]}>The Guide</a>
      <a href="/crew" class:list={["nav-link", { active: currentPath === "/crew" || currentPath === "/crew/" }]}>The Crew</a>
      <a href="/costs" class:list={["nav-link", { active: currentPath === "/costs" || currentPath === "/costs/" }]}>Costs</a>
      <a href="/docs" class:list={["nav-link", { active: currentPath.startsWith("/docs") }]}>Docs</a>
      <div class="nav-gh" id="navGh">
        <a href="https://github.com/TrashedPandai/arr-barr" class="nav-link nav-gh-link" target="_blank" rel="noopener" aria-label="GitHub">
          <svg width="18" height="18" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
        </a>
        <button class="nav-clone-btn" id="cloneBtn" aria-label="Copy clone URL">
          <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor" opacity="0.6"><path d="M0 6.75C0 5.784.784 5 1.75 5h1.5a.75.75 0 010 1.5h-1.5a.25.25 0 00-.25.25v7.5c0 .138.112.25.25.25h7.5a.25.25 0 00.25-.25v-1.5a.75.75 0 011.5 0v1.5A1.75 1.75 0 019.25 16h-7.5A1.75 1.75 0 010 14.25zM5 1.75C5 .784 5.784 0 6.75 0h7.5C15.216 0 16 .784 16 1.75v7.5A1.75 1.75 0 0114.25 11h-7.5A1.75 1.75 0 015 9.25zm1.75-.25a.25.25 0 00-.25.25v7.5c0 .138.112.25.25.25h7.5a.25.25 0 00.25-.25v-7.5a.25.25 0 00-.25-.25z"/></svg>
        </button>
        <div class="clone-toast" id="cloneToast">Copied!</div>
      </div>
    </div>
  </div>
</nav>

<main>
  <slot />
</main>

<footer>
  <nav class="footer-nav">
    <a href="/">Home</a>
    <a href="/guide">The Guide</a>
    <a href="/crew">The Crew</a>
    <a href="/costs">Costs</a>
    <a href="/docs">Docs</a>
  </nav>
  <p><a href="https://github.com/TrashedPandai/arr-barr" target="_blank" rel="noopener" class="footer-brand">arr-barr</a> &mdash; Pandai Technologies</p>
  <p class="mt-1" style="font-size:0.72rem;">Open source. Self-hosted. Self-poured.</p>
  <p class="legal-notice">arr-barr documents the setup and configuration of open-source, legally available software. Users are solely responsible for ensuring their use complies with all applicable laws, including copyright law, in their jurisdiction. This project does not endorse, encourage, or facilitate copyright infringement.</p>
</footer>

<style>
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
    background: rgba(10, 14, 26, 0.85);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(30,41,59,0.6);
    transition: box-shadow 0.3s;
  }
  nav.scrolled { box-shadow: 0 4px 30px rgba(0,0,0,0.5); }

  .nav-inner {
    max-width: 1200px; margin: 0 auto;
    display: flex; align-items: center; justify-content: space-between;
    padding: 0 24px; height: 56px;
  }
  .nav-brand {
    background: none; border: none; cursor: pointer;
    display: flex; align-items: center;
    padding: 4px;
    transition: opacity 0.2s;
  }
  .nav-brand:hover { opacity: 0.9; }
  .nav-brand:hover .nav-logo { filter: drop-shadow(0 0 6px rgba(212,160,74,0.5)); }
  .nav-logo { display: block; transition: filter 0.3s; }
  .nav-links { display: flex; gap: 4px; }
  .nav-link {
    padding: 7px 16px; border-radius: 8px;
    color: var(--text-dim); font-size: 0.88rem; font-weight: 500;
    text-decoration: none; transition: all 0.2s; white-space: nowrap;
  }
  .nav-link:hover { color: var(--text); background: var(--surface); }
  .nav-link.active { color: var(--indigo); background: rgba(99,102,241,0.1); }
  .hamburger {
    display: none; background: none; border: none;
    color: var(--text); font-size: 1.4rem; cursor: pointer; padding: 6px;
  }

  main { padding-top: 56px; min-height: 100vh; }

  /* GitHub + clone button */
  .nav-gh { display:flex; align-items:center; gap:0; position:relative; margin-left:4px; }
  .nav-gh-link { display:flex; align-items:center; padding:7px 8px !important; }
  .nav-clone-btn {
    background:none; border:none; cursor:pointer; padding:7px 6px;
    color:var(--text-dim); display:flex; align-items:center;
    border-radius:6px; transition:all 0.2s;
  }
  .nav-clone-btn:hover { background:var(--surface); color:var(--text); }
  .clone-toast {
    position:absolute; top:100%; right:0; margin-top:6px;
    background:var(--surface); border:1px solid var(--border-h);
    color:var(--green); font-size:0.72rem; font-weight:600;
    padding:4px 10px; border-radius:6px; white-space:nowrap;
    opacity:0; transform:translateY(-4px); pointer-events:none;
    transition:all 0.2s;
  }
  .clone-toast.show { opacity:1; transform:translateY(0); }

  /* Footer */
  .footer-nav {
    display: flex; gap: 16px; justify-content: center; flex-wrap: wrap;
    margin-bottom: 12px;
  }
  .footer-nav a {
    color: rgba(160,175,140,0.5); font-size: 0.78rem; text-decoration: none;
    transition: color 0.2s;
  }
  .footer-nav a:hover { color: var(--gold); }
  .footer-brand { color: inherit; transition: color 0.2s; }
  .footer-brand:hover { color: var(--gold); }

  @media (max-width: 768px) {
    .nav-links {
      display: none; flex-direction: column;
      position: absolute; top: 56px; left: 0; right: 0;
      background: #080c16; border-bottom: 1px solid var(--border);
      padding: 8px;
    }
    .nav-links.open { display: flex; }
    .nav-link { padding: 12px 16px; }
    .hamburger { display: block; }
  }
</style>

<script>
  // Nav scroll effect
  window.addEventListener('scroll', () => {
    document.getElementById('nav')?.classList.toggle('scrolled', window.scrollY > 10);
  });

  // Helm — scroll-synced clockwise rotation + click to reel back
  const helmBtn = document.getElementById('helmBtn');
  const helmSvg = document.getElementById('helmSvg');
  if (helmBtn && helmSvg) {
    let reeling = false;
    let scrollRotation = 0;

    // Scroll-synced: rotate clockwise as user scrolls down
    window.addEventListener('scroll', () => {
      if (reeling) return;
      const maxScroll = document.documentElement.scrollHeight - window.innerHeight;
      const progress = maxScroll > 0 ? window.scrollY / maxScroll : 0;
      // Full page scroll = ~3 full rotations
      scrollRotation = progress * 1080;
      helmSvg.style.transform = `rotate(${scrollRotation}deg)`;
    }, { passive: true });

    // Click: reel back (counter-clockwise spin to top)
    helmBtn.addEventListener('click', (e) => {
      e.preventDefault();
      if (window.scrollY < 10) return;
      reeling = true;

      const scrollDist = window.scrollY;
      const duration = Math.min(Math.max(scrollDist / 1500, 0.8), 3);
      // Spin back past 0 for the reeling effect
      const targetRotation = -(Math.max(2, Math.ceil(scrollDist / 800)) * 360);

      helmSvg.style.transition = `transform ${duration}s cubic-bezier(0.22,1,0.36,1)`;
      helmSvg.style.transform = `rotate(${targetRotation}deg)`;

      // Scroll to top via Lenis if available
      const lenis = (window as any).__lenis;
      if (lenis) {
        lenis.scrollTo(0, { duration: duration });
      } else {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      }

      // Reset after reel completes
      setTimeout(() => {
        reeling = false;
        helmSvg.style.transition = 'none';
        helmSvg.style.transform = 'rotate(0deg)';
        // Re-enable smooth transition after reset
        requestAnimationFrame(() => {
          helmSvg.style.transition = '';
        });
      }, duration * 1000 + 200);
    });
  }

  // Clone button — copy git clone URL
  document.getElementById('cloneBtn')?.addEventListener('click', () => {
    navigator.clipboard.writeText('git clone https://github.com/TrashedPandai/arr-barr.git').then(() => {
      const toast = document.getElementById('cloneToast');
      if (toast) {
        toast.classList.add('show');
        setTimeout(() => toast.classList.remove('show'), 1500);
      }
    });
  });

  // Mobile menu
  const hamburger = document.getElementById('hamburger');
  const navLinks = document.getElementById('navLinks');
  hamburger?.addEventListener('click', () => {
    navLinks?.classList.toggle('open');
  });
  // Close mobile menu when a link is clicked
  navLinks?.querySelectorAll('.nav-link').forEach(link => {
    link.addEventListener('click', () => {
      navLinks.classList.remove('open');
    });
  });
</script>

</body>
</html>

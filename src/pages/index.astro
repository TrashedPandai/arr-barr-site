---
import Base from '../layouts/Base.astro';
import Terminal from '../components/Terminal.astro';
---

<Base title="arr-barr — Your media. Your server. Your rules.">

<section class="hero">
  <div class="hero-glow"></div>
  <!-- Starfield -->
  <div class="starfield" id="starfield" aria-hidden="true">
    <svg class="constellations" id="constellations" aria-hidden="true"></svg>
  </div>
  <!-- Particles container -->
  <div class="particles" id="particles" aria-hidden="true"></div>
  <h1>arr-barr</h1>
  <div class="hero-tag" id="heroTag" aria-live="polite"></div>
  <Terminal />
  <!-- Morphing wave divider -->
  <div class="wave-divider hero-wave-morph">
    <svg viewBox="0 0 1200 80" preserveAspectRatio="none" class="wave-svg">
      <path id="waveA" d="M0,40 C150,65 350,15 600,40 C850,65 1050,15 1200,40 L1200,80 L0,80 Z" fill="#0a0e1a"/>
      <path id="waveB" d="M0,50 C200,20 400,70 600,35 C800,10 1000,60 1200,45 L1200,80 L0,80 Z" fill="#0a0e1a" visibility="hidden"/>
      <path id="waveC" d="M0,30 C100,55 300,25 500,50 C700,75 900,20 1200,35 L1200,80 L0,80 Z" fill="#0a0e1a" visibility="hidden"/>
    </svg>
  </div>
</section>

<!-- JOURNEY -->
<div class="journey-wrap" id="journeyWrap">
  <div class="chapter" data-accent="warm">
    <div class="chapter-node"></div>
    <div class="chapter-content">
      <span class="chapter-label" data-final="01">01</span>
      <h3 class="chapter-title split-title">What is this thing?</h3>
      <p class="chapter-analogy">A personal media server for everything you own.</p>
      <p class="chapter-desc">arr-barr organizes your media library and streams it to any device in your house. Movies, TV shows, music, books, audiobooks, even games &mdash; all in one place, managed automatically. Your hardware, your library, your rules.</p>
    </div>
  </div>

  <div class="chapter" data-accent="amber">
    <div class="chapter-node"></div>
    <div class="chapter-content">
      <span class="chapter-label" data-final="02">02</span>
      <h3 class="chapter-title split-title">How it gets there</h3>
      <p class="chapter-analogy">You search. The crew handles everything else.</p>
      <p class="chapter-desc">Open the request page, search for a movie, and tap request. That's your only job. Behind the scenes, 15 services spring into action &mdash; searching a dozen sources in parallel, scoring every result for quality, and picking the best one automatically. No hunting, no comparing, no guessing.</p>
    </div>
  </div>

  <div class="chapter" data-accent="emerald">
    <div class="chapter-node"></div>
    <div class="chapter-content">
      <span class="chapter-label" data-final="03">03</span>
      <h3 class="chapter-title split-title">Private by default</h3>
      <p class="chapter-analogy">Built-in privacy. Every connection encrypted.</p>
      <p class="chapter-desc">All traffic routes through an encrypted WireGuard VPN tunnel. If the tunnel ever drops, a kill switch blocks all outbound connections until it's back &mdash; no traffic ever leaves unencrypted. Privacy isn't an add-on, it's the default.</p>
    </div>
  </div>

  <div class="chapter" data-accent="gold">
    <div class="chapter-node"></div>
    <div class="chapter-content">
      <span class="chapter-label" data-final="04">04</span>
      <h3 class="chapter-title split-title">Press play</h3>
      <p class="chapter-analogy">Request it. Forget about it. It'll be there when you're ready.</p>
      <p class="chapter-desc">Request something before bed, wake up to a fully organized library entry &mdash; proper name, cover art, subtitles, all handled. It shows up in Jellyfin ready to stream on your TV, phone, tablet, or browser. Share with family and friends &mdash; no per-screen limits, no ads. Your server, your rules.</p>
    </div>
  </div>
</div>

<!-- Beach shore transition — overhead view, waves crashing toward shore (top→bottom) -->
<div class="beach-shore" id="beachShore">
  <svg class="shore-svg" viewBox="0 0 1200 400" preserveAspectRatio="none" aria-hidden="true">
    <!-- LAYER 1: Breaking wave — the bright white foam band where wave crumbles -->
    <path id="breakA" d="M0,160 C40,153 100,168 200,157 C300,146 380,170 480,158 C580,146 660,171 760,159 C860,147 940,169 1040,157 C1120,148 1170,163 1200,156" stroke="rgba(255,255,255,0.22)" stroke-width="4" fill="none" stroke-linecap="round"/>
    <path id="breakB" d="M0,163 C55,156 120,171 220,160 C320,149 400,173 500,161 C600,149 680,174 780,162 C880,150 960,172 1060,160 C1140,151 1180,166 1200,159" stroke="rgba(255,255,255,0.22)" stroke-width="4" fill="none" stroke-linecap="round" visibility="hidden"/>
    <path id="breakC" d="M0,157 C45,150 110,166 210,155 C310,144 390,168 490,156 C590,144 670,169 770,157 C870,145 950,167 1050,155 C1130,146 1175,161 1200,154" stroke="rgba(255,255,255,0.22)" stroke-width="4" fill="none" stroke-linecap="round" visibility="hidden"/>

    <!-- LAYER 4: Wash sheet — wide semi-transparent band that rushes up beach -->
    <path id="washA" d="M0,200 C100,192 250,208 400,196 C550,184 700,210 850,198 C1000,186 1100,204 1200,194 L1200,230 C1100,240 1000,222 850,234 C700,246 550,220 400,232 C250,244 100,228 0,236 Z" fill="rgba(255,255,255,0.04)"/>
    <path id="washB" d="M0,206 C120,198 270,214 420,202 C570,190 720,216 870,204 C1020,192 1120,210 1200,200 L1200,240 C1120,250 1020,232 870,244 C720,256 570,230 420,242 C270,254 120,238 0,246 Z" fill="rgba(255,255,255,0.04)" visibility="hidden"/>
    <path id="washC" d="M0,196 C90,188 240,204 390,192 C540,180 690,206 840,194 C990,182 1090,200 1200,190 L1200,224 C1090,234 990,216 840,228 C690,240 540,214 390,226 C240,238 90,222 0,230 Z" fill="rgba(255,255,255,0.04)" visibility="hidden"/>

    <!-- LAYER 5: Primary foam line — bright, irregular, where wash meets sand -->
    <path id="foamA" d="M0,245 C30,241 80,250 140,243 C200,236 260,252 340,244 C420,236 470,253 550,245 C630,237 690,254 770,246 C850,238 910,253 990,245 C1070,237 1120,249 1200,242" stroke="rgba(255,255,255,0.18)" stroke-width="3" fill="none" stroke-linecap="round"/>
    <path id="foamB" d="M0,248 C40,244 90,253 150,246 C210,239 270,255 350,247 C430,239 480,256 560,248 C640,240 700,257 780,249 C860,241 920,256 1000,248 C1080,240 1130,252 1200,245" stroke="rgba(255,255,255,0.18)" stroke-width="3" fill="none" stroke-linecap="round" visibility="hidden"/>
    <path id="foamC" d="M0,243 C35,239 85,248 145,241 C205,234 265,250 345,242 C425,234 475,251 555,243 C635,235 695,252 775,244 C855,236 915,251 995,243 C1075,235 1125,247 1200,240" stroke="rgba(255,255,255,0.18)" stroke-width="3" fill="none" stroke-linecap="round" visibility="hidden"/>

    <!-- LAYER 6: Secondary foam — thinner, further up the sand -->
    <path id="foam2A" d="M0,275 C60,271 160,280 280,273 C400,266 520,282 640,275 C760,268 880,281 1000,274 C1100,269 1160,277 1200,272" stroke="rgba(255,255,255,0.08)" stroke-width="2" fill="none" stroke-linecap="round"/>
    <path id="foam2B" d="M0,278 C75,274 175,283 295,276 C415,269 535,285 655,278 C775,271 895,284 1015,277 C1115,272 1175,280 1200,275" stroke="rgba(255,255,255,0.08)" stroke-width="2" fill="none" stroke-linecap="round" visibility="hidden"/>

    <!-- LAYER 7: Lace foam — the thinnest receding wash marks at high-tide line -->
    <path id="laceA" d="M0,305 C80,302 200,310 350,304 C500,298 650,312 800,306 C950,300 1080,309 1200,303" stroke="rgba(255,255,255,0.035)" stroke-width="1" fill="none" stroke-linecap="round" stroke-dasharray="12 8 6 10"/>
    <path id="laceB" d="M0,307 C90,304 210,312 360,306 C510,300 660,314 810,308 C960,302 1090,311 1200,305" stroke="rgba(255,255,255,0.035)" stroke-width="1" fill="none" stroke-linecap="round" stroke-dasharray="12 8 6 10" visibility="hidden"/>

    <!-- LAYER 8: Water sheen — subtle teal shimmer in the wet zone -->
    <path id="sheenA" d="M0,170 C150,164 350,178 550,168 C750,158 950,176 1200,168 L1200,210 C950,220 750,200 550,210 C350,220 150,206 0,212 Z" fill="rgba(100,180,200,0.025)"/>
    <path id="sheenB" d="M0,174 C170,168 370,182 570,172 C770,162 970,180 1200,172 L1200,214 C970,224 770,204 570,214 C370,224 170,210 0,216 Z" fill="rgba(100,180,200,0.025)" visibility="hidden"/>
  </svg>
</div>

<!-- On-shore zone — warm background from beach arrival -->
<div class="shore-ground">

<!-- CREW — card-based layout, mobile-first -->
<section class="crew-section">
  <h2 class="crew-heading split-title">The Crew</h2>
  <p class="crew-sub">Fifteen services. Each one does exactly one thing, extremely well.</p>

  <div class="crew-list">
    <div class="crew-group">
      <span class="group-tag">Requests</span>
      <div class="crew-cards grid-no-orphan">
        <a class="crew-card" href="https://github.com/Fallenbagel/jellyseerr" target="_blank" rel="noopener">
          <img class="card-icon" src="https://raw.githubusercontent.com/Fallenbagel/jellyseerr/main/public/logo_full.svg" alt="" loading="lazy"/>
          <span class="card-name">Jellyseerr</span>
          <span class="card-role">Search, click, done.</span>
          <span class="card-arrow">&rarr;</span>
        </a>
      </div>
    </div>

    <div class="crew-group">
      <span class="group-tag">Automation</span>
      <div class="crew-cards grid-no-orphan">
        <a class="crew-card" href="https://radarr.video" target="_blank" rel="noopener">
          <img class="card-icon" src="https://raw.githubusercontent.com/Radarr/Radarr/develop/Logo/128.png" alt="" loading="lazy"/>
          <span class="card-name">Radarr</span>
          <span class="card-role">Movies, handled.</span>
          <span class="card-arrow">&rarr;</span>
        </a>
        <a class="crew-card" href="https://sonarr.tv" target="_blank" rel="noopener">
          <img class="card-icon" src="https://raw.githubusercontent.com/Sonarr/Sonarr/develop/Logo/128.png" alt="" loading="lazy"/>
          <span class="card-name">Sonarr</span>
          <span class="card-role">Every episode, on time.</span>
          <span class="card-arrow">&rarr;</span>
        </a>
        <a class="crew-card" href="https://lidarr.audio" target="_blank" rel="noopener">
          <img class="card-icon" src="https://raw.githubusercontent.com/Lidarr/Lidarr/develop/Logo/128.png" alt="" loading="lazy"/>
          <span class="card-name">Lidarr</span>
          <span class="card-role">Albums in, organized.</span>
          <span class="card-arrow">&rarr;</span>
        </a>
        <a class="crew-card" href="https://gitlab.com/LazyLibrarian/LazyLibrarian" target="_blank" rel="noopener">
          <img class="card-icon" src="https://raw.githubusercontent.com/linuxserver/docker-templates/master/linuxserver.io/img/lazylibrarian-icon.png" alt="" loading="lazy"/>
          <span class="card-name">LazyLibrarian</span>
          <span class="card-role">Books and audiobooks, sorted.</span>
          <span class="card-arrow">&rarr;</span>
        </a>
        <a class="crew-card" href="https://github.com/Doezer/QuestArr" target="_blank" rel="noopener">
          <img class="card-icon" src="https://raw.githubusercontent.com/Doezer/QuestArr/main/public/logo192.png" alt="" loading="lazy"/>
          <span class="card-name">QuestArr</span>
          <span class="card-role">Games, cataloged.</span>
          <span class="card-arrow">&rarr;</span>
        </a>
      </div>
    </div>

    <div class="crew-group">
      <span class="group-tag">Search</span>
      <div class="crew-cards grid-no-orphan">
        <a class="crew-card" href="https://prowlarr.com" target="_blank" rel="noopener">
          <img class="card-icon" src="https://raw.githubusercontent.com/Prowlarr/Prowlarr/develop/Logo/128.png" alt="" loading="lazy"/>
          <span class="card-name">Prowlarr</span>
          <span class="card-role">Twelve indexers, one search.</span>
          <span class="card-arrow">&rarr;</span>
        </a>
        <a class="crew-card" href="https://github.com/FlareSolverr/FlareSolverr" target="_blank" rel="noopener">
          <span class="card-emoji">&#x1F6E1;&#xFE0F;</span>
          <span class="card-name">FlareSolverr</span>
          <span class="card-role">Gets past the bouncers.</span>
          <span class="card-arrow">&rarr;</span>
        </a>
      </div>
    </div>

    <div class="crew-group">
      <span class="group-tag">Downloads</span>
      <div class="crew-cards grid-no-orphan">
        <a class="crew-card" href="https://github.com/qdm12/gluetun" target="_blank" rel="noopener">
          <span class="card-emoji">&#x1F512;</span>
          <span class="card-name">Gluetun</span>
          <span class="card-role">VPN tunnel. Always on.</span>
          <span class="card-arrow">&rarr;</span>
        </a>
        <a class="crew-card" href="https://transmissionbt.com" target="_blank" rel="noopener">
          <span class="card-emoji">&#x1F300;</span>
          <span class="card-name">Transmission</span>
          <span class="card-role">Torrents, through the tunnel.</span>
          <span class="card-arrow">&rarr;</span>
        </a>
        <a class="crew-card" href="https://sabnzbd.org" target="_blank" rel="noopener">
          <span class="card-emoji">&#x26A1;</span>
          <span class="card-name">SABnzbd</span>
          <span class="card-role">Usenet, through the tunnel.</span>
          <span class="card-arrow">&rarr;</span>
        </a>
      </div>
    </div>

    <div class="crew-group">
      <span class="group-tag">Streaming</span>
      <div class="crew-cards grid-no-orphan">
        <a class="crew-card" href="https://jellyfin.org" target="_blank" rel="noopener">
          <img class="card-icon" src="https://raw.githubusercontent.com/jellyfin/jellyfin-ux/master/branding/SVG/icon-transparent.svg" alt="" loading="lazy"/>
          <span class="card-name">Jellyfin</span>
          <span class="card-role">Your library, any screen.</span>
          <span class="card-arrow">&rarr;</span>
        </a>
        <a class="crew-card" href="https://www.bazarr.media" target="_blank" rel="noopener">
          <img class="card-icon" src="https://raw.githubusercontent.com/morpheus65535/bazarr/master/frontend/public/images/logo64.png" alt="" loading="lazy"/>
          <span class="card-name">Bazarr</span>
          <span class="card-role">Subtitles, automatic.</span>
          <span class="card-arrow">&rarr;</span>
        </a>
      </div>
    </div>

    <div class="crew-group">
      <span class="group-tag">Reading</span>
      <div class="crew-cards grid-no-orphan">
        <a class="crew-card" href="https://www.kavitareader.com" target="_blank" rel="noopener">
          <img class="card-icon" src="https://raw.githubusercontent.com/Kareadita/Kavita/develop/Logo/kavita.svg" alt="" loading="lazy"/>
          <span class="card-name">Kavita</span>
          <span class="card-role">Ebooks in the browser.</span>
          <span class="card-arrow">&rarr;</span>
        </a>
        <a class="crew-card" href="https://www.audiobookshelf.org" target="_blank" rel="noopener">
          <img class="card-icon" src="https://raw.githubusercontent.com/advplyr/audiobookshelf/master/client/static/Logo.png" alt="" loading="lazy"/>
          <span class="card-name">Audiobookshelf</span>
          <span class="card-role">Audiobooks with progress sync.</span>
          <span class="card-arrow">&rarr;</span>
        </a>
      </div>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="final-cta">
  <div class="cta-glow"></div>
  <h2 class="split-title">Clone. Configure. Stream.</h2>
  <p>The entire stack in one repo. Documented, automated, ready.</p>
  <a href="/guide" class="btn btn-primary">Read the Guide</a>
</section>

<!-- Grass transition — sand fades to lush ground with subtle noise texture -->
<div class="grass-zone" aria-hidden="true">
  <svg class="grass-noise" width="0" height="0">
    <filter id="grassNoise"><feTurbulence type="fractalNoise" baseFrequency="0.65" numOctaves="4" stitchTiles="stitch"/><feColorMatrix type="saturate" values="0"/></filter>
  </svg>
</div>

</div><!-- /shore-ground -->

</Base>

<style>
  /* ═══ HERO ═══ */
  .hero { text-align:center; padding:80px 20px 120px; background:linear-gradient(180deg,#0a1530 0%,#0f1f45 30%,#132a55 60%,#0a0e1a 100%); position:relative; overflow:hidden; }
  .hero-glow { position:absolute; inset:0; pointer-events:none; background:radial-gradient(ellipse 30% 40% at 70% 15%,rgba(200,220,255,0.08) 0%,transparent 70%),radial-gradient(ellipse 60% 50% at 50% 20%,rgba(100,140,200,0.1) 0%,transparent 70%); }
  .hero h1 { font-size:clamp(2.8rem,8vw,4.2rem); font-weight:800; background:linear-gradient(135deg,#7aa2f7,var(--indigo),var(--purple),#c084fc); background-size:300% 300%; animation:grad 8s ease infinite; -webkit-background-clip:text; background-clip:text; -webkit-text-fill-color:transparent; position:relative; letter-spacing:-1px; }
  @keyframes grad{0%,100%{background-position:0% 50%}50%{background-position:100% 50%}}
  .hero-tag { font-size:0.88rem; color:rgba(125,211,252,0.55); letter-spacing:4px; text-transform:uppercase; margin-top:10px; font-weight:500; position:relative; min-height:1.4em; white-space:nowrap; }



  /* ═══ STARFIELD ═══ */
  .starfield { position:absolute; inset:0; bottom:30%; pointer-events:none; overflow:hidden; z-index:0; }
  .star { position:absolute; border-radius:50%; background:rgba(220,230,255,0.5); }
  .star--warm { background:rgba(255,220,180,0.4); }
  .star--cool { background:rgba(180,200,255,0.45); }
  .constellations { position:absolute; inset:0; width:100%; height:100%; }
  .constellation-line { stroke:rgba(200,215,255,0.06); stroke-width:0.5; fill:none; }
  .constellation-star { fill:rgba(220,230,255,0.55); }

  /* ═══ PARTICLES ═══ */
  .particles { position:absolute; inset:0; pointer-events:none; overflow:hidden; z-index:0; }
  .particle { position:absolute; border-radius:50%; will-change:transform,opacity; pointer-events:none; }

  /* ═══ WAVE DIVIDERS (MorphSVG) ═══ */
  .wave-divider { position:relative; width:100%; height:80px; overflow:hidden; z-index:2; }
  .hero-wave-morph { position:absolute; bottom:-1px; left:0; right:0; height:80px; }
  .wave-svg { display:block; width:100%; height:100%; }
  .wave-flip { transform:scaleY(-1); }

  /* ═══ BEACH SHORE ═══ */
  .beach-shore {
    position:relative; width:100%; height:300px; overflow:hidden;
    background:linear-gradient(180deg,
      #0a0e1a 0%,        /* deep ocean — continuous from journey */
      #0b1018 6%,        /* deep water */
      #0c1316 14%,       /* mid water — slight teal shift */
      #0e1614 24%,       /* shallow water — green tint */
      #111812 36%,       /* very shallow — sand visible beneath */
      #171a10 48%,       /* wet sand */
      #1d1e12 58%,       /* damp sand — darker */
      #222014 68%,       /* dry sand */
      #262316 78%,       /* warm sand */
      #282518 88%,       /* bright sand — obviously beach */
      #2a2719 100%       /* carries into shore-ground */
    );
  }
  .shore-svg {
    position:absolute; inset:0; width:100%; height:100%;
    pointer-events:none;
  }

  @media(max-width:768px){ .hero{padding:70px 16px 80px} }
  @media(max-width:480px){ .hero h1{font-size:2rem} .hero{padding:60px 14px 60px} }

  /* ═══ JOURNEY ═══ */
  .journey-wrap { position:relative; max-width:780px; margin:0 auto; padding:100px 24px 40px 80px; }
  .journey-wrap::after { display:none; }

  /* Canvas overlay for journey animation */
  .journey-wrap canvas {
    position:absolute; left:0; top:0; width:100%; height:100%;
    pointer-events:none; z-index:1;
  }

  /* Warm, varied accents */
  .chapter[data-accent="warm"]    { --accent:#e0976a; --accent-dim:rgba(224,151,106,0.15); }
  .chapter[data-accent="amber"]   { --accent:#e2b340; --accent-dim:rgba(226,179,64,0.15); }
  .chapter[data-accent="emerald"] { --accent:#34d399; --accent-dim:rgba(52,211,153,0.15); }
  .chapter[data-accent="gold"]    { --accent:#d4a04a; --accent-dim:rgba(212,160,74,0.15); }

  .chapter { position:relative; padding:0 0 100px; }

  .chapter-node { display:none; }

  .chapter-content { opacity:0; transform:translateY(30px); }

  .chapter-label { font-size:0.65rem; text-transform:uppercase; letter-spacing:0.2em; color:rgba(200,200,200,0.3); font-weight:600; display:block; margin-bottom:8px; font-family:'SF Mono','Fira Code',monospace; }

  .chapter-title { font-size:clamp(2rem,5.5vw,3.2rem); font-weight:800; color:#f0f0f0; line-height:1.15; margin-bottom:16px; letter-spacing:-0.5px; }

  .chapter-analogy { font-size:clamp(0.95rem,2.5vw,1.1rem); color:var(--accent); margin-bottom:20px; line-height:1.6; font-weight:500; }

  .chapter-desc { font-size:0.9rem; color:var(--text-dim); max-width:520px; line-height:1.9; }
  /* ═══ CREW — card-based, mobile-first ═══ */
  .crew-section { max-width:780px; margin:0 auto; padding:40px 16px 60px; position:relative; }

  .crew-heading { font-size:clamp(1.8rem,5vw,3rem); font-weight:800; color:#f0f0f0; letter-spacing:-0.5px; margin-bottom:8px; }
  .crew-sub { color:var(--text-muted); font-size:0.9rem; margin-bottom:32px; line-height:1.6; }

  .crew-list { display:flex; flex-direction:column; gap:28px; }

  .group-tag { display:block; font-size:0.6rem; text-transform:uppercase; letter-spacing:0.25em; color:rgba(200,200,200,0.3); font-weight:600; margin-bottom:10px; font-family:'SF Mono','Fira Code',monospace; }

  .crew-cards { display:grid; grid-template-columns:1fr; gap:8px; }

  .crew-card {
    display:grid; grid-template-columns:32px 1fr auto; grid-template-rows:auto auto;
    gap:1px 12px; align-items:center;
    padding:12px 14px; border-radius:10px;
    background:rgba(255,255,255,0.02); border:1px solid rgba(255,255,255,0.06);
    text-decoration:none; color:inherit;
    transition:background 0.2s, border-color 0.2s, transform 0.2s;
    -webkit-tap-highlight-color:transparent;
  }
  .crew-card:hover, .crew-card:active {
    background:rgba(255,255,255,0.05); border-color:rgba(255,255,255,0.12);
    transform:translateY(-1px);
  }

  .card-icon { width:28px; height:28px; border-radius:6px; object-fit:contain; opacity:0.85; grid-row:1 / 3; align-self:center; }
  .card-emoji { width:28px; font-size:1.2rem; text-align:center; grid-row:1 / 3; align-self:center; line-height:1; }
  .card-name { font-size:0.95rem; font-weight:700; color:#e8e8e8; letter-spacing:-0.2px; }
  .card-role { grid-column:2; font-size:0.78rem; color:var(--text-muted); line-height:1.4; }
  .card-arrow { grid-row:1 / 3; align-self:center; color:rgba(255,255,255,0.15); font-size:0.9rem; transition:color 0.2s, transform 0.2s; }
  .crew-card:hover .card-arrow { color:var(--sky); transform:translateX(2px); }

  /* Desktop: 2-column grid for groups with 3+ cards */
  @media(min-width:640px) {
    .crew-section { padding:60px 24px 80px; }
    .crew-sub { margin-bottom:48px; }
    .crew-list { gap:36px; }
    .crew-cards { grid-template-columns:repeat(2, 1fr); gap:10px; }
    .crew-card { padding:14px 18px; }
    .card-icon { width:30px; height:30px; }
    .card-name { font-size:1rem; }
  }

  /* ═══ SHORE GROUND (warm "on land" background) ═══ */
  .shore-ground {
    margin-top:-2px;
    background:linear-gradient(180deg,
      #2a2719 0%,
      #252215 12%,
      #201e12 30%,
      #1a1910 50%,
      #16160f 75%,
      #13140e 100%
    );
  }

  /* ═══ CTA ═══ */
  .final-cta { text-align:center; padding:100px 24px 60px; position:relative; max-width:600px; margin:0 auto; }
  .cta-glow { position:absolute; inset:0; pointer-events:none; background:radial-gradient(ellipse 60% 50% at 50% 40%,rgba(212,160,74,0.05) 0%,transparent 70%); }
  .final-cta h2 { font-size:clamp(1.8rem,5vw,2.6rem); font-weight:800; color:#f0f0f0; position:relative; letter-spacing:-0.5px; }
  .final-cta p { color:var(--text-dim); font-size:0.92rem; margin:12px 0 28px; position:relative; }
  .final-cta .btn { position:relative; }

  /* ═══ GRASS ZONE ═══ */
  .grass-zone {
    position:relative; width:100%; height:50px; overflow:hidden;
    margin-top:-2px;
    background:linear-gradient(180deg,
      #13140e 0%,
      #14150e 40%,
      #15160f 70%,
      #161710 100%
    );
  }
  .grass-zone::after {
    content:''; position:absolute; inset:0;
    filter:url(#grassNoise); opacity:0.02;
    pointer-events:none;
  }
  .grass-noise { position:absolute; }

  /* ═══ RESPONSIVE ═══ */
  @media(max-width:768px){
    .hero-tag { font-size:0.7rem; letter-spacing:2px; }
    .journey-wrap { padding:60px 20px 20px; }
    /* Canvas handles mobile layout internally */
    .chapter-node { display:none; }
    .chapter { padding-bottom:40px; position:relative; z-index:1; }
    .chapter:last-child { padding-bottom:20px; }
    .chapter-content { position:relative; z-index:1; }
    .chapter-title { font-size:1.8rem; }
    .crew-heading { font-size:1.8rem; }
    .crew-section { padding-top:24px; }
    .final-cta { padding:60px 20px 40px; }
    .beach-shore { height:120px; }
  }
  @media(max-width:480px){
    .hero-tag { font-size:clamp(0.5rem, 2.8vw, 0.7rem); letter-spacing:1px; }
    .journey-wrap { padding:40px 16px 16px; }
    .chapter { padding-bottom:30px; }
    .chapter:last-child { padding-bottom:16px; }
    .beach-shore { height:90px; }
    .chapter-title { font-size:1.5rem; }
  }

  /* ═══ REDUCED MOTION ═══ */
  @media(prefers-reduced-motion:reduce){
    .journey-wrap canvas { display:none !important; }
    .chapter-content { opacity:1 !important; transform:none !important; }
    .chapter-node { display:none !important; }
    .hero h1 { animation:none !important; background-position:0% 50%; }
    .particle { opacity:0.3 !important; }
    .star { opacity:0.3 !important; }
  }
</style>

<script>
  import Lenis from 'lenis';
  import 'lenis/dist/lenis.css';
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import { SplitText } from 'gsap/SplitText';
  import { DrawSVGPlugin } from 'gsap/DrawSVGPlugin';
  import { MorphSVGPlugin } from 'gsap/MorphSVGPlugin';
  import { Physics2DPlugin } from 'gsap/Physics2DPlugin';
  import { ScrambleTextPlugin } from 'gsap/ScrambleTextPlugin';
  import { JourneyCanvas } from '../lib/journey-canvas';

  gsap.registerPlugin(
    ScrollTrigger, SplitText, DrawSVGPlugin,
    MorphSVGPlugin,
    Physics2DPlugin, ScrambleTextPlugin
  );

  // ═══ Lenis smooth scroll ═══
  const lenis = new Lenis();
  lenis.on('scroll', ScrollTrigger.update);
  gsap.ticker.add((time) => { lenis.raf(time * 1000); });
  gsap.ticker.lagSmoothing(0);
  // Expose for nav helm scroll-to-top
  (window as any).__lenis = lenis;

  const mm = gsap.matchMedia();

  // ═══ ROTATING TAGLINES (ScrambleText) ═══
  const heroTag = document.getElementById('heroTag');
  if (heroTag) {
    const taglines = [
      'Your media. Your server. Your rules',
      'Self-served. Self-hosted. Self-poured',
      'Every crew needs a port',
      'Sail all day. Stream all night',
      'Set your own course',
      'Built by the crew, for the crew',
      'The helm is yours',
      'All hands on deck. All media in one place',
      'Chart your own waters',
    ];
    let tagIdx = Math.floor(Math.random() * taglines.length);
    heroTag.textContent = taglines[tagIdx];

    function cycleTagline() {
      let next = Math.floor(Math.random() * taglines.length);
      while (next === tagIdx && taglines.length > 1) next = Math.floor(Math.random() * taglines.length);
      tagIdx = next;
      gsap.to(heroTag, {
        scrambleText: {
          text: taglines[tagIdx],
          chars: '&#9875;*&#9876;&#9760;+&#8226;~',
          revealDelay: 0.4,
          speed: 0.5,
        },
        duration: 1.2,
        ease: 'none',
      });
    }
    setInterval(cycleTagline, 7000);
  }

  mm.add('(prefers-reduced-motion: no-preference)', () => {

    // ═══ STARFIELD ═══
    const starfield = document.getElementById('starfield');
    const constellationsSvg = document.getElementById('constellations');
    if (starfield) {
      const isMob = window.innerWidth < 768;
      const starCount = isMob ? 35 : 80;

      for (let i = 0; i < starCount; i++) {
        const s = document.createElement('div');
        const size = 1 + Math.random() * 2;
        const variant = Math.random();
        const color = variant < 0.15 ? 'rgba(255,220,180,0.9)' : variant < 0.3 ? 'rgba(180,200,255,0.9)' : 'rgba(220,230,255,0.9)';
        s.style.position = 'absolute';
        s.style.borderRadius = '50%';
        s.style.background = color;
        s.style.width = size + 'px';
        s.style.height = size + 'px';
        s.style.left = (2 + Math.random() * 96) + '%';
        s.style.top = (2 + Math.random() * 96) + '%';
        const baseOpacity = 0.15 + Math.random() * 0.45;
        s.style.opacity = baseOpacity.toString();
        starfield.appendChild(s);

        // Subtle twinkle on ~40% of stars
        if (Math.random() < 0.4) {
          gsap.to(s, {
            opacity: baseOpacity * 0.25,
            duration: 3 + Math.random() * 5,
            ease: 'sine.inOut',
            yoyo: true,
            repeat: -1,
            delay: Math.random() * 12,
          });
        }
      }

      // Constellations — desktop only
      if (constellationsSvg && !isMob) {
        const patterns = [
          [[12, 8], [18, 14], [10, 18], [12, 8]],
          [[72, 6], [78, 12], [85, 9]],
          [[25, 35], [28, 42], [33, 36], [37, 43], [41, 37]],
          [[48, 10], [54, 6], [61, 8], [65, 14]],
        ];
        const svgNS = 'http://www.w3.org/2000/svg';
        patterns.forEach(pts => {
          for (let i = 0; i < pts.length - 1; i++) {
            const line = document.createElementNS(svgNS, 'line');
            line.setAttribute('x1', pts[i][0] + '%');
            line.setAttribute('y1', pts[i][1] + '%');
            line.setAttribute('x2', pts[i + 1][0] + '%');
            line.setAttribute('y2', pts[i + 1][1] + '%');
            line.setAttribute('stroke', 'rgba(200,215,255,0.06)');
            line.setAttribute('stroke-width', '0.5');
            line.setAttribute('fill', 'none');
            constellationsSvg.appendChild(line);
          }
          pts.forEach(([cx, cy]) => {
            const dot = document.createElementNS(svgNS, 'circle');
            dot.setAttribute('cx', cx + '%');
            dot.setAttribute('cy', cy + '%');
            dot.setAttribute('r', '1.5');
            dot.setAttribute('fill', 'rgba(220,230,255,0.55)');
            constellationsSvg.appendChild(dot);
          });
        });
      }
    }

    // ═══ PARTICLES (Physics2D) ═══
    const particleContainer = document.getElementById('particles');
    if (particleContainer) {
      const colors = ['rgba(212,160,74,0.3)', 'rgba(224,151,106,0.25)', 'rgba(125,211,252,0.15)', 'rgba(100,116,139,0.2)', 'rgba(52,211,153,0.15)'];
      const isMobile = window.innerWidth < 768;
      const count = isMobile ? 8 : 18;

      for (let i = 0; i < count; i++) {
        const p = document.createElement('div');
        p.className = 'particle';
        const size = 2 + Math.random() * 4;
        p.style.width = size + 'px';
        p.style.height = size + 'px';
        p.style.background = colors[Math.floor(Math.random() * colors.length)];
        p.style.left = (10 + Math.random() * 80) + '%';
        p.style.top = (20 + Math.random() * 60) + '%';
        p.style.opacity = '0';
        particleContainer.appendChild(p);

        // Fade in
        gsap.to(p, { opacity: 1, duration: 1, delay: Math.random() * 2 });

        // Physics2D: float upward with drift
        gsap.to(p, {
          physics2D: {
            velocity: 20 + Math.random() * 40,
            angle: -90 + (Math.random() - 0.5) * 60,
            gravity: 0,
          },
          duration: 15 + Math.random() * 20,
          repeat: -1,
          onRepeat: function() {
            // Reset position when particle drifts too far
            gsap.set(p, {
              x: 0, y: 0,
              left: (10 + Math.random() * 80) + '%',
              top: (50 + Math.random() * 40) + '%',
            });
          }
        });
      }
    }

    // ═══ MORPHING WAVES (MorphSVG) ═══
    const waveA = document.getElementById('waveA');
    const waveB = document.getElementById('waveB');
    const waveC = document.getElementById('waveC');
    if (waveA && waveB && waveC) {
      const waveTl = gsap.timeline({ repeat: -1 });
      waveTl
        .to(waveA, { morphSVG: waveB, duration: 4, ease: 'sine.inOut' })
        .to(waveA, { morphSVG: waveC, duration: 4, ease: 'sine.inOut' })
        .to(waveA, { morphSVG: waveA, duration: 4, ease: 'sine.inOut' });
    }

    // ═══ BEACH SHORE — Multi-layered wave system ═══
    // Each layer animates independently but coordinated for realism
    const shoreEls = {
      breakA: document.getElementById('breakA'),
      breakB: document.getElementById('breakB'),
      breakC: document.getElementById('breakC'),
      washA: document.getElementById('washA'),
      washB: document.getElementById('washB'),
      washC: document.getElementById('washC'),
      foamA: document.getElementById('foamA'),
      foamB: document.getElementById('foamB'),
      foamC: document.getElementById('foamC'),
      foam2A: document.getElementById('foam2A'),
      foam2B: document.getElementById('foam2B'),
      laceA: document.getElementById('laceA'),
      laceB: document.getElementById('laceB'),
      sheenA: document.getElementById('sheenA'),
      sheenB: document.getElementById('sheenB'),
    };

    if (shoreEls.breakA) {
      // Layer 1: Breaking wave — 3-shape cycle with acceleration feel
      // Uses power1.in on approach, power2.out on recede — asymmetric like real break
      const breakTl = gsap.timeline({ repeat: -1 });
      breakTl
        .to(shoreEls.breakA, {
          morphSVG: shoreEls.breakB, duration: 3, ease: 'power1.in',
          attr: { 'stroke-width': 5, 'stroke-opacity': 0.28 },
        })
        .to(shoreEls.breakA, {
          morphSVG: shoreEls.breakC, duration: 2.5, ease: 'power2.out',
          attr: { 'stroke-width': 3.5, 'stroke-opacity': 0.18 },
        })
        .to(shoreEls.breakA, {
          morphSVG: shoreEls.breakA, duration: 3.5, ease: 'sine.inOut',
          attr: { 'stroke-width': 4, 'stroke-opacity': 0.22 },
        });

      // Layer 4: Wash sheet — expands then contracts, fades in/out
      const washTl = gsap.timeline({ repeat: -1 });
      washTl
        .fromTo(shoreEls.washA, { opacity: 0 }, { opacity: 1, duration: 1.5, ease: 'power2.in' })
        .to(shoreEls.washA, { morphSVG: shoreEls.washB, duration: 3, ease: 'power3.out' })
        .to(shoreEls.washA, { morphSVG: shoreEls.washC, duration: 2.5, ease: 'power1.in' })
        .to(shoreEls.washA, { opacity: 0, duration: 2, ease: 'power2.out' }, '-=2')
        .to(shoreEls.washA, { morphSVG: shoreEls.washA, duration: 0.01 })
        .to({}, { duration: 1.5 }); // pause before next wave

      // Layer 5: Primary foam line — 3-shape organic morph
      const foamTl = gsap.timeline({ repeat: -1 });
      foamTl
        .to(shoreEls.foamA, { morphSVG: shoreEls.foamB, duration: 3.5, ease: 'power1.inOut' })
        .to(shoreEls.foamA, { morphSVG: shoreEls.foamC, duration: 3, ease: 'sine.inOut' })
        .to(shoreEls.foamA, { morphSVG: shoreEls.foamA, duration: 3.5, ease: 'power1.inOut' });

      // Layer 6: Secondary foam — slower, offset timing
      gsap.to(shoreEls.foam2A, {
        morphSVG: shoreEls.foam2B,
        duration: 5.5, ease: 'sine.inOut', repeat: -1, yoyo: true, delay: 1.2,
      });

      // Layer 7: Lace foam — receding, dashed, very subtle
      gsap.to(shoreEls.laceA, {
        morphSVG: shoreEls.laceB,
        duration: 4, ease: 'sine.inOut', repeat: -1, yoyo: true, delay: 2,
      });

      // Layer 8: Water sheen — slow shimmer in wet zone
      gsap.to(shoreEls.sheenA, {
        morphSVG: shoreEls.sheenB,
        duration: 7, ease: 'sine.inOut', repeat: -1, yoyo: true,
      });
    }

    // ═══ CANVAS JOURNEY — Ship, trail, wake particles, chapter nodes ═══
    const journeyWrap = document.getElementById('journeyWrap');
    let journeyCanvas: JourneyCanvas | null = null;
    if (journeyWrap) {
      journeyCanvas = new JourneyCanvas(journeyWrap);
      ScrollTrigger.create({
        trigger: journeyWrap,
        start: 'top 80%',
        end: 'bottom -5%',
        scrub: 0.6,
        onUpdate: (self) => journeyCanvas!.setProgress(self.progress),
      });
    }

    // ═══ Chapter entrances with ScrambleText + SplitText ═══
    gsap.utils.toArray<HTMLElement>('.chapter').forEach(chapter => {
      const content = chapter.querySelector('.chapter-content') as HTMLElement;
      const node = chapter.querySelector('.chapter-node') as HTMLElement;
      const title = chapter.querySelector('.chapter-title') as HTMLElement;
      const analogy = chapter.querySelector('.chapter-analogy') as HTMLElement;
      const desc = chapter.querySelector('.chapter-desc') as HTMLElement;
      const label = chapter.querySelector('.chapter-label') as HTMLElement;

      // SplitText on title
      const split = new SplitText(title, { type: 'chars' });

      const tl = gsap.timeline({
        scrollTrigger: { trigger: chapter, start: 'top 72%' }
      });

      // Make content visible, then animate in sequence
      tl.to(content, { opacity: 1, y: 0, duration: 0.01 })
        // ScrambleText on chapter label
        .to(label, {
          scrambleText: {
            text: label.dataset.final || label.textContent || '',
            chars: '&#9875;*&#9876;&#9760;+&#9618;&#8226;',
            revealDelay: 0.3,
            speed: 0.6,
          },
          duration: 0.8,
        })
        // SplitText character reveal on title
        .from(split.chars, {
          opacity: 0,
          y: 40,
          rotateX: -40,
          duration: 0.6,
          stagger: 0.03,
          ease: 'power3.out',
        }, '-=0.4')
        .from(analogy, { opacity: 0, y: 15, duration: 0.5, ease: 'power2.out' }, '-=0.3')
        .from(desc, { opacity: 0, y: 15, duration: 0.5, ease: 'power2.out' }, '-=0.3');

      // HTML node glow
      ScrollTrigger.create({
        trigger: chapter,
        start: 'top 60%',
        end: 'bottom 40%',
        onEnter: () => node.classList.add('active'),
        onLeaveBack: () => node.classList.remove('active'),
      });
    });

    // ═══ Crew heading SplitText ═══
    const crewSplit = new SplitText('.crew-heading', { type: 'chars' });
    gsap.from(crewSplit.chars, {
      opacity: 0,
      y: 30,
      rotateX: -30,
      duration: 0.5,
      stagger: 0.04,
      ease: 'power3.out',
      scrollTrigger: { trigger: '.crew-heading', start: 'top 80%' }
    });

    // ═══ Crew cards stagger per group ═══
    gsap.utils.toArray<HTMLElement>('.crew-group').forEach(group => {
      gsap.from(group.querySelectorAll('.crew-card'), {
        opacity: 0,
        y: 12,
        duration: 0.4,
        stagger: 0.06,
        ease: 'power2.out',
        scrollTrigger: { trigger: group, start: 'top 85%' }
      });
    });

    // ═══ CTA SplitText ═══
    const ctaSplit = new SplitText('.final-cta h2', { type: 'words' });
    gsap.from(ctaSplit.words, {
      opacity: 0,
      y: 20,
      duration: 0.5,
      stagger: 0.1,
      ease: 'power3.out',
      scrollTrigger: { trigger: '.final-cta', start: 'top 80%' }
    });

    gsap.from('.final-cta p, .final-cta .btn', {
      opacity: 0,
      y: 15,
      duration: 0.5,
      stagger: 0.1,
      ease: 'power2.out',
      scrollTrigger: { trigger: '.final-cta', start: 'top 75%' }
    });

  // ═══ Resize — canvas recomputes path from DOM, no desync possible ═══
  let resizeTimer: ReturnType<typeof setTimeout>;
  window.addEventListener('resize', () => {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(() => {
      journeyCanvas?.resize();
      ScrollTrigger.refresh(true);
    }, 200);
  });

  });
</script>

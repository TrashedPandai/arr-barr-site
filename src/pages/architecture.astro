        RD["Radarr"] & SN["Sonarr"] & LD["Lidarr"] & LL["LazyLibrarian"] & QA["QuestArr"]
    end
    subgraph TORRENT["Transmission Dirs"]
        T1["torrents/radarr/"] & T2["torrents/tv-sonarr/"] & T3["torrents/lidarr/"] & T4["torrents/books/"] & T5["torrents/games/"]
    end
    subgraph USENET["SABnzbd Categories"]
        S1["usenet/movies/"] & S2["usenet/tv/"] & S3["usenet/music/"] & S4["usenet/books/"] & S5["usenet/games/"]
    end

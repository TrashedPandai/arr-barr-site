---
import Base from '../layouts/Base.astro';
import CrewNetwork from '../components/CrewNetwork.astro';
---

<Base title="arr-barr — The Crew" description="Meet the 13 services that make the operation run.">

<div class="page-header">
  <h1>The Crew</h1>
  <p>15 services, one neural network</p>
</div>

<div class="crew-intro gs">
  <p>Every member of the crew has a single responsibility. Together, they form an automated pipeline that goes from "I want to watch something" to "press play" with zero manual work. Click any node to see what it does and how it connects.</p>
</div>

<CrewNetwork />

</Base>

<style>
  .page-header { text-align:center; padding:50px 24px 10px; }
  .page-header h1 {
    font-size:clamp(1.8rem,5vw,2.5rem); font-weight:700;
    background:linear-gradient(135deg,var(--indigo),var(--purple));
    -webkit-background-clip:text; background-clip:text;
    -webkit-text-fill-color:transparent;
  }
  .page-header p { color:var(--text-dim); font-size:1.05rem; margin-top:6px; }

  .crew-intro { text-align:center; max-width:680px; margin:20px auto 30px; padding:0 24px; }
  .crew-intro p { color:var(--text-dim); font-size:1rem; line-height:1.7; }

  .gs { opacity:0; transform:translateY(20px); }
</style>

<script>
  import { initScrollReveal } from '../scripts/scroll-reveal';
  initScrollReveal();
</script>

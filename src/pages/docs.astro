        {[
          {cmd:'setup', alias:'', desc:'First-time wizard: install, env, dirs, templates, pull images', cat:'setup'},
          {cmd:'start', alias:'', desc:'Start all services', cat:'lifecycle'},
          {cmd:'stop', alias:'', desc:'Stop all services', cat:'lifecycle'},
          {cmd:'restart', alias:'', desc:'Smart restart (VPN-aware). Accepts service names', cat:'lifecycle'},
          {cmd:'status', alias:'st', desc:'Container health dashboard with troubleshooting hints', cat:'monitor'},
          {cmd:'health', alias:'hp', desc:'Parallel API health check on all 15 services', cat:'monitor'},
          {cmd:'vpn', alias:'', desc:'Tunnel status, public IP, geolocation, kill switch', cat:'monitor'},
          {cmd:'downloads', alias:'dl', desc:'Live TUI dashboard with progress bars. --once for snapshot', cat:'monitor'},
          {cmd:'logs', alias:'log', desc:'Service log viewer. -f to follow', cat:'debug'},

      <h2>Health Endpoints</h2>
      <p class="sec-desc">All checked in parallel, 2s timeout. Green &lt;1000ms, yellow &gt;1000ms, red = fail.</p>
      <div class="health-grid">
        {[
          {svc:'Gluetun', ep:'/v1/openvpn/status', code:'302'},
          {svc:'Transmission', ep:'/transmission/rpc', code:'409'},
          {svc:'SABnzbd', ep:'/api?mode=version', code:'200'},
          {svc:'Prowlarr', ep:'/ping', code:'200'},
          {svc:'FlareSolverr', ep:'/health', code:'200'},
          {svc:'Radarr', ep:'/ping', code:'200'},
          {svc:'Sonarr', ep:'/ping', code:'200'},
          {svc:'Lidarr', ep:'/ping', code:'200'},
          {svc:'Bazarr', ep:'/ping', code:'200'},
          {svc:'Jellyfin', ep:'/System/Info/Public', code:'200'},
          {svc:'Seerr', ep:'/api/v1/status', code:'200'},
          {svc:'LazyLibrarian', ep:'/api?cmd=getVersion', code:'200'},
          {svc:'Kavita', ep:'/api/health', code:'200'},
          {svc:'Audiobookshelf', ep:'/healthcheck', code:'200'},
          {svc:'QuestArr', ep:'/', code:'200'},
        ].map(h => (
          <div class="hc-row">
            <span class="hc-dot"></span>
            <span class="hc-svc">{h.svc}</span>
            <code class="hc-ep">{h.ep}</code>
            <span class="hc-code">{h.code}</span>
          </div>
        ))}
      </div>
    </section>

    <!-- ═══ UPDATE PIPELINE ═══ -->
    <section id="updates" class="ds">
      <h2>Update Pipeline</h2>
      <div class="update-flow">
        <div class="uf-step"><code>arr update</code></div>
        <div class="uf-arrow">&darr;</div>
        <div class="uf-step"><code>git pull --ff-only</code><span>compose.yaml, CLI, templates</span></div>
        <div class="uf-arrow">&darr;</div>
        <div class="uf-step"><code>docker compose pull</code><span>latest images</span></div>
        <div class="uf-arrow">&darr;</div>
        <div class="uf-step"><code>docker compose up -d</code><span>recreates only changed containers</span></div>
      </div>
      <div class="update-safe">
        <div class="us-yes"><strong>Updated:</strong> compose.yaml, CLI scripts, templates, Docker images</div>
        <div class="us-no"><strong>Never touched:</strong> .env, service configs/databases, media files</div>
      </div>
    </section>

    <!-- ═══ TROUBLESHOOTING ═══ -->
    <section id="troubleshoot" class="ds">
      <h2>Troubleshooting</h2>
      <div class="ts-grid">
        {[
          {q:'Download stuck', a:'Run <code>arr vpn</code>. If tunnel is down, kill switch blocks traffic (by design). Check .env WireGuard creds. <code>arr restart vpn</code> to reconnect.'},
          {q:'No torrent peers', a:'Check port forwarding: <code>arr vpn</code> should show forwarded port. Set <code>VPN_PORT_FORWARDING=on</code> in .env.'},
          {q:'Missing usenet articles', a:'DMCA takedowns. Add more providers on different backbones for better completion. SABnzbd auto-cascades through priority tiers.'},
          {q:'VPN won\'t connect', a:'Check <code>arr logs gluetun</code>. Common: expired WireGuard key, wrong endpoint, server maintenance.'},
          {q:'Files copied not hardlinked', a:'Separate volume mounts break hardlinks. Must use single <code>-v /data:/data</code> mount. Verify with <code>ls -li</code> (same inode = hardlink).'},
          {q:'Permission denied on import', a:'Check PUID/PGID in .env matches file ownership. Synology: 1026:100. Run <code>arr doctor</code> for auto-fix.'},
          {q:'"No compatible streams"', a:'Enable hardware transcoding in Jellyfin &rarr; Playback &rarr; Transcoding. QSV for Intel, VAAPI for others.'},
          {q:'Subtitles out of sync', a:'Bazarr subsync enabled (thresholds: series 90, movies 70). Re-trigger sync or re-download from different provider.'},
        ].map(item => (
          <details class="ts-item">
            <summary>{item.q}</summary>
            <p set:html={item.a} />
          </details>
        ))}
      </div>
    </section>

  </main>
</div>

</Base>

<style>

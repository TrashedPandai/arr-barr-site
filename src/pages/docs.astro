---
import Base from '../layouts/Base.astro';
---

<Base title="arr-barr — Docs" description="Technical reference for the arr-barr stack.">

<div class="docs-layout">

  <!-- Sidebar -->
  <aside class="docs-sidebar" id="sidebar">
    <div class="sb-brand">docs</div>
    <nav class="sb-nav">
      <a href="#stats" class="sb-link active">Overview</a>
      <a href="/docs/diagrams" class="sb-link sb-page">Diagrams <span class="sb-arrow">&nearr;</span></a>
      <div class="sb-divider"></div>
      <span class="sb-label">Architecture</span>
      <a href="#topology" class="sb-link">Network Topology</a>
      <a href="#hardlinks" class="sb-link">Hardlinks</a>
      <a href="#tree" class="sb-link">Directory Tree</a>
      <a href="#profiles" class="sb-link">Compose Profiles</a>
      <div class="sb-divider"></div>
      <span class="sb-label">Pipelines</span>
      <a href="#pipeline" class="sb-link">Request &rarr; Stream</a>
      <a href="#quality" class="sb-link">Quality Scoring</a>
      <a href="#special" class="sb-link">Games &amp; Books</a>
      <div class="sb-divider"></div>
      <span class="sb-label">Operations</span>
      <a href="#cli" class="sb-link">CLI Reference</a>
      <a href="#health" class="sb-link">Health Endpoints</a>
      <a href="#updates" class="sb-link">Update Pipeline</a>
      <div class="sb-divider"></div>
      <span class="sb-label">Help</span>
      <a href="#troubleshoot" class="sb-link">Troubleshooting</a>
    </nav>
  </aside>

  <!-- Mobile toggle -->
  <button class="docs-fab" id="docsFab" aria-label="Toggle navigation">
    <span></span><span></span><span></span>
  </button>

  <main class="docs-main">

    <!-- ═══ STATS BAR ═══ -->
    <section id="stats" class="ds">
      <h1 class="docs-title">arr-barr <span>docs</span></h1>
      <p class="docs-lead">The complete technical reference. Everything under the hood.</p>

      <div class="stat-grid">
        <div class="stat"><div class="stat-val" data-count="15">0</div><div class="stat-label">Services</div></div>
        <div class="stat"><div class="stat-val" data-count="12">0</div><div class="stat-label">Indexers</div></div>
        <div class="stat"><div class="stat-val" data-count="48">0</div><div class="stat-label">Custom Formats</div></div>
        <div class="stat"><div class="stat-val" data-count="3">0</div><div class="stat-label">Network Zones</div></div>
        <div class="stat"><div class="stat-val" data-count="12">0</div><div class="stat-label">CLI Commands</div></div>
        <div class="stat"><div class="stat-val" data-count="0" data-suffix="GB" data-special="zero">0</div><div class="stat-label">Wasted by Hardlinks</div></div>
      </div>
    </section>

    <!-- ═══ NETWORK TOPOLOGY ═══ -->
    <section id="topology" class="ds">
      <h2>Network Topology</h2>
      <p class="sec-desc">Three isolated zones. Downloads through VPN. Everything else stays fast.</p>

      <div class="topo-wrap">
        <svg class="topo-svg" viewBox="0 0 800 420" fill="none" id="topoSvg">
          <!-- Zone backgrounds -->
          <rect id="z1bg" x="20" y="20" width="230" height="380" rx="12" fill="rgba(16,185,129,0.06)" stroke="rgba(16,185,129,0.2)" stroke-width="1.5" opacity="0"/>
          <rect id="z2bg" x="280" y="20" width="290" height="380" rx="12" fill="rgba(34,211,238,0.04)" stroke="rgba(34,211,238,0.12)" stroke-width="1" opacity="0"/>
          <rect id="z3bg" x="600" y="20" width="180" height="380" rx="12" fill="rgba(99,102,241,0.04)" stroke="rgba(99,102,241,0.12)" stroke-width="1" opacity="0"/>

          <!-- Zone labels -->
          <text id="z1label" x="135" y="52" text-anchor="middle" fill="#6ee7b7" font-size="11" font-weight="600" font-family="Inter,sans-serif" opacity="0">VPN TUNNEL</text>
          <text id="z2label" x="425" y="52" text-anchor="middle" fill="#67e8f9" font-size="11" font-weight="600" font-family="Inter,sans-serif" opacity="0">DOCKER BRIDGE</text>
          <text id="z3label" x="690" y="52" text-anchor="middle" fill="#a5b4fc" font-size="11" font-weight="600" font-family="Inter,sans-serif" opacity="0">HOST NETWORK</text>

          <!-- Zone 1 nodes -->
          <g class="topo-node tn-vpn" data-info="WireGuard VPN gateway. Kill switch active. All download traffic encrypted.">
            <rect x="60" y="100" width="150" height="44" rx="8" fill="rgba(16,185,129,0.12)" stroke="rgba(16,185,129,0.3)" stroke-width="1"/>
            <text x="135" y="118" text-anchor="middle" fill="#a7f3d0" font-size="12" font-weight="600" font-family="Inter,sans-serif">Gluetun</text>
            <text x="135" y="134" text-anchor="middle" fill="rgba(167,243,208,0.5)" font-size="9" font-family="Inter,sans-serif">VPN Gateway</text>
          </g>
          <g class="topo-node tn-vpn" data-info="Torrent client. Runs inside Gluetun's network namespace. Port 9091.">
            <rect x="60" y="180" width="150" height="44" rx="8" fill="rgba(16,185,129,0.08)" stroke="rgba(16,185,129,0.2)" stroke-width="1"/>
            <text x="135" y="198" text-anchor="middle" fill="#a7f3d0" font-size="12" font-weight="600" font-family="Inter,sans-serif">Transmission</text>
            <text x="135" y="214" text-anchor="middle" fill="rgba(167,243,208,0.4)" font-size="9" font-family="Inter,sans-serif">Torrents :9091</text>
          </g>
          <g class="topo-node tn-vpn" data-info="Usenet client. 3 providers, 140 connections. Runs inside Gluetun's network. Port 8080.">
            <rect x="60" y="260" width="150" height="44" rx="8" fill="rgba(16,185,129,0.08)" stroke="rgba(16,185,129,0.2)" stroke-width="1"/>
            <text x="135" y="278" text-anchor="middle" fill="#a7f3d0" font-size="12" font-weight="600" font-family="Inter,sans-serif">SABnzbd</text>
            <text x="135" y="294" text-anchor="middle" fill="rgba(167,243,208,0.4)" font-size="9" font-family="Inter,sans-serif">Usenet :8080</text>
          </g>
          <!-- VPN connections -->
          <line class="topo-line tl-vpn" x1="135" y1="144" x2="135" y2="180" stroke="rgba(16,185,129,0.3)" stroke-width="1" stroke-dasharray="4 3"/>
          <line class="topo-line tl-vpn" x1="135" y1="224" x2="135" y2="260" stroke="rgba(16,185,129,0.3)" stroke-width="1" stroke-dasharray="4 3"/>

          <!-- Zone 2 nodes -->
          {[
            {name:'Radarr', sub:'Movies :7878', y:80, info:'Movie search, download, organize. 48 custom formats. TRaSH HD Bluray + WEB guide.'},
            {name:'Sonarr', sub:'TV :8989', y:130, info:'TV show search, download, organize. 44 custom formats. Handles seasons, anime.'},
            {name:'Lidarr', sub:'Music :8686', y:180, info:"Music library manager. Davo's guide. 5 custom formats. Prefers CD rips."},
            {name:'Prowlarr', sub:'Indexers :9696', y:230, info:'Aggregates 12 indexers (8 torrent + 4 usenet). Single source of truth.'},
            {name:'Bazarr', sub:'Subtitles :6767', y:280, info:'Auto subtitle downloads. Watches Radarr/Sonarr. Subsync for timing correction.'},
            {name:'Seerr', sub:'Requests :5055', y:330, info:'User-friendly request interface. Friends search, request, and track here.'},
          ].map(n => (
            <g class="topo-node tn-bridge" data-info={n.info}>
              <rect x="295" y={n.y} width="120" height="38" rx="6" fill="rgba(34,211,238,0.06)" stroke="rgba(34,211,238,0.12)" stroke-width="1"/>
              <text x="355" y={n.y + 16} text-anchor="middle" fill="#e0f2fe" font-size="11" font-weight="600" font-family="Inter,sans-serif">{n.name}</text>
              <text x="355" y={n.y + 30} text-anchor="middle" fill="rgba(125,211,252,0.4)" font-size="8" font-family="Inter,sans-serif">{n.sub}</text>
            </g>
          ))}
          {[
            {name:'QuestArr', sub:'Games :5002', y:80, info:'Game search via Prowlarr indexers. Downloads through VPN pipeline.'},
            {name:'FlareSolverr', sub:'CF Bypass :8191', y:130, info:'Headless browser for Cloudflare challenges. Tagged to all public torrent indexers.'},
            {name:'LazyLib', sub:'Books :5299', y:180, info:'Book + audiobook search. File-type detection sorts to Kavita or Audiobookshelf.'},
            {name:'Kavita', sub:'Reader :5004', y:230, info:'Browser ebook reader. OPDS support, reading progress, comics and manga.'},
            {name:'Audiobookshelf', sub:'Audio :13378', y:280, info:'Audiobook server. Chapter support, bookmarks, sleep timer, mobile apps.'},
          ].map(n => (
            <g class="topo-node tn-bridge" data-info={n.info}>
              <rect x="435" y={n.y} width="120" height="38" rx="6" fill="rgba(34,211,238,0.06)" stroke="rgba(34,211,238,0.12)" stroke-width="1"/>
              <text x="495" y={n.y + 16} text-anchor="middle" fill="#e0f2fe" font-size="11" font-weight="600" font-family="Inter,sans-serif">{n.name}</text>
              <text x="495" y={n.y + 30} text-anchor="middle" fill="rgba(125,211,252,0.4)" font-size="8" font-family="Inter,sans-serif">{n.sub}</text>
            </g>
          ))}

          <!-- Cross-zone connections -->
          <path class="topo-line tl-cross" d="M 250 200 C 270 200, 275 200, 295 200" stroke="rgba(255,255,255,0.06)" stroke-width="1"/>
          <path class="topo-line tl-cross" d="M 555 200 C 575 200, 585 200, 615 200" stroke="rgba(255,255,255,0.06)" stroke-width="1"/>

          <!-- Zone 3 node -->
          <g class="topo-node tn-host" data-info="Media server. Host network for DLNA. Hardware transcoding (QSV). Movies, TV, music streaming.">
            <rect x="615" y="170" width="150" height="60" rx="10" fill="rgba(99,102,241,0.08)" stroke="rgba(99,102,241,0.2)" stroke-width="1.5"/>
            <text x="690" y="196" text-anchor="middle" fill="#c4b5fd" font-size="14" font-weight="700" font-family="Inter,sans-serif">Jellyfin</text>
            <text x="690" y="214" text-anchor="middle" fill="rgba(196,181,253,0.4)" font-size="9" font-family="Inter,sans-serif">Media Server :8096</text>
          </g>

          <!-- Kill switch indicator -->
          <g id="killSwitch" opacity="0">
            <rect x="50" y="340" width="170" height="30" rx="15" fill="rgba(16,185,129,0.15)" stroke="rgba(16,185,129,0.3)" stroke-width="1"/>
            <circle cx="74" cy="355" r="4" fill="#10b981"><animate attributeName="opacity" values="1;0.4;1" dur="2s" repeatCount="indefinite"/></circle>
            <text x="145" y="359" text-anchor="middle" fill="#6ee7b7" font-size="9" font-weight="600" font-family="Inter,sans-serif">KILL SWITCH ACTIVE</text>
          </g>
        </svg>

        <!-- Tooltip -->
        <div class="topo-tip" id="topoTip"></div>
      </div>
    </section>

    <!-- ═══ HARDLINKS ═══ -->
    <section id="hardlinks" class="ds">
      <h2>The Single Mount</h2>
      <p class="sec-desc">One mount. Zero wasted space. The most important architecture decision.</p>

      <div class="hl-demo" id="hlDemo">
        <div class="hl-side">
          <div class="hl-path hl-dl-path">
            <span class="hl-badge hl-b-yellow">downloads</span>
            <code>/data/downloads/torrents/radarr/Movie.mkv</code>
          </div>
          <div class="hl-inode-line">
            <div class="hl-inode-dot" id="hlDot1"></div>
            <div class="hl-inode-wire" id="hlWire"></div>
            <div class="hl-inode-dot" id="hlDot2"></div>
          </div>
          <div class="hl-path hl-lib-path">
            <span class="hl-badge hl-b-pink">media</span>
            <code>/data/media/movies/Movie (2024)/Movie.mkv</code>
          </div>
        </div>
        <div class="hl-result" id="hlResult">
          <div class="hl-num" id="hlNum">50<span>GB</span></div>
          <div class="hl-sub">Same inode &bull; same bytes &bull; same file</div>
          <div class="hl-not">not <span id="hlNot">100</span> GB</div>
        </div>
      </div>

      <div class="hl-compare">
        <div class="hl-correct">
          <div class="hl-c-badge">Correct</div>
          <code>-v /data:/data</code>
          <p>Single mount. Same filesystem. Hardlinks work.</p>
        </div>
        <div class="hl-wrong">
          <div class="hl-c-badge hl-c-bad">Wrong</div>
          <code>-v /downloads:/downloads<br/>-v /media:/media</code>
          <p>Separate mounts. Cross-device. Files get <strong>copied</strong>. Disk doubles.</p>
        </div>
      </div>
    </section>

    <!-- ═══ DIRECTORY TREE ═══ -->
    <section id="tree" class="ds">
      <h2>Directory Tree</h2>
      <div class="tree-wrap">
        <div class="tree-col">
          <div class="tree-head">config/ <span>15 service databases</span></div>
          <div class="tree-items">
            {['radarr','sonarr','lidarr','bazarr','prowlarr','transmission','sabnzbd','jellyfin','jellyfin-cache','seerr','lazylibrarian','kavita','audiobookshelf','audiobookshelf-meta','questarr'].map(s => (
              <span class="tree-leaf">{s}/</span>
            ))}
          </div>
        </div>
        <div class="tree-col tree-yellow">
          <div class="tree-head">downloads/ <span>staging area</span></div>
          <div class="tree-sub">
            <strong>torrents/</strong>
            <div class="tree-items">
              {['radarr','tv-sonarr','lidarr','books','games'].map(s => <span class="tree-leaf">{s}/</span>)}
            </div>
          </div>
          <div class="tree-sub">
            <strong>usenet/</strong>
            <div class="tree-items">
              {['movies','tv','music','books','audiobooks','games'].map(s => <span class="tree-leaf">{s}/</span>)}
            </div>
          </div>
        </div>
        <div class="tree-col tree-pink">
          <div class="tree-head">media/ <span>final library</span></div>
          <div class="tree-items tree-media">
            <span class="tree-leaf">movies/ <em>&rarr; Jellyfin</em></span>
            <span class="tree-leaf">tv/ <em>&rarr; Jellyfin</em></span>
            <span class="tree-leaf">music/ <em>&rarr; Jellyfin + Roon</em></span>
            <span class="tree-leaf">books/ <em>&rarr; Kavita</em></span>
            <span class="tree-leaf">audiobooks/ <em>&rarr; Audiobookshelf</em></span>
            <span class="tree-leaf">games/ <em>&rarr; GameVault</em></span>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ COMPOSE PROFILES ═══ -->
    <section id="profiles" class="ds">
      <h2>Compose Profiles</h2>
      <div class="prof-tabs" id="profTabs">
        <button class="prof-tab active" data-prof="core">Core (12)</button>
        <button class="prof-tab" data-prof="kavita">+ Kavita</button>
        <button class="prof-tab" data-prof="abs">+ Audiobookshelf</button>
        <button class="prof-tab" data-prof="all">All (15)</button>
      </div>
      <div class="prof-grid" id="profGrid">
        {['Gluetun','Transmission','SABnzbd','Prowlarr','FlareSolverr','Radarr','Sonarr','Lidarr','Bazarr','Jellyfin','Seerr','QuestArr','LazyLibrarian','Kavita','Audiobookshelf'].map((s, i) => (
          <div class={`prof-chip ${i >= 12 ? 'prof-optional' : ''}`} data-svc={s.toLowerCase().replace(/\s/g,'')}>{s}</div>
        ))}
      </div>
    </section>

    <!-- ═══ PIPELINE ═══ -->
    <section id="pipeline" class="ds">
      <h2>The Pipeline</h2>
      <p class="sec-desc">From request to streaming in 6 steps. Click any stage for details.</p>

      <div class="pipe-journey" id="pipeJourney">
        <!-- SVG spine with animated data packets -->
        <svg class="pipe-spine" viewBox="0 0 40 960" preserveAspectRatio="none" aria-hidden="true">
          <defs>
            <linearGradient id="pipeGrad" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0%" stop-color="#c084fc"/>
              <stop offset="20%" stop-color="#fbbf24"/>
              <stop offset="40%" stop-color="#22d3ee"/>
              <stop offset="60%" stop-color="#10b981"/>
              <stop offset="80%" stop-color="#f472b6"/>
              <stop offset="100%" stop-color="#6366f1"/>
            </linearGradient>
          </defs>
          <line x1="20" y1="0" x2="20" y2="960" stroke="url(#pipeGrad)" stroke-width="2" stroke-dasharray="6 4" opacity="0.5"/>
          <circle class="pipe-packet" r="4" fill="#22d3ee" opacity="0.8">
            <animateMotion dur="6s" repeatCount="indefinite" path="M20,0 L20,960"/>
          </circle>
          <circle class="pipe-packet" r="3" fill="#d4a04a" opacity="0.5">
            <animateMotion dur="6s" repeatCount="indefinite" begin="2s" path="M20,0 L20,960"/>
          </circle>
        </svg>

        {[
          {id:'request', num:'01', title:'Request', color:'purple', rgb:'192,132,252',
           services:['Jellyseerr'], summary:'User searches for content. Zero technical knowledge needed.',
           details:[{k:'Interface', v:'Jellyseerr web UI or mobile'}, {k:'Routes to', v:'Radarr (movies) / Sonarr (TV)'}, {k:'Auto-approve', v:'Enabled for trusted users'}]},
          {id:'search', num:'02', title:'Search', color:'amber', rgb:'251,191,36',
           services:['Prowlarr','FlareSolverr'], summary:'12 indexers queried in parallel.',
           details:[{k:'Indexers', v:'8 torrent + 4 usenet'}, {k:'Cloudflare', v:'FlareSolverr bypass'}, {k:'Sync', v:'Event-driven push to all arr apps'}]},
          {id:'score', num:'03', title:'Score', color:'cyan', rgb:'34,211,238',
           services:['Radarr','Sonarr','Lidarr'], summary:'48 custom formats rank every result.',
           details:[{k:'Guide', v:'TRaSH HD Bluray + WEB'}, {k:'Reject', v:'LQ, 3D, x265(HD), Scene, AV1'}, {k:'Learn more', v:'See Quality Scoring below'}]},
          {id:'download', num:'04', title:'Download', color:'green', rgb:'16,185,129',
           services:['Gluetun','Transmission','SABnzbd'], summary:'Encrypted WireGuard tunnel. Kill switch active.',
           details:[{k:'Protocol', v:'Best available (torrent or usenet)'}, {k:'Encryption', v:'WireGuard via Proton VPN'}, {k:'Kill switch', v:'iptables DROP — zero leaks'}]},
          {id:'import', num:'05', title:'Import', color:'pink', rgb:'244,114,182',
           services:['Radarr','Sonarr','Lidarr'], summary:'Hardlinked — zero extra disk space.',
           details:[{k:'Torrent', v:'Hardlink (keeps seeding)'}, {k:'Usenet', v:'Move (staging cleared)'}, {k:'Rename', v:'TRaSH naming convention + metadata'}]},
          {id:'stream', num:'06', title:'Stream', color:'indigo', rgb:'99,102,241',
           services:['Jellyfin','Bazarr'], summary:'HW-accelerated, subtitles auto-fetched.',
           details:[{k:'Transcoding', v:'Hardware QSV/VAAPI if needed'}, {k:'Subtitles', v:'Auto via Bazarr'}, {k:'Clients', v:'Any device, anywhere'}]},
        ].map((s, i) => (
          <div class={`pipe-card ${i % 2 === 0 ? 'pc-left' : 'pc-right'}`} style={`--sc:var(--${s.color === 'green' ? 'emerald' : s.color}); --sr:${s.rgb};`} data-stage={s.id}>
            <div class="pc-marker"></div>
            <div class="pc-content">
              <div class="pc-header">
                <span class="pc-num">{s.num}</span>
                <h3>{s.title}</h3>
              </div>
              <div class="pc-services">
                {s.services.map(svc => <span class="pc-svc">{svc}</span>)}
              </div>
              <p class="pc-summary">{s.summary}</p>
              <div class="pc-detail">
                {s.details.map(d => (
                  <div class="pc-row">
                    <span class="pc-key">{d.k}</span>
                    <span class="pc-val">{d.v}</span>
                  </div>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>
      <p class="pipe-link"><a href="/docs/diagrams#main-flow">See the full sequence diagram &rarr;</a></p>
    </section>

    <!-- ═══ QUALITY SCORING ═══ -->
    <section id="quality" class="ds">
      <h2>Quality Scoring</h2>
      <p class="sec-desc">How releases are ranked. Click an app to see its custom formats.</p>

      <div class="q-tabs" id="qTabs">
        <button class="q-tab active" data-app="radarr">Radarr <span>48 CFs</span></button>
        <button class="q-tab" data-app="sonarr">Sonarr <span>44 CFs</span></button>
        <button class="q-tab" data-app="lidarr">Lidarr <span>5 CFs</span></button>
      </div>

      <!-- Radarr -->
      <div class="q-panel active" id="qp-radarr">
        <div class="q-guide">TRaSH HD Bluray + WEB guide</div>
        <div class="q-cols">
          <div>
            <h4 class="q-h-green">Prefer</h4>
            <div class="q-list">
              <div class="q-item"><span>HD Bluray Tier 01</span><span class="qi-score">+1800</span></div>
              <div class="q-item"><span>HD Bluray Tier 02</span><span class="qi-score">+1750</span></div>
              <div class="q-item"><span>HD Bluray Tier 03</span><span class="qi-score">+1700</span></div>
              <div class="q-item"><span>WEB Tier 01</span><span class="qi-score">+1700</span></div>
              <div class="q-item"><span>WEB Tier 02</span><span class="qi-score">+1650</span></div>
              <div class="q-item"><span>WEB Tier 03</span><span class="qi-score">+1600</span></div>
              <div class="q-item"><span>IMAX / IMAX Enhanced</span><span class="qi-score">+800</span></div>
              <div class="q-item"><span>Special Edition</span><span class="qi-score">+125</span></div>
            </div>
          </div>
          <div>
            <h4 class="q-h-red">Reject (-10000)</h4>
            <div class="q-list">
              <div class="q-item"><span>BR-DISK</span><span class="qi-reject">block</span></div>
              <div class="q-item"><span>LQ / LQ (Release Title)</span><span class="qi-reject">block</span></div>
              <div class="q-item"><span>x265 (HD)</span><span class="qi-reject">block</span></div>
              <div class="q-item"><span>3D / Extras / AV1</span><span class="qi-reject">block</span></div>
              <div class="q-item"><span>Bad Dual Groups</span><span class="qi-reject">block</span></div>
              <div class="q-item"><span>No-RlsGroup / Obfuscated</span><span class="qi-reject">block</span></div>
              <div class="q-item"><span>Scene / Retags</span><span class="qi-reject">block</span></div>
            </div>
            <p class="q-note">14 streaming CFs score 0 &mdash; tagging only.</p>
          </div>
        </div>

        <!-- Live scorer -->
        <div class="scorer" id="scorer-radarr">
          <div class="sc-title">Live Score</div>
          <div class="sc-release" id="scRelease">Galactic.Plumber.3.2024.2160p.IMAX.WEB-DL.DV.HDR.Atmos-FLUX</div>
          <div class="sc-matches" id="scMatches"></div>
          <div class="sc-total">Score: <span id="scTotal">0</span></div>
        </div>
      </div>

      <!-- Sonarr -->
      <div class="q-panel" id="qp-sonarr">
        <div class="q-guide">TRaSH WEB-1080p + WEB-2160p combined</div>
        <div class="q-diff">
          <div class="qd"><strong>Streaming services</strong> score <span class="qi-score">+75 each</span> (17 services) &mdash; Radarr scores 0</div>
          <div class="qd"><strong>DV Boost</strong> <span class="qi-score">+1000</span> &bull; HDR <span class="qi-score">+500</span> &bull; HDR10+ <span class="qi-score">+100</span></div>
          <div class="qd"><strong>SDR at 4K</strong> <span class="qi-reject">-10000</span> &mdash; want HDR for 4K content</div>
        </div>
        <p class="q-note">44 CFs total. Same tier system as Radarr. Streaming services matter more for TV because a streaming WEB-DL is almost certainly high quality.</p>
      </div>

      <!-- Lidarr -->
      <div class="q-panel" id="qp-lidarr">
        <div class="q-guide">Davo's Community Guide</div>
        <div class="q-list q-compact">
          <div class="q-item"><span>CD Rip</span><span class="qi-score">+500</span></div>
          <div class="q-item"><span>Preferred Groups (DeVOiD, PERFECT, ENRiCH)</span><span class="qi-score">+500</span></div>
          <div class="q-item"><span>WEB Release</span><span class="qi-score">+200</span></div>
          <div class="q-item"><span>Lossless Tag (FLAC/ALAC)</span><span class="qi-score">+100</span></div>
          <div class="q-item"><span>Vinyl Rip</span><span class="qi-reject">-10000</span></div>
        </div>
        <p class="q-note">Min CF score: 1. Random MP3s with no quality indicators score 0 and get skipped.</p>
      </div>
    </section>

    <!-- ═══ SPECIAL PIPELINES ═══ -->
    <section id="special" class="ds">
      <h2>Special Pipelines</h2>
      <div class="special-grid">
        <div class="sp-card">
          <h3>&#x1F3AE; Games</h3>
          <p>No built-in import engine. QuestArr searches Prowlarr, downloads via VPN. <code>game-import.sh</code> runs every 15 min &mdash; checks download APIs, verifies completion, applies 7 safety checks, then hardlinks (torrent) or moves (usenet) to library.</p>
        </div>
        <div class="sp-card">
          <h3>&#x1F4D6; Books &amp; Audiobooks</h3>
          <p>LazyLibrarian's PostProcessor detects file types: <code>epub/pdf/mobi</code> &rarr; books/, <code>mp3/m4b/m4a</code> &rarr; audiobooks/. Generates cover art and metadata. Kavita reads ebooks, Audiobookshelf serves audiobooks.</p>
        </div>
        <div class="sp-card">
          <h3>&#x1F4DD; Subtitles</h3>
          <p>Bazarr watches Radarr + Sonarr for imports, runs wanted scan every 6h. Scores subtitle candidates against file metadata. Auto-downloads best match, applies subsync timing correction if needed. Jellyfin auto-detects sidecar <code>.srt</code> files.</p>
        </div>
      </div>
    </section>

    <!-- ═══ CLI ═══ -->

    color:var(--cyan); margin-bottom:10px; word-break:break-all;
  }
  .sc-matches { display:flex; flex-wrap:wrap; gap:4px; margin-bottom:10px; min-height:24px; }
  .sc-match {
    font-size:0.7rem; padding:3px 8px; border-radius:4px;
    background:rgba(74,222,128,0.08); border:1px solid rgba(74,222,128,0.15);
    color:#4ade80; opacity:0; transform:translateY(4px);
  }
  .sc-total {
    font-size:1rem; font-weight:700; color:#6ee7b7;
    font-variant-numeric:tabular-nums;
  }
  .sc-total span { font-size:1.4rem; }

  /* ═══ SPECIAL PIPELINES ═══ */
  .special-grid { display:grid; grid-template-columns:1fr 1fr 1fr; gap:12px; }
  .sp-card {
    background:var(--surface); border:1px solid var(--border); border-radius:10px;
    padding:18px; transition:all 0.25s;
  }
  .sp-card:hover { border-color:var(--border-h); transform:translateY(-2px); }
  .sp-card h3 { font-size:0.95rem; color:#e0e6f0; margin-bottom:6px; }
  .sp-card p { font-size:0.78rem; color:var(--text-dim); line-height:1.6; margin:0; }

  /* ═══ CLI ═══ */
  .cli-term {
    background:#080c16; border:1px solid rgba(99,102,241,0.12);
    border-radius:10px; overflow:hidden; margin-bottom:12px;
  }
  .cli-bar {
    display:flex; align-items:center; gap:6px; padding:8px 12px;
    background:rgba(15,22,41,0.8); border-bottom:1px solid rgba(30,41,59,0.6);
  }
  .cd { width:10px; height:10px; border-radius:50%; }
  .cd.red { background:#f87171; } .cd.yellow { background:#fbbf24; } .cd.green { background:#4ade80; }
  .cli-title { margin-left:auto; font-size:0.68rem; color:var(--text-muted); font-family:'SF Mono','Fira Code',monospace; }
  .cli-body { padding:12px 16px; min-height:40px; font-family:'SF Mono','Fira Code',monospace; font-size:0.82rem; color:var(--text-dim); }
  .cli-prompt { color:var(--text-dim); }
  .cli-prompt .cli-cursor {
    display:inline-block; width:7px; height:14px; background:var(--yellow);
    vertical-align:text-bottom; animation:blink 1s step-end infinite;
  }
  @keyframes blink { 50% { opacity:0; } }

  .cli-grid { display:grid; grid-template-columns:1fr 1fr; gap:4px; }
  .cli-cmd {
    display:block; text-align:left; padding:10px 12px; border-radius:6px;
    background:var(--surface); border:1px solid var(--border);
    cursor:pointer; transition:all 0.2s; font-family:inherit;
  }
  .cli-cmd:hover { border-color:var(--border-h); }
  .cli-cmd.cc-active { border-color:rgba(99,102,241,0.3); background:rgba(99,102,241,0.05); }
  .cc-name { font-size:0.82rem; font-weight:600; color:var(--cyan); font-family:'SF Mono','Fira Code',monospace; }
  .cc-alias {
    font-size:0.62rem; color:var(--text-muted); margin-left:6px;
    background:rgba(99,102,241,0.08); padding:1px 6px; border-radius:3px;
  }
  .cc-desc { display:block; font-size:0.72rem; color:var(--text-muted); margin-top:2px; }

  /* ═══ HEALTH ═══ */
  .health-grid { display:grid; grid-template-columns:1fr 1fr 1fr; gap:3px; }
  .hc-row {
    display:flex; align-items:center; gap:6px; padding:6px 10px;
    background:var(--surface); border-radius:4px; font-size:0.78rem;
  }
  .hc-dot { width:6px; height:6px; border-radius:50%; background:#4ade80; flex-shrink:0; }
  .hc-svc { color:var(--text-dim); font-weight:500; flex-shrink:0; }
  .hc-ep { font-size:0.65rem; flex:1; min-width:0; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
  .hc-code { font-size:0.68rem; color:var(--text-muted); font-family:'SF Mono','Fira Code',monospace; }

  /* ═══ UPDATES ═══ */
  .update-flow { display:flex; flex-direction:column; align-items:center; gap:0; margin:16px 0; }
  .uf-step {
    background:var(--surface); border:1px solid var(--border); border-radius:8px;
    padding:10px 20px; text-align:center; width:100%; max-width:400px;
  }
  .uf-step code { font-size:0.85rem; }
  .uf-step span { display:block; font-size:0.72rem; color:var(--text-muted); margin-top:2px; }
  .uf-arrow { color:var(--text-muted); padding:2px 0; }
  .update-safe { display:grid; grid-template-columns:1fr 1fr; gap:8px; margin-top:12px; }
  .us-yes {
    background:rgba(16,185,129,0.04); border:1px solid rgba(16,185,129,0.12);
    border-radius:8px; padding:12px; font-size:0.78rem; color:var(--text-dim);
  }
  .us-yes strong { color:#6ee7b7; }
  .us-no {
    background:rgba(248,113,113,0.04); border:1px solid rgba(248,113,113,0.1);
    border-radius:8px; padding:12px; font-size:0.78rem; color:var(--text-dim);
  }
  .us-no strong { color:#fca5a5; }

  /* ═══ TROUBLESHOOT ═══ */
  .ts-grid { display:flex; flex-direction:column; gap:4px; }
  .ts-item {
    background:var(--surface); border:1px solid var(--border); border-radius:6px; overflow:hidden;
  }
  .ts-item summary {
    padding:10px 14px; cursor:pointer; font-size:0.85rem; font-weight:500;
    color:#e0e6f0; list-style:none; transition:background 0.2s;
  }
  .ts-item summary:hover { background:rgba(99,102,241,0.03); }
  .ts-item summary::before { content:'+ '; color:var(--indigo); font-weight:700; font-family:monospace; }
  .ts-item[open] summary::before { content:'- '; }
  .ts-item summary::-webkit-details-marker { display:none; }
  .ts-item p { padding:0 14px 10px; font-size:0.82rem; color:var(--text-dim); line-height:1.6; margin:0; }

  /* ═══ RESPONSIVE ═══ */
  @media(max-width:900px) {
    .docs-layout { grid-template-columns:1fr; }
    .docs-sidebar {
      display:none; position:fixed; top:56px; left:0; right:0;
      height:calc(100vh - 56px); z-index:150; background:var(--bg);
    }
    .docs-sidebar.open { display:block; }
    .docs-fab { display:flex; }
    .docs-main { padding:24px 16px 60px; }
    .stat-grid { grid-template-columns:repeat(3,1fr); }
    .pipe-wrap { flex-wrap:wrap; }
    .pipe-stage { flex:0 0 calc(33.3% - 8px); }
    .q-cols { grid-template-columns:1fr; }
    .special-grid { grid-template-columns:1fr; }
    .cli-grid { grid-template-columns:1fr; }
    .health-grid { grid-template-columns:1fr; }
    .hl-demo { grid-template-columns:1fr; }
    .hl-compare { grid-template-columns:1fr; }
    .tree-wrap { grid-template-columns:1fr; }
    .update-safe { grid-template-columns:1fr; }
  }
  @media(max-width:480px) {
    .stat-grid { grid-template-columns:repeat(2,1fr); }
    .pipe-stage { flex:0 0 calc(50% - 4px); }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  // ═══ SCROLL REVEALS ═══
  gsap.utils.toArray<HTMLElement>('.ds').forEach(el => {
    gsap.to(el, { opacity:1, y:0, duration:0.6, ease:'power3.out',
      scrollTrigger: { trigger:el, start:'top 88%' }
    });
  });

  // ═══ STAT COUNTERS ═══
  document.querySelectorAll('.stat-val').forEach(el => {
    const target = parseInt(el.getAttribute('data-count') || '0');
    const suffix = el.getAttribute('data-suffix') || '';
    const special = el.getAttribute('data-special');

    ScrollTrigger.create({
      trigger: el,
      start: 'top 90%',
      once: true,
      onEnter: () => {
        if (special === 'zero') {
          gsap.to(el, { duration: 0.8, delay: 0.5,
            onComplete: () => { el.textContent = '0 ' + suffix; }
          });
        } else {
          const obj = { val: 0 };
          gsap.to(obj, {
            val: target, duration: 1.2, ease: 'power2.out',
            onUpdate: () => { el.textContent = Math.round(obj.val) + suffix; }
          });
        }
      }
    });
  });

  // ═══ TOPOLOGY ANIMATION ═══
  ScrollTrigger.create({
    trigger: '#topoSvg',
    start: 'top 80%',
    once: true,
    onEnter: () => {
      const tl = gsap.timeline();
      tl.to('#z1bg, #z2bg, #z3bg', { opacity: 1, duration: 0.5, stagger: 0.15 })
        .to('#z1label, #z2label, #z3label', { opacity: 1, duration: 0.3, stagger: 0.1 }, '-=0.3')
        .from('.topo-node', { opacity: 0, scale: 0.8, transformOrigin: 'center', duration: 0.4, stagger: 0.04, ease: 'power2.out' }, '-=0.2')
        .from('.topo-line', { opacity: 0, duration: 0.3, stagger: 0.05 }, '-=0.3')
        .to('#killSwitch', { opacity: 1, duration: 0.4 }, '-=0.1');
    }
  });

  // Topology tooltips
  const tip = document.getElementById('topoTip')!;
  document.querySelectorAll('.topo-node').forEach(node => {
    node.addEventListener('mouseenter', (e) => {
      const info = node.getAttribute('data-info');
      if (!info) return;
      tip.textContent = info;
      tip.style.display = 'block';
      const rect = (e.target as Element).closest('.topo-wrap')!.getBoundingClientRect();
      const nr = (node.querySelector('rect') as SVGRectElement).getBoundingClientRect();
      tip.style.left = (nr.left - rect.left + nr.width / 2 - 130) + 'px';
      tip.style.top = (nr.bottom - rect.top + 8) + 'px';
    });
    node.addEventListener('mouseleave', () => { tip.style.display = 'none'; });
  });

  // ═══ PIPELINE INTERACTION ═══
  document.querySelectorAll('.pipe-stage').forEach(stage => {
    stage.addEventListener('click', () => {
      const wasActive = stage.classList.contains('ps-active');
      document.querySelectorAll('.pipe-stage').forEach(s => s.classList.remove('ps-active'));
      if (!wasActive) stage.classList.add('ps-active');
    });
  });

  // Auto-activate first stage on scroll
  ScrollTrigger.create({
    trigger: '#pipeWrap',
    start: 'top 75%',
    once: true,
    onEnter: () => {
      const stages = document.querySelectorAll('.pipe-stage');
      let i = 0;
      const interval = setInterval(() => {
        stages.forEach(s => s.classList.remove('ps-active'));
        if (i < stages.length) {
          stages[i].classList.add('ps-active');
          i++;
        } else {
          clearInterval(interval);
          setTimeout(() => stages.forEach(s => s.classList.remove('ps-active')), 2000);
        }
      }, 600);
    }
  });

  // ═══ QUALITY TABS ═══
  document.querySelectorAll('.q-tab').forEach(tab => {
    tab.addEventListener('click', () => {
      document.querySelectorAll('.q-tab').forEach(t => t.classList.remove('active'));
      document.querySelectorAll('.q-panel').forEach(p => p.classList.remove('active'));
      tab.classList.add('active');
      const app = tab.getAttribute('data-app');
      document.getElementById('qp-' + app)?.classList.add('active');
    });
  });

  // ═══ LIVE SCORER ═══
  const scorerData = [
    { name: 'WEB Tier 01', score: 1700 },
    { name: 'IMAX', score: 800 },
    { name: 'HDR', score: 500 },
    { name: 'Dolby Vision', score: 500 },
    { name: 'Atmos', score: 200 },
  ];

  ScrollTrigger.create({
    trigger: '#scorer-radarr',
    start: 'top 80%',
    once: true,
    onEnter: () => {
      const container = document.getElementById('scMatches')!;
      const totalEl = document.getElementById('scTotal')!;
      let runningTotal = 0;

      scorerData.forEach((cf, i) => {
        setTimeout(() => {
          const chip = document.createElement('span');
          chip.className = 'sc-match';
          chip.innerHTML = `${cf.name} <strong>+${cf.score}</strong>`;
          container.appendChild(chip);
          gsap.to(chip, { opacity: 1, y: 0, duration: 0.3, ease: 'power2.out' });

          const startVal = runningTotal;
          runningTotal += cf.score;
          const obj = { val: startVal };
          gsap.to(obj, {
            val: runningTotal, duration: 0.4, ease: 'power2.out',
            onUpdate: () => { totalEl.textContent = Math.round(obj.val).toString(); }
          });
        }, i * 400);
      });
    }
  });

  // ═══ PROFILE TABS ═══
  const profileMap: Record<string, string[]> = {
    core: [],
    kavita: ['lazylibrarian', 'kavita'],
    abs: ['lazylibrarian', 'audiobookshelf'],
    all: ['lazylibrarian', 'kavita', 'audiobookshelf'],
  };

  document.querySelectorAll('.prof-tab').forEach(tab => {
    tab.addEventListener('click', () => {
      document.querySelectorAll('.prof-tab').forEach(t => t.classList.remove('active'));
      tab.classList.add('active');
      const prof = tab.getAttribute('data-prof') || 'core';
      const active = profileMap[prof] || [];

      document.querySelectorAll('.prof-optional').forEach(chip => {
        const svc = chip.getAttribute('data-svc') || '';
        if (active.includes(svc)) {
          chip.classList.add('prof-on');
        } else {
          chip.classList.remove('prof-on');
        }
      });
    });
  });

  // ═══ CLI INTERACTION ═══
  const cliBody = document.getElementById('cliBody')!;
  document.querySelectorAll('.cli-cmd').forEach(cmd => {
    cmd.addEventListener('click', () => {
      document.querySelectorAll('.cli-cmd').forEach(c => c.classList.remove('cc-active'));
      cmd.classList.add('cc-active');
      const name = cmd.getAttribute('data-cmd');
      const desc = cmd.getAttribute('data-desc');
      cliBody.innerHTML = `<div style="color:#fbbf24;">$</div> <span style="color:#e0e6f0;">arr ${name}</span>\n<span style="color:#64748b;">${desc}</span>`;
    });
  });

  // ═══ SIDEBAR ACTIVE STATE ═══
  const sections = document.querySelectorAll('.ds[id]');
  const sideLinks = document.querySelectorAll('.sb-link');

  const sectionObserver = new IntersectionObserver(entries => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        sideLinks.forEach(l => l.classList.remove('active'));
        document.querySelector(`.sb-link[href="#${entry.target.id}"]`)?.classList.add('active');
      }
    });
  }, { rootMargin: '-80px 0px -60% 0px' });

  sections.forEach(s => sectionObserver.observe(s));

  // ═══ MOBILE SIDEBAR ═══
  document.getElementById('docsFab')?.addEventListener('click', () => {
    document.getElementById('sidebar')?.classList.toggle('open');
  });
  document.querySelectorAll('.sb-link').forEach(link => {
    link.addEventListener('click', () => {
      document.getElementById('sidebar')?.classList.remove('open');
    });
  });
</script>

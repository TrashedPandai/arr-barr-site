  <!-- Main content -->
  <div class="dg-content">
    <div class="dg-header">
      <h1>Diagrams</h1>
      <p>The complete technical architecture. Every service, every flow, every decision — visualized.</p>
    </div>

    <!-- SVG shared defs for arrows -->
    <svg class="dg-defs" aria-hidden="true">
      <defs>
        <marker id="arr" viewBox="0 0 10 7" refX="10" refY="3.5" markerWidth="8" markerHeight="6" orient="auto-start-reverse">
          <path d="M 0 0 L 10 3.5 L 0 7 z" fill="#64748b"/>
        </marker>
        <marker id="arr-green" viewBox="0 0 10 7" refX="10" refY="3.5" markerWidth="8" markerHeight="6" orient="auto-start-reverse">
          <path d="M 0 0 L 10 3.5 L 0 7 z" fill="#10b981"/>
        </marker>
        <marker id="arr-red" viewBox="0 0 10 7" refX="10" refY="3.5" markerWidth="8" markerHeight="6" orient="auto-start-reverse">
          <path d="M 0 0 L 10 3.5 L 0 7 z" fill="#f87171"/>
        </marker>
        <marker id="arr-cyan" viewBox="0 0 10 7" refX="10" refY="3.5" markerWidth="8" markerHeight="6" orient="auto-start-reverse">
          <path d="M 0 0 L 10 3.5 L 0 7 z" fill="#22d3ee"/>
        </marker>
        <marker id="arr-gold" viewBox="0 0 10 7" refX="10" refY="3.5" markerWidth="8" markerHeight="6" orient="auto-start-reverse">
          <path d="M 0 0 L 10 3.5 L 0 7 z" fill="#d4a04a"/>
        </marker>
      </defs>
    </svg>

    <!-- ═══════════════════════════════════════ -->
    <!--  SECTION 1: ARCHITECTURE               -->
    <!-- ═══════════════════════════════════════ -->
    <section id="architecture" class="dg-section">
      <h2 class="dg-section-title">Architecture</h2>
      <p class="dg-section-desc">A self-hosted, automated media server stack that searches, downloads, organizes, and streams movies, TV, music, books, audiobooks, and games — with full VPN protection on all download traffic.</p>

      <!-- The Big Picture -->
      <h3 id="big-picture">The Big Picture</h3>
      <div class="dg-wrap">
        <svg class="dg-svg" viewBox="0 0 880 520" role="img">
          <title>Complete system architecture showing all 15 services across 5 layers</title>
          <!-- REQUEST LAYER -->
          <rect x="20" y="10" width="840" height="70" rx="10" fill="rgba(192,132,252,0.06)" stroke="rgba(192,132,252,0.2)" stroke-width="1"/>
          <text x="40" y="32" fill="rgba(192,132,252,0.5)" font-size="9" font-weight="600" font-family="Inter,sans-serif" letter-spacing="0.1em">REQUEST LAYER</text>
          <g class="dg-n" data-tip="Users and friends search and request content through Jellyseerr">
            <rect x="280" y="38" width="130" height="34" rx="6" fill="rgba(192,132,252,0.1)" stroke="rgba(192,132,252,0.25)" stroke-width="1"/>
            <text x="345" y="56" text-anchor="middle" fill="#e9d5ff" font-size="11" font-weight="600" font-family="Inter,sans-serif">Users</text>
          </g>
          <g class="dg-n" data-tip="Jellyseerr — User-friendly request interface. Friends search here.">
            <rect x="470" y="38" width="130" height="34" rx="6" fill="rgba(192,132,252,0.1)" stroke="rgba(192,132,252,0.25)" stroke-width="1"/>
            <text x="535" y="56" text-anchor="middle" fill="#e9d5ff" font-size="11" font-weight="600" font-family="Inter,sans-serif">Jellyseerr</text>
          </g>
          <line x1="410" y1="55" x2="470" y2="55" stroke="rgba(192,132,252,0.3)" stroke-width="1" marker-end="url(#arr)"/>

          <!-- SEARCH LAYER -->
          <rect x="20" y="95" width="840" height="70" rx="10" fill="rgba(251,191,36,0.04)" stroke="rgba(251,191,36,0.15)" stroke-width="1"/>
          <text x="40" y="117" fill="rgba(251,191,36,0.5)" font-size="9" font-weight="600" font-family="Inter,sans-serif" letter-spacing="0.1em">SEARCH LAYER</text>
          <g class="dg-n" data-tip="Prowlarr — Aggregates 12 indexers (8 torrent + 4 usenet). Single source of truth.">
            <rect x="320" y="120" width="140" height="34" rx="6" fill="rgba(251,191,36,0.08)" stroke="rgba(251,191,36,0.2)" stroke-width="1"/>
            <text x="390" y="138" text-anchor="middle" fill="#fde68a" font-size="11" font-weight="600" font-family="Inter,sans-serif">Prowlarr</text>
          </g>
          <g class="dg-n" data-tip="FlareSolverr — Headless browser for Cloudflare-protected indexers">
            <rect x="520" y="120" width="140" height="34" rx="6" fill="rgba(251,191,36,0.08)" stroke="rgba(251,191,36,0.2)" stroke-width="1"/>
            <text x="590" y="138" text-anchor="middle" fill="#fde68a" font-size="11" font-weight="600" font-family="Inter,sans-serif">FlareSolverr</text>
          </g>
          <line x1="460" y1="137" x2="520" y2="137" stroke="rgba(251,191,36,0.25)" stroke-width="1" marker-end="url(#arr)"/>

          <!-- MANAGEMENT LAYER -->
          <rect x="20" y="180" width="840" height="90" rx="10" fill="rgba(34,211,238,0.04)" stroke="rgba(34,211,238,0.12)" stroke-width="1"/>
          <text x="40" y="202" fill="rgba(34,211,238,0.5)" font-size="9" font-weight="600" font-family="Inter,sans-serif" letter-spacing="0.1em">MANAGEMENT LAYER</text>
          {[
            {name:'Radarr', sub:'Movies', x:60},
            {name:'Sonarr', sub:'TV Shows', x:195},
            {name:'Lidarr', sub:'Music', x:330},
            {name:'LazyLib', sub:'Books', x:465},
            {name:'QuestArr', sub:'Games', x:600},
            {name:'Bazarr', sub:'Subtitles', x:735},
          ].map(s => (
            <g class="dg-n" data-tip={`${s.name} — ${s.sub} management`}>
              <rect x={s.x} y="215" width="115" height="40" rx="6" fill="rgba(34,211,238,0.06)" stroke="rgba(34,211,238,0.15)" stroke-width="1"/>
              <text x={s.x + 57} y="233" text-anchor="middle" fill="#e0f2fe" font-size="11" font-weight="600" font-family="Inter,sans-serif">{s.name}</text>
              <text x={s.x + 57} y="247" text-anchor="middle" fill="rgba(125,211,252,0.4)" font-size="8" font-family="Inter,sans-serif">{s.sub}</text>
            </g>
          ))}

          <!-- Connections: Seerr → Radarr/Sonarr -->
          <line x1="535" y1="72" x2="118" y2="215" stroke="rgba(192,132,252,0.15)" stroke-width="1" marker-end="url(#arr)"/>
          <line x1="535" y1="72" x2="253" y2="215" stroke="rgba(192,132,252,0.15)" stroke-width="1" marker-end="url(#arr)"/>
          <!-- Arr apps → Prowlarr -->
          <line x1="118" y1="215" x2="370" y2="154" stroke="rgba(251,191,36,0.12)" stroke-width="1" marker-end="url(#arr)"/>
          <line x1="253" y1="215" x2="380" y2="154" stroke="rgba(251,191,36,0.12)" stroke-width="1" marker-end="url(#arr)"/>
          <line x1="388" y1="215" x2="390" y2="154" stroke="rgba(251,191,36,0.12)" stroke-width="1" marker-end="url(#arr)"/>

          <!-- VPN TUNNEL LAYER -->
          <rect x="20" y="290" width="840" height="80" rx="10" fill="rgba(248,113,113,0.05)" stroke="rgba(248,113,113,0.2)" stroke-width="1.5"/>
          <text x="40" y="312" fill="rgba(248,113,113,0.6)" font-size="9" font-weight="700" font-family="Inter,sans-serif" letter-spacing="0.1em">VPN TUNNEL — ALL TRAFFIC ENCRYPTED</text>
          <g class="dg-n" data-tip="Gluetun — WireGuard VPN gateway with kill switch">
            <rect x="200" y="322" width="130" height="36" rx="6" fill="rgba(248,113,113,0.1)" stroke="rgba(248,113,113,0.25)" stroke-width="1"/>
            <text x="265" y="344" text-anchor="middle" fill="#fca5a5" font-size="11" font-weight="600" font-family="Inter,sans-serif">Gluetun</text>
          </g>
          <g class="dg-n" data-tip="Transmission — Torrent client inside VPN namespace, port 9091">
            <rect x="390" y="322" width="130" height="36" rx="6" fill="rgba(248,113,113,0.08)" stroke="rgba(248,113,113,0.2)" stroke-width="1"/>
            <text x="455" y="344" text-anchor="middle" fill="#fca5a5" font-size="11" font-weight="600" font-family="Inter,sans-serif">Transmission</text>
          </g>
          <g class="dg-n" data-tip="SABnzbd — Usenet client inside VPN namespace, port 8080">
            <rect x="580" y="322" width="130" height="36" rx="6" fill="rgba(248,113,113,0.08)" stroke="rgba(248,113,113,0.2)" stroke-width="1"/>
            <text x="645" y="344" text-anchor="middle" fill="#fca5a5" font-size="11" font-weight="600" font-family="Inter,sans-serif">SABnzbd</text>
          </g>
          <line x1="330" y1="340" x2="390" y2="340" stroke="rgba(248,113,113,0.2)" stroke-width="1" stroke-dasharray="4 3"/>
          <line x1="520" y1="340" x2="580" y2="340" stroke="rgba(248,113,113,0.2)" stroke-width="1" stroke-dasharray="4 3"/>

          <!-- Arr → Download clients -->
          <line x1="118" y1="255" x2="455" y2="322" stroke="rgba(34,211,238,0.1)" stroke-width="1" marker-end="url(#arr)"/>
          <line x1="253" y1="255" x2="455" y2="322" stroke="rgba(34,211,238,0.1)" stroke-width="1" marker-end="url(#arr)"/>
          <line x1="388" y1="255" x2="645" y2="322" stroke="rgba(34,211,238,0.1)" stroke-width="1" marker-end="url(#arr)"/>
          <line x1="523" y1="255" x2="645" y2="322" stroke="rgba(34,211,238,0.1)" stroke-width="1" marker-end="url(#arr)"/>

          <!-- STREAMING LAYER -->
          <rect x="20" y="390" width="840" height="70" rx="10" fill="rgba(74,222,128,0.04)" stroke="rgba(74,222,128,0.15)" stroke-width="1"/>
          <text x="40" y="412" fill="rgba(74,222,128,0.5)" font-size="9" font-weight="600" font-family="Inter,sans-serif" letter-spacing="0.1em">STREAMING LAYER</text>
          <g class="dg-n" data-tip="Jellyfin — Self-hosted media server for movies, TV, music">
            <rect x="200" y="418" width="140" height="34" rx="6" fill="rgba(74,222,128,0.08)" stroke="rgba(74,222,128,0.2)" stroke-width="1"/>
            <text x="270" y="436" text-anchor="middle" fill="#bbf7d0" font-size="11" font-weight="600" font-family="Inter,sans-serif">Jellyfin</text>
          </g>
          <g class="dg-n" data-tip="Kavita — Browser-based ebook reader with OPDS support">
            <rect x="400" y="418" width="140" height="34" rx="6" fill="rgba(74,222,128,0.08)" stroke="rgba(74,222,128,0.2)" stroke-width="1"/>
            <text x="470" y="436" text-anchor="middle" fill="#bbf7d0" font-size="11" font-weight="600" font-family="Inter,sans-serif">Kavita</text>
          </g>
          <g class="dg-n" data-tip="Audiobookshelf — Audiobook server with progress tracking and mobile apps">
            <rect x="600" y="418" width="140" height="34" rx="6" fill="rgba(74,222,128,0.08)" stroke="rgba(74,222,128,0.2)" stroke-width="1"/>
            <text x="670" y="436" text-anchor="middle" fill="#bbf7d0" font-size="11" font-weight="600" font-family="Inter,sans-serif">Audiobookshelf</text>
          </g>

          <!-- Download → Streaming -->
          <line x1="455" y1="358" x2="270" y2="418" stroke="rgba(74,222,128,0.12)" stroke-width="1" marker-end="url(#arr-green)"/>
          <line x1="645" y1="358" x2="470" y2="418" stroke="rgba(74,222,128,0.12)" stroke-width="1" marker-end="url(#arr-green)"/>
          <line x1="645" y1="358" x2="670" y2="418" stroke="rgba(74,222,128,0.12)" stroke-width="1" marker-end="url(#arr-green)"/>

          <!-- Users → Streaming -->
          <line x1="345" y1="72" x2="270" y2="418" stroke="rgba(74,222,128,0.08)" stroke-width="1" stroke-dasharray="6 4" marker-end="url(#arr-green)"/>

          <!-- Bazarr → Radarr/Sonarr dotted -->
          <line x1="793" y1="215" x2="160" y2="255" stroke="rgba(34,211,238,0.08)" stroke-width="1" stroke-dasharray="3 3"/>
          <line x1="793" y1="215" x2="295" y2="255" stroke="rgba(34,211,238,0.08)" stroke-width="1" stroke-dasharray="3 3"/>

          <!-- Legend -->
          <g transform="translate(20, 478)">
            <rect width="840" height="32" rx="6" fill="rgba(15,22,41,0.5)" stroke="rgba(30,41,59,0.3)" stroke-width="1"/>
            <circle cx="20" cy="16" r="5" fill="rgba(192,132,252,0.3)"/><text x="32" y="20" fill="#94a3b8" font-size="8" font-family="Inter,sans-serif">Request</text>
            <circle cx="100" cy="16" r="5" fill="rgba(251,191,36,0.3)"/><text x="112" y="20" fill="#94a3b8" font-size="8" font-family="Inter,sans-serif">Search</text>
            <circle cx="175" cy="16" r="5" fill="rgba(34,211,238,0.3)"/><text x="187" y="20" fill="#94a3b8" font-size="8" font-family="Inter,sans-serif">Manage</text>
            <circle cx="260" cy="16" r="5" fill="rgba(248,113,113,0.3)"/><text x="272" y="20" fill="#94a3b8" font-size="8" font-family="Inter,sans-serif">VPN Tunnel</text>
            <circle cx="360" cy="16" r="5" fill="rgba(74,222,128,0.3)"/><text x="372" y="20" fill="#94a3b8" font-size="8" font-family="Inter,sans-serif">Stream</text>
          </g>
        </svg>
        <!-- Tooltip -->
        <div class="dg-tip" id="dgTip"></div>
      </div>

      <!-- 15 Services Table -->
      <!-- Network Zones -->
      <h3 id="network-zones">Three Network Zones</h3>
      <div class="dg-wrap">
        <div class="zone-grid">
          <div class="zone zone-vpn">
            <div class="zone-label">Zone 1 &mdash; VPN Tunnel</div>
            <div class="zone-nodes">
              <div class="zn zn-vpn">Gluetun<span>VPN Gateway</span></div>
              <div class="zone-conn">&darr;</div>
              <div class="zn zn-vpn">Transmission<span>Torrents :9091</span></div>
              <div class="zone-conn">&darr;</div>
              <div class="zn zn-vpn">SABnzbd<span>Usenet :8080</span></div>
            </div>
            <div class="zone-pill">Kill Switch Active</div>
          </div>
          <div class="zone zone-bridge">
            <div class="zone-label">Zone 2 &mdash; Docker Bridge</div>
            <div class="zone-nodes zone-nodes-grid">
              <div class="zn zn-bridge">Radarr<span>:7878</span></div>
              <div class="zn zn-bridge">Sonarr<span>:8989</span></div>
              <div class="zn zn-bridge">Lidarr<span>:8686</span></div>
              <div class="zn zn-bridge">Prowlarr<span>:9696</span></div>
              <div class="zn zn-bridge">FlareSolverr<span>:8191</span></div>
              <div class="zn zn-bridge">Bazarr<span>:6767</span></div>
              <div class="zn zn-bridge">Seerr<span>:5055</span></div>
              <div class="zn zn-bridge">QuestArr<span>:5002</span></div>
            </div>
          </div>
          <div class="zone zone-host">
            <div class="zone-label">Zone 3 &mdash; Host Network</div>
            <div class="zone-nodes">
              <div class="zn zn-host zn-lg">Jellyfin<span>Media Server :8096</span></div>
            </div>
          </div>
        </div>
      </div>
      <div class="dg-callout">
        <p><strong>Zone 1 — VPN Tunnel:</strong> Transmission and SABnzbd share Gluetun's network namespace. All traffic exits through the encrypted WireGuard tunnel. Kill switch blocks everything if VPN drops.</p>
        <p><strong>Zone 2 — Docker Bridge:</strong> Management apps on a private bridge network, communicating by container name.</p>
        <p><strong>Zone 3 — Host Network:</strong> Jellyfin runs on the host for maximum streaming performance and DLNA support.</p>
      </div>

      <!-- Hardlink Architecture -->
      <h3 id="hardlinks">Hardlink Architecture (TRaSH Guides)</h3>
      <p class="dg-p">The key to zero-waste storage: every service that touches both downloads and media mounts the <strong>same root directory</strong>, enabling hardlinks.</p>
      <div class="dg-wrap">
        <div class="hl-demo">
          <div class="hl-side">
            <div class="hl-path">
              <span class="hl-badge hl-b-amber">downloads</span>
              <code>/data/downloads/torrents/movie.mkv</code>
              <span class="hl-inode">inode #3899</span>
            </div>
            <div class="hl-wire">
              <div class="hl-dot"></div>
              <div class="hl-line"></div>
              <div class="hl-tag">HARDLINK &mdash; same inode, zero extra space</div>
              <div class="hl-line"></div>
              <div class="hl-dot"></div>
            </div>
            <div class="hl-path">
              <span class="hl-badge hl-b-pink">media</span>
              <code>/data/media/movies/Movie 2024/movie.mkv</code>
              <span class="hl-inode">inode #3899</span>
            </div>
          </div>
        </div>
      </div>
      <div class="dg-callout dg-callout-info">A 50GB movie doesn't get copied — it gets a second filename pointing to the same data blocks. Torrent client seeds from the original path, Jellyfin streams from the library path. Zero duplication.</div>

      <!-- Volume Tiers -->
      <h3 id="volume-tiers">Volume Mount Tiers</h3>
      <div class="dg-wrap">
        <div class="tier-grid">
          <div class="tier tier-green">
            <div class="tier-label">Tier 1: Full /data read-write &mdash; Can hardlink</div>
            <div class="tier-chips">
              {['Transmission','SABnzbd','Radarr','Sonarr','Lidarr','Bazarr','LazyLibrarian'].map(s => (
                <span class="tier-chip tc-green">{s}</span>
              ))}
            </div>
          </div>
          <div class="tier tier-blue">
            <div class="tier-label">Tier 2: Media Only read-only &mdash; Consumers</div>
            <div class="tier-chips">
              {['Jellyfin','Kavita','Audiobookshelf'].map(s => (
                <span class="tier-chip tc-blue">{s}</span>
              ))}
            </div>
          </div>
          <div class="tier tier-amber">
            <div class="tier-label">Tier 3: Config Only &mdash; No media access</div>
            <div class="tier-chips">
              {['Prowlarr','Seerr','QuestArr','FlareSolverr','Gluetun'].map(s => (
                <span class="tier-chip tc-amber">{s}</span>
              ))}
            </div>
          </div>
        </div>
      </div>

    </section>

    <!-- ═══════════════════════════════════════ -->
    <!--  SECTION 2: FLOWS                       -->
    <!-- ═══════════════════════════════════════ -->
    <section id="flows" class="dg-section">
      <h2 class="dg-section-title">Flows</h2>
      <p class="dg-section-desc">The complete journey from "I want to watch something" to "it's streaming on my TV."</p>

      <!-- Request → Stream -->
      <h3 id="main-flow">Request &rarr; Search &rarr; Download &rarr; Stream</h3>
      <div class="dg-wrap">
        <div class="seq">
          <div class="seq-actors">
            {['User','Seerr','Arr App','Prowlarr','VPN','DL Client','Library','Jellyfin'].map(a => (
              <div class="seq-actor">{a}</div>
            ))}
          </div>
          <div class="seq-body">
            <div class="seq-msg" style="--from:0;--to:1"><span>"I want The Matrix"</span></div>
            <div class="seq-msg" style="--from:1;--to:2"><span>Add to wanted list</span></div>
            <div class="seq-msg" style="--from:2;--to:3"><span>Search all indexers</span></div>
            <div class="seq-msg seq-msg-ret" style="--from:3;--to:2"><span>Results from 12 indexers</span></div>
            <div class="seq-msg seq-msg-self" style="--from:2;--to:2"><span>Score with Custom Formats</span></div>
            <div class="seq-block seq-block-alt" style="--col-start:2;--col-end:7">
              <div class="seq-block-label">alt</div>
              <div class="seq-block-cond">Torrent</div>
              <div class="seq-msg" style="--from:2;--to:5"><span>Send to Transmission</span></div>
              <div class="seq-msg" style="--from:5;--to:4"><span>Download through tunnel</span></div>
              <div class="seq-msg seq-msg-ret" style="--from:5;--to:2"><span>Complete</span></div>
              <div class="seq-msg seq-msg-hl" style="--from:2;--to:6"><span>HARDLINK</span></div>
              <div class="seq-block-divider"></div>
              <div class="seq-block-cond">Usenet</div>
              <div class="seq-msg" style="--from:2;--to:5"><span>Send to SABnzbd</span></div>
              <div class="seq-msg" style="--from:5;--to:4"><span>Download through tunnel</span></div>
              <div class="seq-msg seq-msg-ret" style="--from:5;--to:2"><span>Complete</span></div>
              <div class="seq-msg seq-msg-mv" style="--from:2;--to:6"><span>MOVE</span></div>
            </div>
            <div class="seq-msg seq-msg-ret" style="--from:6;--to:7"><span>New file detected</span></div>
            <div class="seq-msg seq-msg-ret" style="--from:7;--to:0"><span>Ready to watch</span></div>
          </div>
        </div>
      </div>

      <!-- VPN Kill Switch -->
      <h3 id="vpn-killswitch">VPN Kill Switch</h3>
      <div class="dg-wrap">
        <div class="flow-vertical">
          <div class="fv-step fv-red"><strong>Tunnel drops</strong><span>VPN connection lost</span></div>
          <div class="fv-arrow">&darr;</div>
          <div class="fv-step fv-red"><strong>Download client tries to send</strong><span>Outbound packet</span></div>
          <div class="fv-arrow">&darr;</div>
          <div class="fv-step fv-block"><strong>BLOCKED &mdash; kill switch</strong><span>iptables default DROP. Zero traffic leaks.</span></div>
          <div class="fv-arrow">&darr;</div>
          <div class="fv-step fv-amber"><strong>Re-establish tunnel</strong><span>Gluetun reconnects automatically</span></div>
          <div class="fv-arrow">&darr;</div>
          <div class="fv-step fv-green"><strong>Download resumes</strong><span>Traffic routed through new tunnel</span></div>
        </div>
      </div>
      <div class="dg-callout">The kill switch uses iptables with a default DROP policy. Only VPN tunnel traffic, Docker-internal communication, and WireGuard handshake packets are allowed. IPv6 fully blocked.</div>

      <!-- Search vs Download -->
      <h3 id="search-vs-download">Search vs Download Traffic</h3>
      <div class="dg-wrap">
        <div class="split-compare">
          <div class="split-col split-cyan">
            <div class="split-head">Search Traffic &mdash; Direct, no VPN</div>
            <div class="split-items">
              <div class="split-item"><strong>Arr Apps</strong> &rarr; Indexer Sites<span>HTTPS</span></div>
              <div class="split-item"><strong>Prowlarr</strong> &rarr; CF-Protected Sites<span>via FlareSolverr</span></div>
            </div>
          </div>
          <div class="split-col split-red">
            <div class="split-head">Download Traffic &mdash; VPN encrypted</div>
            <div class="split-items">
              <div class="split-item"><strong>Transmission</strong> &rarr; Torrent Trackers<span>WireGuard</span></div>
              <div class="split-item"><strong>SABnzbd</strong> &rarr; Usenet Servers<span>WireGuard</span></div>
            </div>
          </div>
        </div>
      </div>

      <!-- Indexer Architecture -->
      <h3 id="indexer-architecture">Indexer Architecture</h3>
      <div class="dg-wrap">
        <div class="indexer-arch">
          <div class="ia-hub"><strong>Prowlarr</strong><span>Central Manager</span></div>
          <div class="ia-arrows">
            <div class="ia-arrow ia-arrow-left">with FlareSolverr &darr;</div>
            <div class="ia-arrow ia-arrow-right">API key auth &darr;</div>
          </div>
          <div class="ia-groups">
            <div class="ia-group ia-torrent">
              <div class="ia-group-label">8 Torrent Indexers</div>
              <div class="ia-chips">
                {['1337x','EZTV','Knaben','LimeTorrents','Nyaa.si','SkidrowRepack','The Pirate Bay','YTS'].map(i => (
                  <span class="ia-chip">{i}</span>
                ))}
              </div>
            </div>
            <div class="ia-group ia-usenet">
              <div class="ia-group-label">4 Usenet Indexers</div>
              <div class="ia-chips">
                {['NZBFinder','NZBgeek','NzbPlanet','Usenet-Crawler'].map(i => (
                  <span class="ia-chip ia-chip-amber">{i}</span>
                ))}
              </div>
            </div>
          </div>
          <div class="ia-sync">
            <span>Event-driven push &darr;</span>
          </div>
          <div class="ia-targets">
            {['Radarr','Sonarr','Lidarr'].map(t => (
              <span class="ia-target">{t}</span>
            ))}
          </div>
        </div>
      </div>

      <!-- Category Routing -->
      <h3 id="category-routing">Download Category Routing</h3>
      <div class="dg-wrap">
        <div class="cat-grid">
          <div class="cat-col">
            <div class="cat-head">Arr Apps</div>
            {['Radarr','Sonarr','Lidarr','LazyLibrarian','QuestArr'].map(a => (
              <div class="cat-app">{a}</div>
            ))}
          </div>
          <div class="cat-col">
            <div class="cat-head">Transmission Dirs</div>
            {['torrents/radarr/','torrents/tv-sonarr/','torrents/lidarr/','torrents/books/','torrents/games/'].map(d => (
              <div class="cat-dir">{d}</div>
            ))}
          </div>
          <div class="cat-col">
            <div class="cat-head">SABnzbd Categories</div>
            {['usenet/movies/','usenet/tv/','usenet/music/','usenet/books/','usenet/games/'].map(d => (
              <div class="cat-dir cat-dir-amber">{d}</div>
            ))}
          </div>
        </div>
      </div>

      <!-- Usenet Tiers -->
      <h3 id="usenet-tiers">Usenet Server Tiers</h3>
      <div class="dg-wrap">
        <div class="flow-vertical fv-narrow">
          <div class="fv-step fv-cyan"><strong>Priority 0 &mdash; Newshosting</strong><span>Primary backbone, 100 connections</span></div>
          <div class="fv-arrow-label">&darr; <em>missing articles?</em></div>
          <div class="fv-step fv-amber"><strong>Priority 1 &mdash; UsenetExpress</strong><span>Fill server, 8 connections</span></div>
          <div class="fv-arrow-label">&darr; <em>still missing?</em></div>
          <div class="fv-step fv-dim"><strong>Priority 2 &mdash; FrugalUsenet + BlockNews</strong><span>Backup servers, 40 connections total</span></div>
        </div>
      </div>

      <!-- Torrent vs Usenet -->
      <!-- Hardlink Flow -->
      <h3 id="hardlink-flow">The Hardlink Flow</h3>
      <div class="dg-wrap">
        <div class="flow-vertical">
          <div class="fv-step fv-cyan"><strong>Download complete</strong><span>Transmission saves file, inode #3899</span></div>
          <div class="fv-arrow">&darr;</div>
          <div class="fv-step fv-dim"><strong>Continue seeding</strong><span>Transmission keeps the download path active</span></div>
          <div class="fv-arrow">&darr;</div>
          <div class="fv-step fv-green"><strong>Radarr hardlinks to /media/movies/</strong><span>Two filenames, one set of data blocks</span></div>
          <div class="fv-arrow">&darr;</div>
          <div class="fv-step fv-indigo"><strong>Jellyfin streams from library path</strong><span>User watches the movie</span></div>
          <div class="fv-arrow">&darr;</div>
          <div class="fv-step fv-dim"><strong>Eventually stop seeding</strong><span>Delete download path &mdash; inode still has 1 link, data persists</span></div>
        </div>
      </div>
      <div class="dg-callout dg-callout-warn"><strong>Common mistake:</strong> Two separate volume mounts = cross-device hardlink fails = files get COPIED = disk doubles. Always use a single mount <code>-v /data:/data</code>.</div>

      <!-- DNS Architecture -->
      <h3 id="dns">DNS Architecture</h3>
      <div class="dg-wrap">
        <div class="zone-grid zone-grid-dns">
          <div class="zone zone-vpn">
            <div class="zone-label">Inside VPN</div>
            <div class="zone-nodes">
              <div class="zn zn-vpn">Transmission &amp; SABnzbd</div>
              <div class="zone-conn">&darr;</div>
              <div class="zn zn-vpn">Gluetun DNS</div>
              <div class="zone-conn">&darr;</div>
              <div class="zn zn-vpn">Through tunnel &rarr; Cloudflare DNS</div>
            </div>
          </div>
          <div class="zone zone-bridge">
            <div class="zone-label">Bridge Network</div>
            <div class="zone-nodes">
              <div class="zn zn-bridge">Arr Apps</div>
              <div class="zone-conn">&darr;</div>
              <div class="zn zn-bridge">Docker DNS (127.0.0.11)</div>
              <div class="zone-conn">&darr;</div>
              <div class="zn zn-bridge">1.1.1.1 / 8.8.8.8</div>
            </div>
          </div>
          <div class="zone zone-host">
            <div class="zone-label">Host Network</div>
            <div class="zone-nodes">
              <div class="zn zn-host">Jellyfin</div>
              <div class="zone-conn">&darr;</div>
              <div class="zn zn-host">Router DNS (192.168.1.254)</div>
            </div>
          </div>
        </div>
      </div>

      <!-- Game Pipeline -->
      <h3 id="game-pipeline">Game Pipeline</h3>
      <div class="dg-wrap">
        <div class="flow-vertical">
          <div class="fv-step fv-cyan"><strong>QuestArr</strong><span>User picks a game</span></div>
          <div class="fv-arrow">&darr;</div>
          <div class="fv-step fv-red"><strong>Download Client</strong><span>Downloads through VPN tunnel</span></div>
          <div class="fv-arrow">&darr;</div>
          <div class="fv-step fv-loop">
            <div class="fv-loop-label">Every 15 minutes &mdash; game-import.sh</div>
            <div class="fv-loop-body">
              <div class="fv-mini">Check download APIs &rarr; Download finished?</div>
              <div class="fv-mini">Run 7 safety checks</div>
              <div class="fv-mini-split">
                <span class="fv-mini-opt fv-mini-green">Torrent &rarr; Hardlink</span>
                <span class="fv-mini-opt fv-mini-amber">Usenet &rarr; Move</span>
              </div>
            </div>
          </div>
          <div class="fv-arrow">&darr;</div>
          <div class="fv-step fv-green"><strong>Game Library</strong><span>/media/games/</span></div>
        </div>
      </div>

      <!-- Book Sorting -->
      <h3 id="book-sorting">Book Sorting</h3>
      <div class="dg-wrap">
        <div class="flow-vertical fv-narrow">
          <div class="fv-step fv-cyan"><strong>Download completes</strong><span>Every 10 min &rarr; PostProcessor</span></div>
          <div class="fv-arrow">&darr;</div>
          <div class="fv-step fv-dim"><strong>File type detection</strong></div>
          <div class="fv-fork">
            <div class="fv-branch">
              <div class="fv-branch-label">epub / pdf / mobi</div>
              <div class="fv-step fv-pink"><strong>/media/books/</strong><span>&rarr; Kavita</span></div>
            </div>
            <div class="fv-branch">
              <div class="fv-branch-label">mp3 / m4b / m4a</div>
              <div class="fv-step fv-indigo"><strong>/media/audiobooks/</strong><span>&rarr; Audiobookshelf</span></div>
            </div>
          </div>
        </div>
      </div>

      <!-- Subtitle Flow -->
      <h3 id="subtitle-flow">Subtitle Flow</h3>
      <div class="dg-wrap">
        <div class="flow-vertical fv-narrow">
          <div class="fv-fork fv-fork-top">
            <div class="fv-step fv-cyan fv-sm"><strong>New media imported</strong></div>
            <div class="fv-step fv-amber fv-sm"><strong>Wanted scan every 6h</strong></div>
          </div>
          <div class="fv-arrow">&darr;</div>
          <div class="fv-step fv-indigo"><strong>Bazarr</strong><span>Query subtitle providers</span></div>
          <div class="fv-arrow">&darr;</div>
          <div class="fv-step fv-dim"><strong>Score against media metadata</strong></div>
          <div class="fv-arrow">&darr;</div>
          <div class="fv-fork">
            <div class="fv-branch">
              <div class="fv-branch-label">Above threshold</div>
              <div class="fv-step fv-green fv-sm"><strong>Download .srt</strong><span>Place alongside media</span></div>
            </div>
            <div class="fv-branch">
              <div class="fv-branch-label">Below threshold</div>
              <div class="fv-step fv-red fv-sm"><strong>Skip</strong></div>
            </div>
          </div>
          <div class="fv-arrow">&darr;</div>
          <div class="fv-step fv-green"><strong>Jellyfin auto-detects</strong><span>Subtitles available in player</span></div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════ -->
    <!--  SECTION 3: QUALITY & SELECTION         -->
    <!-- ═══════════════════════════════════════ -->
    <section id="quality" class="dg-section">
      <h2 class="dg-section-title">Quality &amp; Selection</h2>
      <p class="dg-section-desc">How the stack decides which release to download when multiple options exist.</p>

      <!-- Decision Engine -->
      <h3 id="decision-engine">The Decision Engine</h3>
      <div class="dg-wrap">
        <div class="flow-vertical fv-narrow">
          <div class="fv-step fv-cyan"><strong>Incoming Release</strong></div>
          <div class="fv-arrow">&darr;</div>
          <div class="fv-step fv-dim"><strong>Quality allowed?</strong></div>
          <div class="fv-fork">
            <div class="fv-branch">
              <div class="fv-branch-label">No</div>
              <div class="fv-step fv-red fv-sm"><strong>REJECTED</strong></div>
            </div>
            <div class="fv-branch">
              <div class="fv-branch-label">Yes &darr;</div>
              <div class="fv-step fv-dim fv-sm"><strong>Score Custom Formats</strong></div>
            </div>
          </div>
          <div class="fv-arrow">&darr;</div>
          <div class="fv-step fv-dim"><strong>Any -10000 Custom Format?</strong></div>
          <div class="fv-fork">
            <div class="fv-branch">
              <div class="fv-branch-label">Yes</div>
              <div class="fv-step fv-red fv-sm"><strong>REJECTED</strong></div>
            </div>
            <div class="fv-branch">
              <div class="fv-branch-label">No &darr;</div>
              <div class="fv-step fv-dim fv-sm"><strong>Score &ge; minimum?</strong></div>
            </div>
          </div>
          <div class="fv-arrow">&darr;</div>
          <div class="fv-fork">
            <div class="fv-branch">
              <div class="fv-branch-label">No</div>
              <div class="fv-step fv-red fv-sm"><strong>REJECTED</strong></div>
            </div>
            <div class="fv-branch">
              <div class="fv-branch-label">Yes</div>
              <div class="fv-step fv-green fv-sm"><strong>ACCEPTED</strong><span>Ranked by score</span></div>
            </div>
          </div>
          <div class="fv-arrow">&darr;</div>
          <div class="fv-step fv-green"><strong>Highest score grabbed</strong></div>
          <div class="fv-arrow">&darr;</div>
          <div class="fv-step fv-dim"><strong>Better than existing?</strong></div>
          <div class="fv-fork">
            <div class="fv-branch">
              <div class="fv-branch-label">Yes</div>
              <div class="fv-step fv-green fv-sm"><strong>UPGRADE</strong></div>
            </div>
            <div class="fv-branch">
              <div class="fv-branch-label">No</div>
              <div class="fv-step fv-dim fv-sm"><strong>SKIP</strong></div>
            </div>
          </div>
        </div>
      </div>

      <!-- Upgrade Flow -->
      <h3 id="upgrade-flow">Upgrade Flow</h3>
      <div class="dg-wrap">
        <div class="flow-vertical fv-narrow">
          <div class="fv-step fv-loop">
            <div class="fv-loop-label">Every 15-30 min &mdash; RSS Sync</div>
            <div class="fv-loop-body">
              <div class="fv-mini">New release found, score 2600</div>
              <div class="fv-mini">Current library score: 1700</div>
              <div class="fv-mini fv-mini-green">2600 &gt; 1700 &rarr; Download upgrade</div>
            </div>
          </div>
          <div class="fv-arrow">&darr;</div>
          <div class="fv-step fv-green"><strong>Replace</strong><span>Old removed, new hardlinked</span></div>
        </div>
      </div>

    </section>

    <!-- ═══════════════════════════════════════ -->
    <!--  SECTION 4: OPERATIONS & CLI            -->
    <!-- ═══════════════════════════════════════ -->
    <section id="operations" class="dg-section">
      <h2 class="dg-section-title">Operations &amp; CLI</h2>
      <p class="dg-section-desc">12 commands, Catppuccin Mocha theming, animated ASCII logos, and real-time dashboards.</p>

      <!-- Command Map -->
      <h3 id="command-map">Command Map</h3>
      <div class="dg-wrap">
        <div class="cmd-map">
          <div class="cmd-hub"><code>arr</code> <span>command</span></div>
          <div class="cmd-fan">
            {[
              {cmd:'setup', desc:'First-time wizard', color:'cyan'},
              {cmd:'start', desc:'Start all services', color:'green'},
              {cmd:'stop', desc:'Stop all services', color:'red'},
              {cmd:'restart', desc:'Smart restart', color:'amber'},
              {cmd:'status', desc:'Container dashboard', color:'indigo'},
              {cmd:'health', desc:'15 parallel checks', color:'green'},
              {cmd:'vpn', desc:'Tunnel status', color:'red'},
              {cmd:'downloads', desc:'Live TUI dashboard', color:'cyan'},
              {cmd:'logs', desc:'Log viewer', color:'dim'},
              {cmd:'doctor', desc:'6-check diagnostic', color:'amber'},
              {cmd:'update', desc:'Git pull + Docker pull', color:'indigo'},
              {cmd:'backup', desc:'Config snapshot', color:'dim'},
            ].map(c => (
              <div class={`cmd-leaf cmd-${c.color}`}>
                <code>arr {c.cmd}</code>
                <span>{c.desc}</span>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- Quick Reference -->
      <!-- Setup Flow -->
      <h3 id="setup-flow">Setup Flow</h3>
      <div class="dg-wrap">
        <div class="pipe-flow">
          {[
            {n:'1', label:'Install CLI', color:'cyan'},
            {n:'2', label:'Configure .env', color:'cyan'},
            {n:'3', label:'Create 20 dirs', color:'cyan'},
            {n:'4', label:'Apply templates', color:'amber'},
            {n:'5', label:'Fix permissions', color:'amber'},
            {n:'6', label:'Pull images', color:'green'},
          ].map((s, i) => (
            <Fragment>
              <div class={`pipe-step pipe-${s.color}`}>
                <div class="pipe-num">{s.n}</div>
                <div class="pipe-label">{s.label}</div>
              </div>
              {i < 5 && <div class="pipe-conn">&rarr;</div>}
            </Fragment>
          ))}
        </div>
      </div>

      <!-- Doctor -->
      <h3 id="doctor">Doctor Self-Repair</h3>
      <div class="dg-wrap">
        <div class="doctor-grid">
          {[
            {check:'arr binary', fix:'Auto-update', type:'fix'},
            {check:'.env vars', fix:'Append missing', type:'fix'},
            {check:'VPN creds', fix:'Warning', type:'warn'},
            {check:'20 directories', fix:'Auto-create', type:'fix'},
            {check:'Templates', fix:'Auto-copy', type:'fix'},
            {check:'Seerr perms', fix:'Auto-chown', type:'fix'},
          ].map((d, i) => (
            <div class="doc-row">
              <div class="doc-check"><span class="doc-num">{i + 1}</span> {d.check}</div>
              <div class="doc-arrow">&rarr;</div>
              <div class={`doc-fix doc-${d.type}`}>{d.fix}</div>
            </div>
          ))}
        </div>
      </div>

      <!-- Downloads Dashboard -->
      <h3 id="downloads-dashboard">Downloads Dashboard</h3>
      <div class="dg-wrap">
        <div class="flow-vertical fv-narrow">
          <div class="fv-fork fv-fork-top">
            <div class="fv-step fv-cyan fv-sm"><strong>Transmission RPC</strong></div>
            <div class="fv-step fv-amber fv-sm"><strong>SABnzbd API</strong></div>
          </div>
          <div class="fv-arrow"><em>4 parallel curls</em> &darr;</div>
          <div class="fv-step fv-green"><strong>Main Loop</strong><span>100ms poll cycle</span></div>
          <div class="fv-arrow">&darr;</div>
          <div class="fv-step fv-indigo"><strong>Render</strong><span>Speed gauges, progress bars, ETAs</span></div>
          <div class="fv-arrow">&darr;</div>
          <div class="fv-step fv-dim"><strong>Keyboard</strong><span>q = quit, r = refresh</span></div>
        </div>
      </div>

      <!-- Health Checks -->
      <!-- Update Pipeline -->
      <h3 id="update-pipeline">Update Pipeline</h3>
      <div class="dg-wrap">
        <div class="flow-vertical fv-narrow">
          <div class="fv-step fv-indigo"><strong>arr update</strong></div>
          <div class="fv-arrow">&darr;</div>
          <div class="fv-step fv-cyan"><code>git pull --ff-only</code><span>compose.yaml, CLI, templates</span></div>
          <div class="fv-arrow">&darr;</div>
          <div class="fv-step fv-cyan"><code>docker compose pull</code><span>Latest images</span></div>
          <div class="fv-arrow">&darr;</div>
          <div class="fv-step fv-green"><code>docker compose up -d</code><span>Only changed containers recreated</span></div>
        </div>
      </div>

      <!-- Onboarding -->
      <h3 id="onboarding">Onboarding Friends</h3>
      <div class="dg-wrap">
        <div class="pipe-flow">
          {[
            {n:'1', label:'Clone repo', color:'cyan'},
            {n:'2', label:'arr setup', color:'cyan'},
            {n:'3', label:'Edit .env', color:'amber'},
            {n:'4', label:'arr start', color:'green'},
            {n:'5', label:'Open Seerr', color:'green'},
          ].map((s, i) => (
            <Fragment>
              <div class={`pipe-step pipe-${s.color}`}>
                <div class="pipe-num">{s.n}</div>
                <div class="pipe-label">{s.label}</div>
              </div>
              {i < 4 && <div class="pipe-conn">&rarr;</div>}
            </Fragment>
          ))}
        </div>
      </div>
      <p class="dg-p">Friends update with <code>arr update</code> — pulls latest code and Docker images in one command.</p>
    </section>

  </div>
</div>

</Base>


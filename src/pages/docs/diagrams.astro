    .dg-header { padding:30px 0 20px; }
    .zone-grid, .zone-grid-dns { grid-template-columns:1fr; }
    .split-compare { grid-template-columns:1fr; }
    .ia-groups { grid-template-columns:1fr; }
    .cat-grid { grid-template-columns:1fr; }
    .cf-cols { grid-template-columns:1fr; }
    .cmd-fan { grid-template-columns:repeat(2, 1fr); }
    .seq-actors { min-width:600px; }
    .pipe-flow { flex-direction:column; }
    .pipe-conn { transform:rotate(90deg); }
  }
  @media(max-width:480px) {
    .dg-content { padding:0 12px 40px; }
    .cmd-fan { grid-template-columns:1fr; }
    .fv-fork { flex-direction:column; }
    .fv-mini-split { flex-direction:column; }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  // Section reveals
  gsap.utils.toArray<HTMLElement>('.dg-section').forEach(el => {
    gsap.to(el, { opacity:1, y:0, duration:0.6, ease:'power3.out',
      scrollTrigger: { trigger:el, start:'top 88%' }
    });
  });

  // SVG node tooltips
  const tip = document.getElementById('dgTip');
  if (tip) {
    document.querySelectorAll('.dg-n').forEach(node => {
      node.addEventListener('mouseenter', (e) => {
        const info = node.getAttribute('data-tip');
        if (!info) return;
        tip.textContent = info;
        tip.style.display = 'block';
        const wrap = (e.target as Element).closest('.dg-wrap');
        if (!wrap) return;
        const rect = wrap.getBoundingClientRect();
        const nr = (node.querySelector('rect') as SVGRectElement)?.getBoundingClientRect();
        if (!nr) return;
        tip.style.left = Math.max(0, nr.left - rect.left + nr.width / 2 - 130) + 'px';
        tip.style.top = (nr.bottom - rect.top + 8) + 'px';
      });
      node.addEventListener('mouseleave', () => { tip.style.display = 'none'; });
    });
  }

  // Sidebar scroll spy
  const tocLinks = document.querySelectorAll('.dg-sb-link');
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const id = entry.target.getAttribute('id');
        tocLinks.forEach(link => {
          link.classList.toggle('active', link.getAttribute('href') === `#${id}`);
        });
      }
    });
  }, { rootMargin: '-80px 0px -70% 0px' });
  document.querySelectorAll('[id]').forEach(el => observer.observe(el));

  // Mobile sidebar toggle
  const sidebar = document.getElementById('dgSidebar');
  document.getElementById('dgFab')?.addEventListener('click', () => sidebar?.classList.toggle('open'));
  tocLinks.forEach(link => {
    link.addEventListener('click', () => sidebar?.classList.remove('open'));
  });
</script>

</Base>

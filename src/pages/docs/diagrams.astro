  .dg-sb-div { height:1px; background:var(--border); margin:4px 8px; }
  .dg-sb-link { display:block; padding:3px 8px; border-radius:4px; font-size:0.76rem; color:var(--text-dim); text-decoration:none; transition:all 0.15s; border-left:2px solid transparent; }
  .dg-sb-link:hover { color:var(--text); background:rgba(212,160,74,0.04); }
  .dg-sb-link.active { color:var(--gold); border-left-color:var(--gold); background:rgba(212,160,74,0.06); }

  .dg-fab { display:none; position:fixed; bottom:20px; right:20px; z-index:200; width:44px; height:44px; border-radius:50%; background:var(--gold); border:none; cursor:pointer; box-shadow:0 4px 20px rgba(212,160,74,0.4); flex-direction:column; align-items:center; justify-content:center; gap:4px; }
  .dg-fab span { display:block; width:18px; height:2px; background:#1a1204; border-radius:1px; }

  /* ═══ CONTENT ═══ */
  .dg-content { flex:1; min-width:0; padding:0 40px 80px; }
  .dg-header { padding:50px 0 30px; border-bottom:1px solid var(--border); margin-bottom:40px; }
  .dg-header h1 { font-size:clamp(1.8rem,5vw,2.5rem); font-weight:700; background:linear-gradient(135deg,var(--gold),#b8860b); -webkit-background-clip:text; background-clip:text; -webkit-text-fill-color:transparent; }
  .dg-header p { color:var(--text-dim); font-size:1rem; margin-top:8px; line-height:1.6; }

  .dg-section { padding-bottom:60px; border-bottom:1px solid rgba(255,255,255,0.04); margin-bottom:40px; opacity:0; transform:translateY(16px); }
  .dg-section:last-child { border-bottom:none; }
  .dg-section-title { font-size:clamp(1.5rem,4vw,1.9rem); font-weight:700; color:#f1f5f9; margin-bottom:12px; scroll-margin-top:80px; }
  .dg-section h3 { font-size:1.2rem; font-weight:600; color:#e0e6f0; margin:36px 0 12px; scroll-margin-top:80px; }
  .dg-section h4 { font-size:1rem; font-weight:600; color:var(--text-dim); margin:24px 0 8px; scroll-margin-top:80px; }
  .dg-section-desc, .dg-p { color:var(--text-dim); font-size:0.9rem; line-height:1.8; margin-bottom:12px; max-width:700px; }

  /* ═══ DIAGRAM CONTAINER ═══ */
  .dg-wrap { margin:16px 0 24px; background:rgba(15,22,41,0.5); border:1px solid rgba(30,41,59,0.5); border-radius:10px; padding:20px; overflow-x:auto; position:relative; }
  .dg-svg { width:100%; height:auto; display:block; }
  .dg-n { cursor:pointer; transition:filter 0.2s; }
  .dg-n:hover { filter:brightness(1.4); }
  .dg-tip { position:absolute; display:none; max-width:260px; padding:10px 14px; background:#131a2e; border:1px solid var(--border-h); border-radius:8px; font-size:0.78rem; color:var(--text-dim); line-height:1.5; pointer-events:none; z-index:10; box-shadow:0 8px 30px rgba(0,0,0,0.4); }

  /* ═══ TABLES ═══ */
  .dg-table-wrap { margin:16px 0 24px; overflow-x:auto; border-radius:10px; border:1px solid rgba(30,41,59,0.5); }
  .dg-table-wrap table { width:100%; border-collapse:collapse; font-size:0.82rem; }
  .dg-table-wrap thead { background:rgba(15,22,41,0.8); }
  .dg-table-wrap th { text-align:left; padding:10px 14px; color:var(--text-dim); font-weight:600; font-size:0.72rem; text-transform:uppercase; letter-spacing:0.08em; border-bottom:1px solid var(--border); }
  .dg-table-wrap td { padding:8px 14px; color:var(--text-dim); border-bottom:1px solid rgba(255,255,255,0.03); }
  .dg-table-wrap tr:last-child td { border-bottom:none; }
  .dg-table-wrap tr:hover td { background:rgba(255,255,255,0.02); }
  .dg-table-wrap td strong { color:#e0e6f0; }
  .dg-table-wrap td code { font-size:0.78rem; background:rgba(99,102,241,0.1); border:1px solid rgba(99,102,241,0.15); padding:1px 6px; border-radius:4px; color:var(--cyan); }

  /* ═══ CODE BLOCKS ═══ */
  .dg-code { margin:16px 0 24px; background:#080c16; border:1px solid rgba(30,41,59,0.5); border-radius:10px; overflow-x:auto; }
  .dg-code pre { padding:16px 20px; margin:0; font-family:'SF Mono','Fira Code',Consolas,monospace; font-size:0.78rem; line-height:1.7; color:var(--text-dim); }
  .dg-code code { background:none; border:none; padding:0; color:inherit; font-size:inherit; }

  /* ═══ CALLOUTS ═══ */
  .dg-callout { margin:16px 0 24px; padding:16px 20px; background:rgba(15,22,41,0.5); border-left:3px solid var(--border-h); border-radius:0 8px 8px 0; font-size:0.85rem; color:var(--text-dim); line-height:1.7; }
  .dg-callout p { margin-bottom:8px; max-width:none; }
  .dg-callout p:last-child { margin-bottom:0; }
  .dg-callout strong { color:#e0e6f0; }
  .dg-callout-info { border-left-color:var(--cyan); }
  .dg-callout-warn { border-left-color:var(--amber); }

  /* ═══ ZONE GRID ═══ */
  .zone-grid { display:grid; grid-template-columns:1fr 1.5fr 0.8fr; gap:12px; }
  .zone-grid-dns { grid-template-columns:1fr 1fr 1fr; }
  .zone { border-radius:10px; padding:14px; }
  .zone-vpn { background:rgba(16,185,129,0.04); border:1px solid rgba(16,185,129,0.15); }
  .zone-bridge { background:rgba(34,211,238,0.03); border:1px solid rgba(34,211,238,0.1); }
  .zone-host { background:rgba(99,102,241,0.03); border:1px solid rgba(99,102,241,0.1); }
  .zone-label { font-size:0.7rem; font-weight:600; text-transform:uppercase; letter-spacing:0.08em; margin-bottom:10px; }
  .zone-vpn .zone-label { color:#6ee7b7; }
  .zone-bridge .zone-label { color:#67e8f9; }
  .zone-host .zone-label { color:#a5b4fc; }
  .zone-nodes { display:flex; flex-direction:column; align-items:center; gap:4px; }
  .zone-nodes-grid { display:grid; grid-template-columns:1fr 1fr; gap:6px; }
  .zone-conn { color:var(--text-muted); font-size:0.7rem; text-align:center; }
  .zone-pill { margin-top:10px; text-align:center; font-size:0.68rem; font-weight:600; color:#6ee7b7; background:rgba(16,185,129,0.1); border:1px solid rgba(16,185,129,0.2); border-radius:20px; padding:4px 12px; }
  .zn { padding:8px 12px; border-radius:6px; font-size:0.78rem; font-weight:600; text-align:center; width:100%; }
  .zn span { display:block; font-size:0.65rem; font-weight:400; opacity:0.5; margin-top:1px; }
  .zn-vpn { background:rgba(16,185,129,0.08); border:1px solid rgba(16,185,129,0.18); color:#a7f3d0; }
  .zn-bridge { background:rgba(34,211,238,0.05); border:1px solid rgba(34,211,238,0.1); color:#e0f2fe; }
  .zn-host { background:rgba(99,102,241,0.06); border:1px solid rgba(99,102,241,0.15); color:#c4b5fd; }
  .zn-lg { padding:16px 12px; font-size:0.95rem; }

  /* ═══ HARDLINK DEMO ═══ */
  .hl-demo { display:flex; flex-direction:column; gap:4px; }
  .hl-path { display:flex; align-items:center; gap:8px; flex-wrap:wrap; }
  .hl-badge { font-size:0.65rem; font-weight:600; padding:2px 8px; border-radius:4px; }
  .hl-b-amber { background:rgba(251,191,36,0.15); color:var(--yellow); }
  .hl-b-pink { background:rgba(244,114,182,0.15); color:var(--pink); }
  .hl-inode { font-size:0.68rem; color:var(--emerald); font-family:'SF Mono','Fira Code',monospace; }
  .hl-wire { display:flex; align-items:center; gap:0; padding:8px 0; }
  .hl-dot { width:8px; height:8px; border-radius:50%; background:var(--emerald); flex-shrink:0; }
  .hl-line { flex:1; height:2px; background:var(--emerald); opacity:0.3; }
  .hl-tag { font-size:0.72rem; color:var(--emerald); font-weight:600; padding:0 12px; white-space:nowrap; }

  /* ═══ TIER GRID ═══ */
  .tier-grid { display:flex; flex-direction:column; gap:10px; }
  .tier { border-radius:8px; padding:14px; }
  .tier-green { background:rgba(74,222,128,0.04); border:1px solid rgba(74,222,128,0.12); }
  .tier-blue { background:rgba(34,211,238,0.03); border:1px solid rgba(34,211,238,0.1); }
  .tier-amber { background:rgba(251,191,36,0.03); border:1px solid rgba(251,191,36,0.1); }
  .tier-label { font-size:0.75rem; font-weight:600; color:var(--text-dim); margin-bottom:8px; }
  .tier-green .tier-label { color:#6ee7b7; }
  .tier-blue .tier-label { color:#67e8f9; }
  .tier-amber .tier-label { color:#fde68a; }
  .tier-chips { display:flex; flex-wrap:wrap; gap:4px; }
  .tier-chip { font-size:0.72rem; padding:4px 10px; border-radius:4px; font-weight:500; }
  .tc-green { background:rgba(74,222,128,0.08); border:1px solid rgba(74,222,128,0.15); color:#bbf7d0; }
  .tc-blue { background:rgba(34,211,238,0.06); border:1px solid rgba(34,211,238,0.12); color:#e0f2fe; }
  .tc-amber { background:rgba(251,191,36,0.06); border:1px solid rgba(251,191,36,0.1); color:#fde68a; }

  /* ═══ VERTICAL FLOW ═══ */
  .flow-vertical { display:flex; flex-direction:column; align-items:center; gap:0; }
  .fv-narrow { max-width:500px; margin:0 auto; }
  .fv-step { width:100%; padding:12px 16px; border-radius:8px; text-align:center; font-size:0.85rem; }
  .fv-step strong { display:block; }
  .fv-step span { font-size:0.75rem; color:var(--text-muted); display:block; margin-top:2px; }
  .fv-step code { font-size:0.82rem; }
  .fv-sm { padding:8px 12px; font-size:0.78rem; }
  .fv-arrow { color:var(--text-muted); padding:4px 0; font-size:0.8rem; text-align:center; }
  .fv-arrow em { font-size:0.7rem; font-style:normal; color:var(--text-muted); }
  .fv-arrow-label { color:var(--text-muted); padding:4px 0; font-size:0.75rem; text-align:center; }
  .fv-arrow-label em { font-style:italic; }
  .fv-cyan { background:rgba(34,211,238,0.06); border:1px solid rgba(34,211,238,0.15); color:#e0f2fe; }
  .fv-green { background:rgba(74,222,128,0.06); border:1px solid rgba(74,222,128,0.15); color:#bbf7d0; }
  .fv-red { background:rgba(248,113,113,0.06); border:1px solid rgba(248,113,113,0.15); color:#fca5a5; }
  .fv-block { background:rgba(248,113,113,0.1); border:2px solid rgba(248,113,113,0.3); color:#fca5a5; font-weight:700; }
  .fv-amber { background:rgba(251,191,36,0.06); border:1px solid rgba(251,191,36,0.15); color:#fde68a; }
  .fv-indigo { background:rgba(99,102,241,0.06); border:1px solid rgba(99,102,241,0.15); color:#c4b5fd; }
  .fv-pink { background:rgba(244,114,182,0.06); border:1px solid rgba(244,114,182,0.15); color:#fce7f3; }
  .fv-dim { background:var(--surface); border:1px solid var(--border); color:var(--text-dim); }

  /* Forks */
  .fv-fork { display:flex; gap:10px; width:100%; }
  .fv-fork-top { margin-bottom:4px; }
  .fv-branch { flex:1; display:flex; flex-direction:column; align-items:center; gap:4px; }
  .fv-branch-label { font-size:0.7rem; color:var(--text-muted); font-weight:500; }

  /* Loop blocks */
  .fv-loop { border:1px dashed rgba(34,211,238,0.2); border-radius:8px; padding:12px; background:rgba(34,211,238,0.02); }
  .fv-loop-label { font-size:0.68rem; color:var(--cyan); font-weight:600; text-transform:uppercase; letter-spacing:0.06em; margin-bottom:8px; }
  .fv-loop-body { display:flex; flex-direction:column; gap:4px; }
  .fv-mini { font-size:0.78rem; color:var(--text-dim); padding:4px 8px; background:rgba(0,0,0,0.15); border-radius:4px; text-align:center; }
  .fv-mini-green { color:#4ade80; font-weight:600; }
  .fv-mini-split { display:flex; gap:8px; }
  .fv-mini-opt { flex:1; font-size:0.72rem; padding:4px 8px; border-radius:4px; text-align:center; background:rgba(0,0,0,0.15); }
  .fv-mini-opt.fv-mini-green { color:#4ade80; }
  .fv-mini-opt.fv-mini-amber { color:#fde68a; }

  /* ═══ SPLIT COMPARE ═══ */
  .split-compare { display:grid; grid-template-columns:1fr 1fr; gap:12px; }
  .split-col { border-radius:8px; padding:14px; }
  .split-cyan { background:rgba(34,211,238,0.03); border:1px solid rgba(34,211,238,0.1); }
  .split-red { background:rgba(248,113,113,0.03); border:1px solid rgba(248,113,113,0.1); }
  .split-head { font-size:0.75rem; font-weight:600; margin-bottom:10px; }
  .split-cyan .split-head { color:#67e8f9; }
  .split-red .split-head { color:#fca5a5; }
  .split-items { display:flex; flex-direction:column; gap:6px; }
  .split-item { font-size:0.78rem; color:var(--text-dim); padding:6px 10px; background:rgba(0,0,0,0.15); border-radius:4px; display:flex; justify-content:space-between; align-items:center; }
  .split-item span { font-size:0.68rem; color:var(--text-muted); }

  /* ═══ INDEXER ARCHITECTURE ═══ */
  .indexer-arch { display:flex; flex-direction:column; align-items:center; gap:10px; }
  .ia-hub { padding:12px 24px; border-radius:8px; background:rgba(34,211,238,0.08); border:1px solid rgba(34,211,238,0.2); color:#e0f2fe; font-size:0.9rem; text-align:center; }
  .ia-hub span { display:block; font-size:0.7rem; color:var(--text-muted); }
  .ia-arrows { display:flex; gap:40px; }
  .ia-arrow { font-size:0.72rem; color:var(--text-muted); text-align:center; }
  .ia-groups { display:grid; grid-template-columns:1fr 1fr; gap:12px; width:100%; }
  .ia-group { border-radius:8px; padding:12px; }
  .ia-torrent { background:rgba(34,211,238,0.03); border:1px solid rgba(34,211,238,0.1); }
  .ia-usenet { background:rgba(251,191,36,0.03); border:1px solid rgba(251,191,36,0.1); }
  .ia-group-label { font-size:0.7rem; font-weight:600; margin-bottom:8px; }
  .ia-torrent .ia-group-label { color:#67e8f9; }
  .ia-usenet .ia-group-label { color:#fde68a; }
  .ia-chips { display:flex; flex-wrap:wrap; gap:4px; }
  .ia-chip { font-size:0.68rem; padding:3px 8px; border-radius:4px; background:rgba(34,211,238,0.06); border:1px solid rgba(34,211,238,0.1); color:#e0f2fe; }
  .ia-chip-amber { background:rgba(251,191,36,0.06); border-color:rgba(251,191,36,0.1); color:#fde68a; }
  .ia-sync { font-size:0.72rem; color:var(--text-muted); }
  .ia-targets { display:flex; gap:8px; }
  .ia-target { padding:6px 14px; border-radius:6px; font-size:0.78rem; font-weight:500; background:rgba(99,102,241,0.06); border:1px solid rgba(99,102,241,0.12); color:#c4b5fd; }

  /* ═══ CATEGORY ROUTING ═══ */
  .cat-grid { display:grid; grid-template-columns:1fr 1fr 1fr; gap:12px; }
  .cat-head { font-size:0.72rem; font-weight:600; color:var(--text-dim); text-transform:uppercase; letter-spacing:0.06em; margin-bottom:8px; padding-bottom:6px; border-bottom:1px solid var(--border); }
  .cat-app { font-size:0.78rem; padding:5px 10px; margin-bottom:4px; border-radius:4px; background:rgba(34,211,238,0.05); border:1px solid rgba(34,211,238,0.1); color:#e0f2fe; }
  .cat-dir { font-size:0.72rem; padding:5px 10px; margin-bottom:4px; border-radius:4px; background:rgba(0,0,0,0.15); color:var(--text-dim); font-family:'SF Mono','Fira Code',monospace; }
  .cat-dir-amber { background:rgba(251,191,36,0.04); color:#fde68a; }

  /* ═══ CUSTOM FORMAT COLS ═══ */
  .cf-cols { display:grid; grid-template-columns:1fr 1fr; gap:16px; }
  .cf-head { font-size:0.78rem; font-weight:600; margin-bottom:8px; }
  .cf-head-green { color:#4ade80; }
  .cf-head-red { color:#f87171; }
  .cf-list { display:flex; flex-direction:column; gap:2px; }
  .cf-item { display:flex; justify-content:space-between; align-items:center; padding:4px 8px; border-radius:4px; font-size:0.78rem; background:rgba(0,0,0,0.15); color:var(--text-dim); }
  .cf-score { color:#4ade80; font-weight:600; font-family:'SF Mono','Fira Code',monospace; font-size:0.75rem; }
  .cf-reject { color:#f87171; font-weight:600; font-size:0.68rem; text-transform:uppercase; }

  /* ═══ SEQUENCE DIAGRAMS ═══ */
  .seq { overflow-x:auto; }
  .seq-actors { display:grid; grid-template-columns:repeat(8, 1fr); gap:4px; margin-bottom:12px; }
  .seq-actor { text-align:center; padding:8px 4px; border-radius:6px; font-size:0.72rem; font-weight:600; color:#e0e6f0; background:var(--surface); border:1px solid var(--border); }
  .seq-body { display:flex; flex-direction:column; gap:6px; padding:0 4px; min-width:600px; }
  .seq-msg { position:relative; padding:4px 0; font-size:0.72rem; color:var(--text-dim); display:flex; align-items:center; }
  .seq-msg::before { content:''; position:absolute; top:50%; height:1px; background:rgba(100,116,139,0.3); left:calc((100% / 8) * var(--from) + (100% / 16)); right:calc(100% - (100% / 8) * var(--to) - (100% / 16)); }
  .seq-msg::after { content:''; position:absolute; top:50%; right:calc(100% - (100% / 8) * var(--to) - (100% / 16)); width:0; height:0; border-top:4px solid transparent; border-bottom:4px solid transparent; border-left:6px solid rgba(100,116,139,0.4); transform:translateY(-50%); }
  .seq-msg span { position:relative; z-index:1; background:rgba(15,22,41,0.9); padding:2px 8px; border-radius:3px; white-space:nowrap; margin-left:calc((100% / 8) * min(var(--from), var(--to)) + (100% / 16) + 8px); }
  .seq-msg-ret::before { background:rgba(100,116,139,0.15); }
  .seq-msg-ret::after { border-left:none; border-right:6px solid rgba(100,116,139,0.25); left:calc((100% / 8) * min(var(--from), var(--to)) + (100% / 16)); right:auto; }
  .seq-msg-hl span { color:#4ade80; font-weight:600; }
  .seq-msg-mv span { color:#fde68a; font-weight:600; }
  .seq-msg-self span { color:var(--cyan); font-style:italic; }

  .seq-block { border:1px solid rgba(34,211,238,0.1); border-radius:6px; padding:8px; margin:4px 0; background:rgba(34,211,238,0.02); }
  .seq-block-alt { }
  .seq-block-label { font-size:0.62rem; font-weight:700; color:var(--cyan); text-transform:uppercase; letter-spacing:0.08em; margin-bottom:4px; }
  .seq-block-cond { font-size:0.68rem; color:var(--text-muted); font-style:italic; margin-bottom:4px; }
  .seq-block-divider { height:1px; background:rgba(34,211,238,0.1); margin:6px 0; }

  /* ═══ COMMAND MAP ═══ */
  .cmd-map { display:flex; flex-direction:column; align-items:center; gap:12px; }
  .cmd-hub { padding:12px 24px; border-radius:8px; background:rgba(212,160,74,0.08); border:1px solid rgba(212,160,74,0.2); color:var(--gold); font-size:0.95rem; text-align:center; }
  .cmd-hub code { color:var(--gold); background:none; border:none; font-size:1rem; font-weight:700; }
  .cmd-hub span { font-size:0.72rem; color:var(--text-muted); margin-left:4px; }
  .cmd-fan { display:grid; grid-template-columns:repeat(4, 1fr); gap:6px; width:100%; }
  .cmd-leaf { padding:8px 12px; border-radius:6px; background:var(--surface); border:1px solid var(--border); transition:all 0.2s; }
  .cmd-leaf:hover { transform:translateY(-2px); border-color:var(--border-h); }
  .cmd-leaf code { font-size:0.75rem; display:block; background:none; border:none; padding:0; }
  .cmd-leaf span { font-size:0.65rem; color:var(--text-muted); display:block; margin-top:2px; }
  .cmd-cyan code { color:var(--cyan); }
  .cmd-green code { color:#4ade80; }
  .cmd-red code { color:#f87171; }
  .cmd-amber code { color:#fde68a; }
  .cmd-indigo code { color:#a5b4fc; }
  .cmd-dim code { color:var(--text-dim); }

  /* ═══ PIPELINE FLOW ═══ */
  .pipe-flow { display:flex; align-items:center; gap:0; flex-wrap:wrap; justify-content:center; }
  .pipe-step { display:flex; align-items:center; gap:8px; padding:10px 16px; border-radius:8px; }
  .pipe-num { font-size:0.72rem; font-weight:700; width:22px; height:22px; border-radius:50%; display:flex; align-items:center; justify-content:center; }
  .pipe-label { font-size:0.82rem; font-weight:500; }
  .pipe-conn { color:var(--text-muted); padding:0 4px; font-size:0.8rem; }
  .pipe-cyan { background:rgba(34,211,238,0.05); border:1px solid rgba(34,211,238,0.12); color:#e0f2fe; }
  .pipe-cyan .pipe-num { background:rgba(34,211,238,0.15); color:#67e8f9; }
  .pipe-amber { background:rgba(251,191,36,0.05); border:1px solid rgba(251,191,36,0.12); color:#fde68a; }
  .pipe-amber .pipe-num { background:rgba(251,191,36,0.15); color:#fbbf24; }
  .pipe-green { background:rgba(74,222,128,0.05); border:1px solid rgba(74,222,128,0.12); color:#bbf7d0; }
  .pipe-green .pipe-num { background:rgba(74,222,128,0.15); color:#4ade80; }

  /* ═══ DOCTOR GRID ═══ */
  .doctor-grid { display:flex; flex-direction:column; gap:6px; }
  .doc-row { display:grid; grid-template-columns:1fr auto auto; gap:8px; align-items:center; }
  .doc-check { font-size:0.82rem; color:var(--text-dim); padding:8px 12px; background:var(--surface); border:1px solid var(--border); border-radius:6px; }
  .doc-num { font-weight:700; color:var(--cyan); margin-right:4px; }
  .doc-arrow { color:var(--text-muted); font-size:0.8rem; }
  .doc-fix { font-size:0.78rem; padding:6px 14px; border-radius:6px; font-weight:600; }
  .doc-fix { background:rgba(74,222,128,0.06); border:1px solid rgba(74,222,128,0.15); color:#4ade80; }
  .doc-warn { background:rgba(251,191,36,0.06); border:1px solid rgba(251,191,36,0.15); color:#fde68a; }

  /* ═══ RESPONSIVE ═══ */
  @media(max-width:900px) {
    .dg-sidebar { position:fixed; left:0; top:56px; bottom:0; z-index:50; background:var(--bg); transform:translateX(-100%); transition:transform 0.3s; border-right:1px solid var(--border); width:240px; }
    .dg-sidebar.open { transform:translateX(0); }
    .dg-fab { display:flex; }

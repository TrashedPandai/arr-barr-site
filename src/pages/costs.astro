---
import Base from '../layouts/Base.astro';

const tiers = [
  {
    name: 'Torrents Only',
    price: '~$10',
    period: '/month',
    color: 'green',
    highlight: true,
    items: [
      'VPN with WireGuard (~$10/mo)',
      'Public torrent indexers (free)',
      'All 15 services included',
      'Jellyfin, Kavita, Audiobookshelf',
      'The arr CLI tool',
      'Unlimited users & streams',
    ],
    note: 'VPN is the only cost. Everything else is free and open source.',
  },
  {
    name: 'Torrents + Usenet',
    price: '~$20',
    period: '/month',
    color: 'indigo',
    highlight: false,
    items: [
      'VPN with WireGuard (~$10/mo)',
      '1 usenet provider (~$10/mo)',
      '1 free usenet indexer ($0)',
      'Two download sources',
      'Better availability',
    ],
    note: 'Adding usenet fills gaps that torrents miss. Most people land here.',
  },
  {
    name: 'The Full Spread',
    price: '~$30',
    period: '/month',
    color: 'purple',
    highlight: false,
    items: [
      'VPN with WireGuard (~$10/mo)',
      '2-3 usenet providers (~$15/mo)',
      '2+ paid usenet indexers (~$15-30/yr)',
      'Better completion rates',
      'More content found',
      'Redundant sources',
    ],
    note: 'Multiple providers fill each other\'s gaps. Near-100% success rate on downloads.',
  },
];

const usenetConcepts = [
  {
    title: 'Providers',
    icon: '\u2B07',
    desc: 'Host content on server networks ("backbones"). Mixing providers across backbones improves reliability.',
    color: 'cyan',
  },
  {
    title: 'Indexers',
    icon: '\uD83D\uDD0D',
    desc: 'Search engines that find what\'s available. Free indexers exist but paid ones find more.',
    color: 'yellow',
  },
];

const usenetTiers = [
  {
    name: 'Budget',
    price: '~$5',
    period: '/mo',
    color: 'emerald',
    rows: [
      { label: '1 budget provider', cost: '$3-5/mo' },
      { label: '1 free indexer', cost: '$0' },
    ],
    note: 'Gets you started. Most things work fine.',
  },
  {
    name: 'Mid-Range',
    price: '~$10-12',
    period: '/mo',
    color: 'indigo',
    rows: [
      { label: '1 premium provider', cost: '$8-10/mo' },
      { label: '1 block account (fill)', cost: '~$2/mo equiv.' },
      { label: '2 paid indexers', cost: '~$1.50/mo equiv.' },
    ],
    note: 'The sweet spot for most people.',
  },
  {
    name: 'Max Coverage',
    price: '~$20-25',
    period: '/mo',
    color: 'purple',
    rows: [
      { label: '2 unlimited providers', cost: '$15-18/mo' },
      { label: '1 block account (fill)', cost: '~$2/mo equiv.' },
      { label: '3 paid indexers', cost: '~$2.50/mo equiv.' },
    ],
    note: 'Near-100% completion. The endgame.',
  },
];

const hardware = [
  { name: 'Synology DS920+', price: '$550', desc: 'Intel QSV transcoding, 4 bays, low power.', tag: 'Recommended' },
  { name: 'Used Mini PC', price: '$100-200', desc: 'Intel N100/N5105. Great transcoding.', tag: 'Budget' },
  { name: 'Old Desktop', price: '$0', desc: 'Runs Docker and stays on? It works.', tag: 'Free' },
];
---

<Base title="arr-barr — Costs" description="What's free, what's paid, and what's optional.">

<div class="page-header">
  <h1>What It Costs</h1>
  <p>Honest numbers, no surprises</p>
</div>

<div class="costs-container">

  <div class="costs-intro gs">
    <p>The software is 100% free. The services that make it useful cost money. Here's the full picture so you can decide what makes sense for you.</p>
  </div>

  <!-- Tiers -->
  <div class="tier-grid">
    {tiers.map(tier => (
      <div class={`tier-card tier-${tier.color} ${tier.highlight ? 'tier-highlight' : ''} gs`}>
        {tier.highlight && <div class="tier-badge">Most common</div>}
        <h2 class="tier-name">{tier.name}</h2>
        <div class="tier-price">
          <span class="tp-amount">{tier.price}</span>
          <span class="tp-period">{tier.period}</span>
        </div>
        <ul class="tier-items">
          {tier.items.map(item => (
            <li>{item}</li>
          ))}
        </ul>
        <p class="tier-note">{tier.note}</p>
      </div>
    ))}
  </div>

  <!-- Usenet Deep Dive -->
  <section class="usenet-section gs">
    <h2>Usenet Deep Dive</h2>
    <p class="usenet-intro">Usenet is the second download source in the stack. It works differently from torrents — here's how the costs break down and what you actually need.</p>

    <div class="usenet-concepts grid-no-orphan">
      {usenetConcepts.map(c => (
        <div class={`uc-card uc-${c.color}`}>
          <div class="uc-icon">{c.icon}</div>
          <h3>{c.title}</h3>
          <p>{c.desc}</p>
        </div>
      ))}
    </div>

    <div class="usenet-tier-grid">
      {usenetTiers.map(tier => (
        <div class={`usenet-tier-card ut-${tier.color} gs`}>
          <h3>{tier.name}</h3>
          <div class="ut-price">
            <span class="ut-amount">{tier.price}</span>
            <span class="ut-period">{tier.period}</span>
          </div>
          <div class="ut-rows">
            {tier.rows.map(row => (
              <div class="ut-row">
                <span>{row.label}</span>
                <span class="ut-cost">{row.cost}</span>
              </div>
            ))}
          </div>
          <p class="ut-note">{tier.note}</p>
        </div>
      ))}
    </div>

    <div class="usenet-tip gs">
      <p><strong>Tip:</strong> One provider per backbone, block accounts for fill, 2-3 indexers. Black Friday is the best time to lock in annual pricing.</p>
    </div>
  </section>

  <!-- Hardware -->
  <section class="hw-section gs">
    <h2>Hardware</h2>
    <p class="hw-intro">One-time cost. Use what you have or buy something dedicated.</p>
    <div class="hw-grid grid-no-orphan">
      {hardware.map(hw => (
        <div class="hw-card">
          <div class="hw-top">
            <h3>{hw.name}</h3>
            <span class={`hw-tag ${hw.tag === 'Not recommended' ? 'hw-warn' : ''}`}>{hw.tag}</span>
          </div>
          <div class="hw-price">{hw.price}</div>
          <p>{hw.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Bottom line -->
  <div class="bottom-line gs">
    <h2>The Bottom Line</h2>
    <div class="bl-grid">
      <div class="bl-card">
        <div class="bl-label">Cheapest way in</div>
        <div class="bl-val bl-green">~$10/mo</div>
        <p>VPN + free torrent indexers. That's it.</p>
      </div>
      <div class="bl-card">
        <div class="bl-label">Typical monthly</div>
        <div class="bl-val bl-indigo">~$20-30</div>
        <p>VPN + usenet provider + 1-2 indexers</p>
      </div>
      <div class="bl-card">
        <div class="bl-label">Software cost</div>
        <div class="bl-val bl-gold">$0</div>
        <p>Every service in the stack is free and open source, forever</p>
      </div>
    </div>
  </div>

</div>

</Base>

<style>
  .page-header { text-align:center; padding:50px 24px 10px; }
  .page-header h1 {
    font-size:clamp(1.8rem,5vw,2.5rem); font-weight:700;
    background:linear-gradient(135deg,var(--indigo),var(--purple));
    -webkit-background-clip:text; background-clip:text;
    -webkit-text-fill-color:transparent;
  }
  .page-header p { color:var(--text-dim); font-size:1.05rem; margin-top:6px; }

  .costs-container { max-width:960px; margin:0 auto; padding:0 24px 60px; }

  .costs-intro { text-align:center; max-width:640px; margin:20px auto 40px; }
  .costs-intro p { color:var(--text-dim); font-size:1rem; line-height:1.7; }

  /* Tier grid */
  .tier-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:16px; margin-bottom:50px; }

  .tier-card {
    background:var(--surface); border:1px solid var(--border);
    border-radius:14px; padding:28px 24px; position:relative;
  }
  .tier-highlight {
    border-color:rgba(99,102,241,0.35);
    box-shadow:0 0 40px rgba(99,102,241,0.08);
  }
  .tier-badge {
    position:absolute; top:-10px; left:50%; transform:translateX(-50%);
    background:linear-gradient(135deg,var(--indigo),var(--purple));
    color:#fff; font-size:0.68rem; font-weight:600;
    padding:3px 14px; border-radius:20px;
  }
  .tier-name { font-size:1rem; font-weight:600; margin-bottom:12px; }
  .tier-green .tier-name { color:#6ee7b7; }
  .tier-indigo .tier-name { color:#a5b4fc; }
  .tier-purple .tier-name { color:#c4b5fd; }

  .tier-price { margin-bottom:16px; }
  .tp-amount { font-size:2rem; font-weight:800; color:#f1f5f9; }
  .tp-period { font-size:0.85rem; color:var(--text-muted); margin-left:4px; }

  .tier-items { list-style:none; padding:0; margin-bottom:16px; }
  .tier-items li {
    padding:6px 0; font-size:0.85rem; color:var(--text-dim);
    border-bottom:1px solid rgba(30,41,59,0.3);
    display:flex; align-items:center; gap:8px;
  }
  .tier-items li::before {
    content:''; width:5px; height:5px; border-radius:50%;
    background:var(--text-muted); flex-shrink:0;
  }
  .tier-items li:last-child { border-bottom:none; }
  .tier-note { font-size:0.78rem; color:var(--text-muted); line-height:1.6; font-style:italic; }

  /* Usenet Deep Dive */
  .usenet-section { margin-bottom:50px; }
  .usenet-section > h2 { font-size:1.3rem; color:#f1f5f9; margin-bottom:4px; }
  .usenet-intro { color:var(--text-dim); font-size:0.92rem; margin-bottom:24px; line-height:1.7; }

  .usenet-concepts { display:grid; grid-template-columns:repeat(2,1fr); gap:12px; margin-bottom:24px; }
  .uc-card {
    background:var(--surface); border:1px solid var(--border);
    border-radius:12px; padding:20px; border-top:2px solid var(--border);
  }
  .uc-card.uc-cyan { border-top-color:var(--cyan); }
  .uc-card.uc-yellow { border-top-color:var(--yellow); }
  .uc-icon { font-size:1.5rem; margin-bottom:8px; }
  .uc-card h3 { font-size:0.95rem; font-weight:600; margin-bottom:8px; }
  .uc-cyan h3 { color:var(--cyan); }
  .uc-yellow h3 { color:var(--yellow); }
  .uc-card p { font-size:0.82rem; color:var(--text-dim); line-height:1.7; }

  .usenet-tier-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:16px; margin-bottom:24px; }
  .usenet-tier-card {
    background:var(--surface); border:1px solid var(--border);
    border-radius:14px; padding:24px 20px;
  }
  .usenet-tier-card h3 { font-size:1rem; font-weight:600; margin-bottom:10px; }
  .ut-emerald h3 { color:#6ee7b7; }
  .ut-indigo h3 { color:#a5b4fc; }
  .ut-purple h3 { color:#c4b5fd; }
  .ut-price { margin-bottom:14px; }
  .ut-amount { font-size:2rem; font-weight:800; color:#f1f5f9; }
  .ut-period { font-size:0.85rem; color:var(--text-muted); margin-left:4px; }
  .ut-rows { margin-bottom:14px; }
  .ut-row {
    display:flex; justify-content:space-between; align-items:center;
    padding:7px 0; font-size:0.82rem; color:var(--text-dim);
    border-bottom:1px dashed rgba(30,41,59,0.4);
  }
  .ut-row:last-child { border-bottom:none; }
  .ut-cost { color:var(--text-muted); font-weight:500; font-size:0.78rem; white-space:nowrap; }
  .ut-note { font-size:0.78rem; color:var(--text-muted); line-height:1.6; font-style:italic; }

  .usenet-tip {
    background:var(--surface); border:1px solid var(--border);
    border-radius:12px; padding:16px 20px;
  }
  .usenet-tip p { font-size:0.82rem; color:var(--text-dim); line-height:1.7; }
  .usenet-tip strong { color:#e0e6f0; }

  /* Hardware */
  .hw-section { margin-bottom:50px; }
  .hw-section h2 { font-size:1.3rem; color:#f1f5f9; margin-bottom:4px; }
  .hw-intro { color:var(--text-dim); font-size:0.92rem; margin-bottom:16px; }
  .hw-grid { display:grid; grid-template-columns:repeat(2,1fr); gap:12px; }

  .hw-card {
    background:var(--surface); border:1px solid var(--border);
    border-radius:12px; padding:18px;
  }
  .hw-top { display:flex; align-items:center; justify-content:space-between; margin-bottom:4px; }
  .hw-card h3 { font-size:0.95rem; color:#e0e6f0; }
  .hw-tag {
    font-size:0.65rem; font-weight:500; padding:2px 8px; border-radius:4px;
    background:rgba(99,102,241,0.1); color:var(--indigo);
    border:1px solid rgba(99,102,241,0.2);
  }
  .hw-warn { background:rgba(248,113,113,0.1); color:var(--red); border-color:rgba(248,113,113,0.2); }
  .hw-price { font-size:1.2rem; font-weight:700; color:var(--yellow); margin-bottom:6px; }
  .hw-card p { font-size:0.82rem; color:var(--text-dim); line-height:1.6; }

  /* Bottom line */
  .bottom-line { text-align:center; padding:30px 0 10px; border-top:1px solid rgba(30,41,59,0.4); }
  .bottom-line h2 { font-size:1.3rem; color:#f1f5f9; margin-bottom:20px; }
  .bl-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:16px; }

  .bl-card {
    background:var(--surface); border:1px solid var(--border);
    border-radius:14px; padding:24px 18px;
  }
  .bl-label { font-size:0.78rem; color:var(--text-muted); margin-bottom:8px; text-transform:uppercase; letter-spacing:0.05em; }
  .bl-val { font-size:2.2rem; font-weight:800; margin-bottom:8px; }
  .bl-green { color:#4ade80; }
  .bl-indigo { color:#818cf8; }
  .bl-gold { color:#d4a04a; }
  .bl-card p { font-size:0.78rem; color:var(--text-dim); line-height:1.5; }

  .gs { opacity:0; transform:translateY(20px); }

  @media(max-width:768px) {
    .tier-grid { grid-template-columns:1fr; }
    .usenet-concepts { grid-template-columns:1fr; }
    .usenet-tier-grid { grid-template-columns:1fr; }
    .hw-grid { grid-template-columns:1fr; }
    .bl-grid { grid-template-columns:1fr; }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  gsap.utils.toArray<HTMLElement>('.gs').forEach(el => {
    gsap.to(el, { opacity:1, y:0, duration:0.7, ease:'power3.out',
      scrollTrigger: { trigger:el, start:'top 85%' }
    });
  });
</script>
